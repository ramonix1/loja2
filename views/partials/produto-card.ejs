<div class="produto-card">
  <a href="/produto/<%= produto.id %>" style="display:block; text-decoration:none; color:inherit;">
    <img
      src="<%= produto.primeira_imagem || '/images/sem-imagem.png' %>"
      alt="<%= produto.nome %>"
      class="produto-img"
      onerror="this.src='https://placehold.co/400x220/eee/aaa?text=Sem+Imagem'">

    <div class="produto-body">
      <h2 class="produto-title"><%= produto.nome %></h2>
      <% if(produto.subtitulo){ %>
        <p class="produto-subtitle"><%= produto.subtitulo %></p>
      <% } %>
      <div class="produto-preco">R$ <%= Number(produto.valor).toFixed(2).replace('.',',') %></div>
    </div>
  </a>
  <div class="produto-body" style="padding-top:0;">
    <div style="display:flex;gap:8px;margin-top:10px;">
      <a href="/produto/<%= produto.id %>" class="btn btn-outline" style="flex:1;font-size:12px;padding:8px;text-align:center;text-decoration:none;">Ver detalhes</a>
      <button class="btn btn-primary btn-add-cart" data-id="<%= produto.id %>" style="flex:1;font-size:12px;padding:8px;">🛒 Adicionar</button>
    </div>
  </div>
</div>
