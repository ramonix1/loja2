<style>
  :root {
    --cor-primaria: <%= locals.loja?.cor_primaria || '#2563eb' %>;
  }
  .btn-primary, .btn-hero, .banner-cta { background-color: var(--cor-primaria) !important; }
  .btn-primary:hover, .btn-hero:hover, .banner-cta:hover { filter: brightness(0.9); }
  .cart-badge { background-color: var(--cor-primaria) !important; }
</style>

<% if (locals.loja?.favicon) { %>
  <link rel="icon" href="<%= locals.loja.favicon %>">
<% } %>

<nav class="navbar">
  <a href="/" class="logo" style="display:flex;align-items:center;gap:10px;text-decoration:none;">
    <% if (locals.loja?.logo) { %>
      <img src="<%= locals.loja.logo %>" alt="<%= locals.loja.nome %>"
           style="height:40px;max-width:160px;object-fit:contain;">
    <% } else { %>
      <div style="display:flex;align-items:center;width:24px;height:24px;"><%- icon('shopping_cart') %></div>
      <%= locals.loja?.nome || 'Lojão' %>
    <% } %>
  </a>

  <div class="nav-links" style="align-items:center;">
    <a href="/">Home</a>
    <% if (locals.usuario) { %>

      <a href="/meus-pedidos" style="color:#d1d5db;text-decoration:none;font-size:14px;font-weight:500;">Pedidos</a>
      <a href="/carrinho" class="cart-link" id="cartLink" title="Meu Carrinho" style="display:flex;align-items:center;position:relative;">
        <span class="cart-icon" style="display:flex;align-items:center;width:24px;height:24px;"><%- icon('shopping_cart') %></span>
        <span class="cart-badge" id="cartBadge" style="display:none;">0</span>
      </a>

      <% if (locals.usuario.role === 'admin') { %>
        <a href="/admin">Admin</a>
        <a href="/admin/pedidos" style="color:#d1d5db;text-decoration:none;font-size:14px;font-weight:500;">Pedidos</a>
      <% } %>

      <div style="display:flex;align-items:center;gap:12px;">
        <span style="font-size:0.85rem;color:#9ca3af;">Olá, <%= locals.usuario.nome.split(' ')[0] %></span>
        <form method="POST" action="/logout" style="margin:0;">
          <input type="hidden" name="_csrf" value="<%= locals.csrfToken %>">
          <button type="submit" class="btn btn-secondary" style="font-size:0.8rem;padding:6px 14px;">Sair</button>
        </form>
      </div>

    <% } else { %>
      <a href="/login" class="btn btn-primary" style="font-size:0.85rem;padding:8px 18px;">Entrar</a>
    <% } %>
  </div>
</nav>

<script>
(function() {
  function atualizarBadge() {
    fetch('/carrinho/contagem').then(r => r.json()).then(d => {
      var badge = document.getElementById('cartBadge');
      if (!badge) return;
      if (d.contagem > 0) {
        badge.textContent = d.contagem;
        badge.style.display = 'inline-flex';
      } else {
        badge.style.display = 'none';
      }
    }).catch(function(){});
  }
  window.atualizarBadge = atualizarBadge;
  atualizarBadge();
})();
</script>
