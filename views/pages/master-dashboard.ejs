<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Painel Master</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>body { font-family: 'Inter', sans-serif; }</style>
</head>
<body class="bg-gray-950 min-h-screen text-white">

  <!-- Sidebar -->
  <div class="flex min-h-screen">
    <aside class="w-56 bg-gray-900 border-r border-gray-800 flex flex-col shrink-0">
      <div class="p-5 border-b border-gray-800">
        <span class="text-blue-400 font-bold text-sm uppercase tracking-wider">Painel Master</span>
      </div>
      <nav class="flex-1 p-3 space-y-1">
        <a href="/_master?tab=leads"
           class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition
                  <%= tab === 'leads' ? 'bg-blue-600 text-white' : 'text-gray-400 hover:bg-gray-800 hover:text-white' %>">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          Leads
          <% if (stats.leadsPendentes > 0) { %>
          <span class="ml-auto bg-yellow-500 text-black text-xs font-bold px-1.5 py-0.5 rounded-full"><%= stats.leadsPendentes %></span>
          <% } %>
        </a>
        <a href="/_master?tab=tenants"
           class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition
                  <%= tab === 'tenants' ? 'bg-blue-600 text-white' : 'text-gray-400 hover:bg-gray-800 hover:text-white' %>">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
          Tenants
          <span class="ml-auto text-gray-500 text-xs"><%= stats.tenantsAtivos %></span>
        </a>
        <a href="/_master?tab=config"
           class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition
                  <%= tab === 'config' ? 'bg-blue-600 text-white' : 'text-gray-400 hover:bg-gray-800 hover:text-white' %>">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          Configurações
        </a>
      </nav>
      <div class="p-3 border-t border-gray-800">
        <form method="POST" action="/_master/logout">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button type="submit" class="w-full flex items-center gap-2 px-3 py-2 rounded-lg text-sm text-gray-500 hover:text-red-400 hover:bg-gray-800 transition">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
            Sair
          </button>
        </form>
      </div>
    </aside>

    <!-- Main content -->
    <main class="flex-1 overflow-auto">
      <!-- Top bar -->
      <div class="bg-gray-900 border-b border-gray-800 px-8 py-4 flex items-center justify-between">
        <div>
          <% if (tab === 'leads') { %><h1 class="text-lg font-bold">Leads & Onboarding</h1><% } %>
          <% if (tab === 'tenants') { %><h1 class="text-lg font-bold">Tenants Ativos</h1><% } %>
          <% if (tab === 'config') { %><h1 class="text-lg font-bold">Configurações da Plataforma</h1><% } %>
        </div>
        <!-- Stats chips -->
        <div class="flex items-center gap-4 text-xs text-gray-400">
          <span><strong class="text-white text-sm"><%= stats.tenantsAtivos %></strong> tenants ativos</span>
          <span><strong class="text-yellow-400 text-sm"><%= stats.leadsPendentes %></strong> leads pendentes</span>
          <span><strong class="text-green-400 text-sm"><%= stats.leadsAtivos %></strong> convertidos</span>
        </div>
      </div>

      <div class="p-8">

        <!-- Alertas -->
        <% if (mensagem) { %>
        <div class="bg-green-900/40 border border-green-700 text-green-300 rounded-xl px-4 py-3 text-sm mb-6 flex items-center gap-2">
          <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
          <%= mensagem %>
        </div>
        <% } %>
        <% if (erro) { %>
        <div class="bg-red-900/40 border border-red-700 text-red-300 rounded-xl px-4 py-3 text-sm mb-6"><%= erro %></div>
        <% } %>

        <!-- Link gerado -->
        <% if (linkGerado) { %>
        <div class="bg-blue-900/40 border border-blue-700 rounded-xl px-5 py-4 mb-6">
          <p class="text-xs font-semibold text-blue-400 mb-2">LINK DO CONSULTOR GERADO</p>
          <div class="flex items-center gap-3 bg-gray-900 rounded-lg px-3 py-2">
            <code id="linkGerado" class="text-sm text-blue-300 flex-1 break-all"><%= linkGerado %></code>
            <button onclick="copiarLink()" class="text-blue-400 hover:text-blue-200 text-xs font-semibold whitespace-nowrap">Copiar</button>
          </div>
          <p class="text-xs text-gray-500 mt-2">Envie este link ao cliente. Ele pré-preencherá o formulário de cadastro.</p>
        </div>
        <% } %>

        <!-- ============================================================ -->
        <!-- TAB: LEADS -->
        <!-- ============================================================ -->
        <% if (tab === 'leads') { %>

        <!-- Gerar link do consultor -->
        <div class="bg-gray-900 border border-gray-700 rounded-2xl p-6 mb-6">
          <h2 class="text-sm font-bold text-gray-300 mb-4">Gerar link para consultor</h2>
          <form method="POST" action="/_master/leads/gerar-link" class="flex flex-wrap items-end gap-3">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <div class="flex-1 min-w-40">
              <label class="block text-xs text-gray-500 mb-1">Nome do consultor *</label>
              <input type="text" name="consultor_nome" required placeholder="João Silva"
                class="w-full bg-gray-800 border border-gray-700 text-white rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
            </div>
            <div class="flex-1 min-w-40">
              <label class="block text-xs text-gray-500 mb-1">Email do lead (opcional)</label>
              <input type="email" name="email" placeholder="cliente@empresa.com"
                class="w-full bg-gray-800 border border-gray-700 text-white rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
            </div>
            <div class="flex-1 min-w-40">
              <label class="block text-xs text-gray-500 mb-1">Empresa (opcional)</label>
              <input type="text" name="nome_empresa" placeholder="Loja do João"
                class="w-full bg-gray-800 border border-gray-700 text-white rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
            </div>
            <div class="w-36">
              <label class="block text-xs text-gray-500 mb-1">Plano sugerido</label>
              <select name="plano" class="w-full bg-gray-800 border border-gray-700 text-white rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
                <option value="basic">Basic — R$ 99</option>
                <option value="pro">Pro — R$ 199</option>
                <option value="premium">Premium — R$ 399</option>
              </select>
            </div>
            <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold px-5 py-2 rounded-lg transition whitespace-nowrap">
              Gerar link
            </button>
          </form>
        </div>

        <!-- Tabela de leads -->
        <div class="bg-gray-900 border border-gray-800 rounded-2xl overflow-hidden">
          <div class="px-6 py-4 border-b border-gray-800 flex items-center justify-between">
            <h2 class="font-semibold text-gray-200">Todos os leads (<%= leads.length %>)</h2>
          </div>

          <% if (leads.length === 0) { %>
          <div class="text-center text-gray-600 py-12">Nenhum lead ainda.</div>
          <% } else { %>
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead class="bg-gray-800/50 text-gray-500 text-xs uppercase tracking-wider">
                <tr>
                  <th class="px-4 py-3 text-left">Lead</th>
                  <th class="px-4 py-3 text-left">Empresa / Slug</th>
                  <th class="px-4 py-3 text-left">Plano</th>
                  <th class="px-4 py-3 text-left">Consultor</th>
                  <th class="px-4 py-3 text-left">Status</th>
                  <th class="px-4 py-3 text-left">Data</th>
                  <th class="px-4 py-3 text-right">Ações</th>
                </tr>
              </thead>
              <%
                function sColor(s){var m={ativo:'bg-green-900/60 text-green-300',cancelado:'bg-red-900/40 text-red-400',aguardando_pagamento:'bg-yellow-900/60 text-yellow-300',aguardando_ativacao:'bg-orange-900/60 text-orange-300',em_onboarding:'bg-blue-900/60 text-blue-300'};return m[s]||'bg-gray-700 text-gray-300';}
                function sLabel(s){var m={novo:'Novo',em_onboarding:'Em cadastro',aguardando_pagamento:'Aguard. pagamento',aguardando_ativacao:'Aguard. ativacao',ativo:'Ativo',cancelado:'Cancelado'};return m[s]||s;}
              %>
              <tbody class="divide-y divide-gray-800">
                <% leads.forEach(function(lead) { %>
                <tr class="hover:bg-gray-800/30">
                  <td class="px-4 py-3">
                    <p class="font-medium text-white"><%= lead.nome_contato || '—' %></p>
                    <p class="text-xs text-gray-500"><%= lead.email %></p>
                  </td>
                  <td class="px-4 py-3">
                    <p class="text-gray-300"><%= lead.nome_empresa || '—' %></p>
                    <% if (lead.slug_desejado) { %>
                    <p class="text-xs text-gray-600 font-mono"><%= lead.slug_desejado %></p>
                    <% } %>
                  </td>
                  <td class="px-4 py-3">
                    <span class="text-xs font-semibold text-gray-300 capitalize"><%= lead.plano %></span>
                  </td>
                  <td class="px-4 py-3 text-xs text-gray-400"><%= lead.consultor_nome || '—' %></td>
                  <td class="px-4 py-3">
                    <span class="text-xs font-semibold px-2 py-1 rounded-full <%= sColor(lead.status) %>"><%= sLabel(lead.status) %></span>
                  </td>
                  <td class="px-4 py-3 text-xs text-gray-500">
                    <%= new Date(lead.created_at).toLocaleDateString('pt-BR') %>
                  </td>
                  <td class="px-4 py-3">
                    <div class="flex items-center justify-end gap-2">
                      <% if (lead.token && lead.status !== 'ativo' && lead.status !== 'cancelado') { %>
                      <button onclick="copiarTexto('<%= appUrl %>/onboarding/<%= lead.token %>')"
                        class="text-xs text-blue-400 hover:text-blue-300 font-medium">Link</button>
                      <% } %>
                      <% if (['aguardando_ativacao', 'em_onboarding', 'aguardando_pagamento', 'novo'].includes(lead.status) && lead.slug_desejado) { %>
                      <form method="POST" action="/_master/leads/<%= lead.id %>/ativar" onsubmit="return confirm('Provisionar este tenant?')">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <button type="submit" class="text-xs text-green-400 hover:text-green-300 font-medium">Ativar</button>
                      </form>
                      <% } %>
                      <% if (lead.status !== 'cancelado' && lead.status !== 'ativo') { %>
                      <form method="POST" action="/_master/leads/<%= lead.id %>/cancelar" onsubmit="return confirm('Cancelar este lead?')">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <button type="submit" class="text-xs text-red-500 hover:text-red-400 font-medium">Cancelar</button>
                      </form>
                      <% } %>
                    </div>
                  </td>
                </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
          <% } %>
        </div>
        <% } %>

        <!-- ============================================================ -->
        <!-- TAB: TENANTS -->
        <!-- ============================================================ -->
        <% if (tab === 'tenants') { %>
        <div class="bg-gray-900 border border-gray-800 rounded-2xl overflow-hidden">
          <div class="px-6 py-4 border-b border-gray-800">
            <h2 class="font-semibold text-gray-200">Tenants (<%= tenants.length %>)</h2>
          </div>
          <% if (tenants.length === 0) { %>
          <div class="text-center text-gray-600 py-12">Nenhum tenant cadastrado.</div>
          <% } else { %>
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead class="bg-gray-800/50 text-gray-500 text-xs uppercase tracking-wider">
                <tr>
                  <th class="px-4 py-3 text-left">Tenant</th>
                  <th class="px-4 py-3 text-left">Plano</th>
                  <th class="px-4 py-3 text-left">Gateway</th>
                  <th class="px-4 py-3 text-left">Taxa</th>
                  <th class="px-4 py-3 text-left">Status</th>
                  <th class="px-4 py-3 text-right">Ações</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-800">
                <% tenants.forEach(t => { %>
                <tr class="hover:bg-gray-800/30">
                  <td class="px-4 py-3">
                    <p class="font-medium text-white"><%= t.nome %></p>
                    <p class="text-xs text-gray-500 font-mono"><%= t.slug %></p>
                  </td>
                  <td class="px-4 py-3 text-xs font-semibold text-gray-300 capitalize"><%= t.plano || 'basic' %></td>
                  <td class="px-4 py-3 text-xs text-gray-400"><%= t.gateway_type || 'asaas_native' %></td>
                  <td class="px-4 py-3">
                    <form method="POST" action="/_master/tenants/<%= t.slug %>/fee" class="flex items-center gap-1">
                      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                      <input type="number" name="fee" step="0.01" min="0" max="100"
                        value="<%= t.fee_percent_override ?? '' %>"
                        placeholder="padrão"
                        class="w-20 bg-gray-800 border border-gray-700 text-white rounded px-2 py-1 text-xs focus:outline-none focus:ring-1 focus:ring-blue-500">
                      <span class="text-gray-500 text-xs">%</span>
                      <button type="submit" class="text-xs text-blue-400 hover:text-blue-300 font-medium ml-1">OK</button>
                    </form>
                    <p class="text-xs text-gray-600 mt-0.5">vazio = usa padrão</p>
                  </td>
                  <td class="px-4 py-3">
                    <span class="text-xs font-semibold px-2 py-1 rounded-full <%= t.ativo ? 'bg-green-900/60 text-green-300' : 'bg-red-900/40 text-red-400' %>">
                      <%= t.ativo ? 'Ativo' : 'Inativo' %>
                    </span>
                  </td>
                  <td class="px-4 py-3">
                    <div class="flex items-center justify-end gap-3">
                      <a href="/_tenants/acessar/<%= t.slug %>" class="text-xs text-blue-400 hover:text-blue-300 font-medium">Acessar</a>
                      <form method="POST" action="/_master/tenants/<%= t.slug %>/toggle">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <button type="submit" class="text-xs <%= t.ativo ? 'text-red-500 hover:text-red-400' : 'text-green-400 hover:text-green-300' %> font-medium">
                          <%= t.ativo ? 'Desativar' : 'Ativar' %>
                        </button>
                      </form>
                    </div>
                  </td>
                </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
          <% } %>
        </div>
        <% } %>

        <!-- ============================================================ -->
        <!-- TAB: CONFIG -->
        <!-- ============================================================ -->
        <% if (tab === 'config') { %>
        <div class="max-w-xl">
          <div class="bg-gray-900 border border-gray-800 rounded-2xl p-8">
            <h2 class="font-bold text-gray-200 mb-6">Configurações do Asaas</h2>
            <form method="POST" action="/_master/config" class="space-y-5">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">

              <div>
                <label class="block text-xs font-semibold text-gray-400 mb-1.5">API Key do Asaas</label>
                <input type="password" name="asaas_api_key"
                  value="<%= config.asaas_api_key || '' %>"
                  placeholder="$aact_..."
                  class="w-full bg-gray-800 border border-gray-700 text-white rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
                <p class="text-xs text-gray-600 mt-1">Conta master da plataforma no Asaas.</p>
              </div>

              <div>
                <label class="block text-xs font-semibold text-gray-400 mb-1.5">Ambiente</label>
                <select name="asaas_env" class="w-full bg-gray-800 border border-gray-700 text-white rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
                  <option value="sandbox"    <%= config.asaas_env === 'sandbox'    ? 'selected' : '' %>>Sandbox (testes)</option>
                  <option value="production" <%= config.asaas_env === 'production' ? 'selected' : '' %>>Produção</option>
                </select>
              </div>

              <div>
                <label class="block text-xs font-semibold text-gray-400 mb-1.5">Taxa padrão por transação (%)</label>
                <div class="flex items-center gap-2">
                  <input type="number" name="asaas_default_fee_percent" step="0.01" min="0" max="100"
                    value="<%= config.asaas_default_fee_percent || '1.50' %>"
                    class="w-32 bg-gray-800 border border-gray-700 text-white rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
                  <span class="text-gray-500 text-sm">%</span>
                </div>
                <p class="text-xs text-gray-600 mt-1">Retida pela plataforma em cada transação dos tenants que usam o gateway nativo.</p>
              </div>

              <div>
                <label class="block text-xs font-semibold text-gray-400 mb-1.5">Token do Webhook Asaas</label>
                <input type="text" name="asaas_webhook_token"
                  value="<%= config.asaas_webhook_token || '' %>"
                  placeholder="Token para validar eventos recebidos"
                  class="w-full bg-gray-800 border border-gray-700 text-white rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
              </div>

              <button type="submit" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2.5 rounded-xl transition">
                Salvar configurações
              </button>
            </form>
          </div>
        </div>
        <% } %>

      </div>
    </main>
  </div>

  <script>
    function copiarLink() {
      const el = document.getElementById('linkGerado');
      if (el) navigator.clipboard.writeText(el.textContent.trim()).then(() => alert('Link copiado!'));
    }
    function copiarTexto(texto) {
      navigator.clipboard.writeText(texto).then(() => alert('Link copiado!'));
    }
  </script>
</body>
</html>
