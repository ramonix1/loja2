<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Banners - Admin Lojão</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap');
    body { font-family: 'Inter', sans-serif; }
    .badge-soon { font-size: 10px; font-weight: 700; letter-spacing: 0.5px; }
  </style>
</head>

<body class="bg-gray-950 min-h-screen text-white">
  <div class="flex min-h-screen">

  <%- include('../partials/admin-sidebar') %>

    <!-- Conteúdo principal -->
    <main class="ml-60 flex-1 p-8">

      <div class="flex items-center justify-between mb-8">
        <div>
          <h1 class="text-2xl font-bold text-white">Banners</h1>
          <p class="text-gray-400 mt-1 text-sm">Gerencie os banners exibidos no carrossel da página inicial</p>
        </div>
        <a href="/admin/banners/novo"
           class="bg-blue-600 hover:bg-blue-700 text-white font-semibold px-4 py-2.5 rounded-lg text-sm transition flex items-center gap-2">
          + Novo Banner
        </a>
      </div>

      <% if (banners.length === 0) { %>
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-16 text-center">
          <div class="text-5xl mb-4"></div>
          <h3 class="text-lg font-semibold text-white mb-2">Nenhum banner cadastrado</h3>
          <p class="text-gray-400 text-sm mb-6">Crie o primeiro banner para o carrossel da loja.</p>
          <a href="/admin/banners/novo" class="bg-blue-600 hover:bg-blue-700 text-white font-semibold px-5 py-2.5 rounded-lg text-sm transition inline-block">
            Criar banner
          </a>
        </div>
      <% } else { %>
        <div class="space-y-4">
          <% banners.forEach(function(banner) { %>
            <div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden flex items-stretch">

              <!-- Imagem preview -->
              <div class="w-48 flex-shrink-0 bg-gray-800">
                <img src="<%= banner.imagem %>" alt="<%= banner.titulo %>"
                     class="w-full h-full object-cover" style="max-height:120px; object-position:center;">
              </div>

              <!-- Info -->
              <div class="flex-1 p-5 flex flex-col justify-between">
                <div>
                  <div class="flex items-center gap-3 mb-1">
                    <h3 class="font-bold text-white text-base"><%= banner.titulo %></h3>
                    <% if (banner.ativo) { %>
                      <span class="text-xs bg-green-900 text-green-400 font-semibold px-2 py-0.5 rounded-full">Ativo</span>
                    <% } else { %>
                      <span class="text-xs bg-gray-800 text-gray-500 font-semibold px-2 py-0.5 rounded-full">Inativo</span>
                    <% } %>
                  </div>
                  <% if (banner.subtitulo) { %>
                    <p class="text-gray-400 text-sm mb-2"><%= banner.subtitulo %></p>
                  <% } %>
                  <div class="flex flex-wrap gap-3 text-xs text-gray-500">
                    <span>CTA: <span class="text-gray-300"><%= banner.cta_texto %></span></span>
                    <% if (banner.produto_nome) { %>
                      <span>Produto vinculado: <span class="text-blue-400"><%= banner.produto_nome %></span></span>
                    <% } else if (banner.cta_url) { %>
                      <span>URL: <span class="text-gray-300"><%= banner.cta_url %></span></span>
                    <% } %>
                    <span>Ordem: <span class="text-gray-300"><%= banner.ordem %></span></span>
                  </div>
                </div>
              </div>

              <!-- Ações -->
              <div class="flex flex-col justify-center gap-2 px-5 border-l border-gray-800">
                <a href="/admin/banners/editar/<%= banner.id %>"
                   class="bg-gray-800 hover:bg-gray-700 text-white text-sm font-medium px-4 py-2 rounded-lg transition text-center">
                  Editar
                </a>
                <form action="/admin/banners/toggle/<%= banner.id %>" method="POST">
                  <input type="hidden" name="_csrf" value="<%= locals.csrfToken %>">
                  <button type="submit"
                    class="w-full <%= banner.ativo ? 'bg-yellow-900 hover:bg-yellow-800 text-yellow-300' : 'bg-green-900 hover:bg-green-800 text-green-300' %> text-sm font-medium px-4 py-2 rounded-lg transition">
                    <%= banner.ativo ? 'Desativar' : 'Ativar' %>
                  </button>
                </form>
                <a href="/admin/banners/excluir/<%= banner.id %>"
                   onclick="return confirm('Excluir este banner?')"
                   class="bg-red-900 hover:bg-red-800 text-red-300 text-sm font-medium px-4 py-2 rounded-lg transition text-center">
                  Excluir
                </a>
              </div>

            </div>
          <% }) %>
        </div>
      <% } %>

    </main>
  </div>
</body>
</html>
