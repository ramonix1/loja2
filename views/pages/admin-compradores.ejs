<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Compradores - Admin</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap');
    body { font-family: 'Inter', sans-serif; }
  </style>
</head>
<body class="bg-gray-950 min-h-screen text-white">
<div class="flex min-h-screen">

  <%- include('../partials/admin-sidebar') %>

  <main class="ml-60 flex-1 p-8">

    <div class="mb-6">
      <div class="text-xs text-gray-500 mb-1">
        <a href="/admin" class="hover:text-gray-300 transition">Dashboard</a>
        <span class="mx-2">/</span>
        <span class="text-gray-300">Compradores</span>
      </div>
      <h1 class="text-2xl font-bold text-white">👥 Compradores</h1>
      <p class="text-gray-400 mt-1 text-sm">Fichas de todos os clientes que realizaram cadastro</p>
    </div>

    <!-- Cards de resumo -->
    <div class="grid grid-cols-3 gap-4 mb-6">
      <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
        <div class="text-xs text-gray-500 mb-1">Total de compradores</div>
        <div class="text-3xl font-bold text-white"><%= totais.total_compradores %></div>
      </div>
      <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
        <div class="text-xs text-gray-500 mb-1">Contas ativas</div>
        <div class="text-3xl font-bold text-green-400"><%= totais.ativos %></div>
      </div>
      <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
        <div class="text-xs text-gray-500 mb-1">Novos este mês</div>
        <div class="text-3xl font-bold text-blue-400"><%= totais.novos_mes %></div>
      </div>
    </div>

    <!-- Busca -->
    <form method="GET" action="/admin/compradores" class="mb-6">
      <div class="flex gap-3">
        <input type="text" name="busca" value="<%= busca %>"
          placeholder="Buscar por nome, e-mail, CPF ou telefone..."
          class="flex-1 bg-gray-900 border border-gray-800 rounded-xl px-4 py-2.5 text-sm text-white placeholder-gray-500 focus:outline-none focus:border-blue-500">
        <button type="submit"
          class="bg-blue-600 hover:bg-blue-500 px-5 py-2.5 rounded-xl text-sm font-medium transition">
          Buscar
        </button>
        <% if (busca) { %>
          <a href="/admin/compradores" class="bg-gray-800 hover:bg-gray-700 px-4 py-2.5 rounded-xl text-sm transition">
            Limpar
          </a>
        <% } %>
      </div>
    </form>

    <!-- Tabela -->
    <div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-800 flex justify-between items-center">
        <h2 class="font-semibold text-white">
          <%= compradores.length %> comprador<%= compradores.length !== 1 ? 'es' : '' %>
          <% if (busca) { %><span class="text-gray-500 font-normal text-sm"> para "<%= busca %>"</span><% } %>
        </h2>
      </div>

      <% if (compradores.length === 0) { %>
        <div class="py-16 text-center">
          <div class="text-5xl mb-3">👥</div>
          <p class="text-gray-400 font-medium">Nenhum comprador encontrado</p>
          <% if (busca) { %>
            <p class="text-gray-600 text-sm mt-1">Tente uma busca diferente</p>
          <% } else { %>
            <p class="text-gray-600 text-sm mt-1">Os compradores aparecem aqui quando fazem cadastro na loja</p>
          <% } %>
        </div>
      <% } else { %>
        <div class="overflow-x-auto">
          <table class="w-full">
            <thead>
              <tr class="border-b border-gray-800 text-xs text-gray-500 uppercase">
                <th class="px-6 py-3 text-left">Comprador</th>
                <th class="px-4 py-3 text-left">Telefone</th>
                <th class="px-4 py-3 text-left">Cidade/UF</th>
                <th class="px-4 py-3 text-center">Pedidos</th>
                <th class="px-4 py-3 text-right">Total gasto</th>
                <th class="px-4 py-3 text-center">Status</th>
                <th class="px-4 py-3 text-center">Cadastro</th>
                <th class="px-4 py-3"></th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-800">
              <% compradores.forEach(c => { %>
                <tr class="hover:bg-gray-800/50 transition">
                  <td class="px-6 py-4">
                    <div class="font-medium text-white text-sm"><%= c.nome %></div>
                    <div class="text-xs text-gray-500 mt-0.5"><%= c.email %></div>
                    <% if (c.cpf) { %><div class="text-xs text-gray-600 mt-0.5">CPF: <%= c.cpf %></div><% } %>
                  </td>
                  <td class="px-4 py-4 text-sm text-gray-300"><%= c.telefone || '—' %></td>
                  <td class="px-4 py-4 text-sm text-gray-300">
                    <%= c.cidade ? `${c.cidade}/${c.estado}` : '—' %>
                  </td>
                  <td class="px-4 py-4 text-center">
                    <span class="text-sm font-semibold text-white"><%= c.total_pedidos %></span>
                  </td>
                  <td class="px-4 py-4 text-right text-sm font-semibold text-green-400">
                    R$ <%= Number(c.total_gasto).toFixed(2).replace('.', ',') %>
                  </td>
                  <td class="px-4 py-4 text-center">
                    <span class="text-xs px-2 py-1 rounded-full font-medium
                      <%= c.ativo ? 'bg-green-900/50 text-green-400' : 'bg-red-900/50 text-red-400' %>">
                      <%= c.ativo ? 'Ativo' : 'Inativo' %>
                    </span>
                  </td>
                  <td class="px-4 py-4 text-center text-xs text-gray-500">
                    <%= new Date(c.created_at).toLocaleDateString('pt-BR') %>
                  </td>
                  <td class="px-4 py-4 text-right">
                    <a href="/admin/compradores/<%= c.id %>"
                      class="text-xs bg-gray-800 hover:bg-gray-700 px-3 py-1.5 rounded-lg transition">
                      Ver ficha
                    </a>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>

  </main>
</div>
</body>
</html>
