<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Aguardando pagamento - Lojão</title>
  <link rel="stylesheet" href="/css/style.css">
  <style>
    .maquininha-box {
      max-width: 520px;
      margin: 60px auto;
      background: #fff;
      border-radius: 20px;
      box-shadow: 0 8px 32px rgba(0,0,0,0.08);
      padding: 48px 40px;
      text-align: center;
    }
    .spinner {
      width: 64px; height: 64px;
      border: 5px solid #e5e7eb;
      border-top-color: #2563eb;
      border-radius: 50%;
      animation: spin 0.9s linear infinite;
      margin: 0 auto 24px;
    }
    @keyframes spin { to { transform: rotate(360deg); } }
    .status-icon { font-size: 64px; margin-bottom: 20px; }
    .valor { font-size: 40px; font-weight: 900; color: #2563eb; margin: 8px 0 24px; }
    .instrucoes {
      background: #f0f9ff;
      border-radius: 12px;
      padding: 18px;
      font-size: 14px;
      color: #0369a1;
      margin: 20px 0;
      text-align: left;
      line-height: 1.9;
    }
    .instrucoes strong { display: block; margin-bottom: 4px; color: #0c4a6e; }
    .btn-cancelar {
      background: none;
      border: 1.5px solid #e5e7eb;
      color: #6b7280;
      padding: 10px 24px;
      border-radius: 8px;
      cursor: pointer;
      font-size: 14px;
      margin-top: 16px;
      transition: all 0.2s;
    }
    .btn-cancelar:hover { border-color: #ef4444; color: #ef4444; }
    #statusMsg { font-size: 17px; font-weight: 600; color: #374151; margin-bottom: 8px; }
    #statusSub { font-size: 14px; color: #6b7280; }
  </style>
</head>
<body>
<%- include("../partials/header") %>

<div class="container">
  <div class="maquininha-box" id="box">

    <!-- Estado: aguardando ─────────────────────── -->
    <div id="estado-aguardando">
      <div class="spinner"></div>
      <div id="statusMsg">Aguardando pagamento na maquininha</div>
      <div id="statusSub">Apresente o cartão ou aproxime o celular na leitora SumUp</div>

      <div class="valor">R$ <%= Number(pedido.total).toFixed(2).replace('.',',') %></div>

      <div class="instrucoes">
        <strong>Como pagar:</strong>
        1. A maquininha já recebeu o valor automaticamente<br>
        2. Passe, aproxime ou insira o cartão na leitora<br>
        3. Aguarde a confirmação — esta página atualiza sozinha
      </div>

      <button class="btn-cancelar" id="btnCancelar">Cancelar pagamento</button>
    </div>

    <!-- Estado: aprovado ───────────────────────── -->
    <div id="estado-aprovado" style="display:none;">
      <div class="status-icon">✅</div>
      <h2 style="font-size:24px;font-weight:800;color:#111827;margin-bottom:8px;">Pagamento aprovado!</h2>
      <p style="color:#6b7280;margin-bottom:24px;">Seu pedido #<%= pedido.id %> foi confirmado.</p>
      <a href="/checkout/resultado/<%= pedido.id %>" class="btn btn-primary" style="padding:14px 32px;font-size:15px;">Ver pedido →</a>
    </div>

    <!-- Estado: recusado ───────────────────────── -->
    <div id="estado-recusado" style="display:none;">
      <div class="status-icon">❌</div>
      <h2 style="font-size:22px;font-weight:800;color:#991b1b;margin-bottom:8px;">Pagamento recusado</h2>
      <p style="color:#6b7280;margin-bottom:24px;">Tente outro cartão ou escolha outra forma de pagamento.</p>
      <a href="/carrinho" class="btn btn-primary" style="padding:14px 32px;">Tentar novamente</a>
    </div>

  </div>
</div>

<%- include("../partials/footer") %>

<script>
(function() {
  var pedidoId = '<%= pedido.id %>';
  var tid = '<%= tid %>';
  var tentativas = 0;
  var maxTentativas = 60; // 5 min (polling a cada 5s)
  var intervalo;

  function verificarStatus() {
    fetch('/checkout/status-maquininha/' + pedidoId + '/' + encodeURIComponent(tid))
      .then(function(r) { return r.json(); })
      .then(function(d) {
        tentativas++;
        if (d.statusInterno === 'pago' || d.status === 'successful') {
          clearInterval(intervalo);
          document.getElementById('estado-aguardando').style.display = 'none';
          document.getElementById('estado-aprovado').style.display = 'block';
          setTimeout(function() { window.location.href = '/checkout/resultado/' + pedidoId; }, 3000);
        } else if (d.statusInterno === 'rejeitado' || d.statusInterno === 'cancelado'
                   || d.status === 'failed' || d.status === 'timed_out' || d.status === 'cancelled') {
          clearInterval(intervalo);
          document.getElementById('estado-aguardando').style.display = 'none';
          document.getElementById('estado-recusado').style.display = 'block';
        } else if (tentativas >= maxTentativas) {
          clearInterval(intervalo);
          document.getElementById('statusMsg').textContent = 'Tempo esgotado';
          document.getElementById('statusSub').textContent = 'A transação expirou. Tente novamente.';
        }
      })
      .catch(function() {});
  }

  intervalo = setInterval(verificarStatus, 5000);
  verificarStatus(); // consulta imediata

  document.getElementById('btnCancelar').addEventListener('click', function() {
    if (!confirm('Deseja cancelar o pagamento na maquininha?')) return;
    clearInterval(intervalo);
    fetch('/checkout/cancelar-maquininha/' + pedidoId + '/' + encodeURIComponent(tid), {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'x-csrf-token': '<%= csrfToken %>' },
      body: '{}'
    }).then(function() { window.location.href = '/carrinho'; });
  });
})();
</script>
</body>
</html>
