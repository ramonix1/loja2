<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Editar Cliente - Admin Lojão</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap');
    body { font-family: 'Inter', sans-serif; }
  </style>
</head>

<body class="bg-gray-950 min-h-screen text-white">

  <div class="flex min-h-screen">

    <!-- Sidebar -->
    <aside class="w-60 bg-gray-900 border-r border-gray-800 flex flex-col fixed h-full">
      <div class="p-6 border-b border-gray-800">
        <a href="/" class="flex items-center gap-3">
          <span class="text-2xl">🛒</span>
          <div>
            <div class="font-bold text-white text-lg leading-tight">Lojão</div>
            <div class="text-xs text-gray-400 font-medium">Painel Admin</div>
          </div>
        </a>
      </div>

      <nav class="flex-1 p-4 space-y-1">
        <a href="/admin"
           class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-gray-400 hover:bg-gray-800 hover:text-white font-medium text-sm transition">
          <span>🏠</span> Dashboard
        </a>
        <a href="/admin/produtos"
           class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-gray-400 hover:bg-gray-800 hover:text-white font-medium text-sm transition">
          <span>📦</span> Produtos
        </a>
        <a href="/admin/banners"
           class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-gray-400 hover:bg-gray-800 hover:text-white font-medium text-sm transition">
          <span>🖼️</span> Banners
        </a>
        <a href="/admin/clientes"
           class="flex items-center gap-3 px-3 py-2.5 rounded-lg bg-blue-600 text-white font-medium text-sm">
          <span>🏢</span> Clientes
        </a>
      </nav>

      <div class="p-4 border-t border-gray-800">
        <a href="/"
           class="flex items-center gap-2 text-sm text-gray-400 hover:text-white transition px-3 py-2 rounded-lg hover:bg-gray-800">
          ← Ver loja
        </a>
      </div>
    </aside>

    <!-- Conteúdo -->
    <main class="ml-60 flex-1 p-8">

      <!-- Header -->
      <div class="mb-6">
        <div class="text-xs text-gray-500 mb-1">
          <a href="/admin" class="hover:text-gray-300 transition">Dashboard</a>
          <span class="mx-2">/</span>
          <a href="/admin/clientes" class="hover:text-gray-300 transition">Clientes</a>
          <span class="mx-2">/</span>
          <span class="text-gray-300">Editar</span>
        </div>
        <h1 class="text-2xl font-bold text-white">✏️ Editar Cliente</h1>
        <p class="text-gray-400 mt-1 text-sm">Modifique as informações do cliente</p>
      </div>

      <!-- Formulário de edição -->
      <div class="bg-gray-900 border border-gray-800 rounded-xl p-6 max-w-2xl">
        <form action="/admin/clientes/atualizar/<%= cliente.id %>" method="POST" enctype="multipart/form-data" class="space-y-4">
          <input type="hidden" name="_csrf" value="<%= locals.csrfToken %>">

          <div>
            <label class="block text-sm font-medium text-gray-300 mb-1">Nome do Cliente *</label>
            <input type="text" name="nome" value="<%= cliente.nome %>" required
              class="w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2.5 text-white text-sm placeholder-gray-500 focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500"
              placeholder="Ex: Empresa ABC">
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-300 mb-1">Site (URL) - Opcional</label>
            <input type="url" name="website" value="<%= cliente.website || '' %>"
              class="w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2.5 text-white text-sm placeholder-gray-500 focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500"
              placeholder="https://exemplo.com">
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-300 mb-1">Ordem de Exibição</label>
            <input type="number" name="ordem" value="<%= cliente.ordem %>" min="0"
              class="w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2.5 text-white text-sm placeholder-gray-500 focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500">
            <p class="text-xs text-gray-500 mt-1">Menor número aparece primeiro</p>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-300 mb-1">
              <input type="hidden" name="ativo" value="false">
              <input type="checkbox" name="ativo" value="true" <%= cliente.ativo ? 'checked' : '' %> class="rounded">
              Cliente ativo
            </label>
            <p class="text-xs text-gray-500 mt-1">Desmarque para ocultar da lista de clientes</p>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-300 mb-1">Logo Atual</label>
            <% if (cliente.logo) { %>
              <img src="<%= cliente.logo %>"
                   class="h-20 w-20 object-cover rounded-lg border border-gray-700 mb-3">
            <% } else { %>
              <p class="text-gray-500 text-sm mb-3">Nenhuma logo cadastrada</p>
            <% } %>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-300 mb-1">Nova Logo (opcional)</label>
            <input type="file" name="logo" id="logo" accept="image/*"
              class="w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2.5 text-gray-300 text-sm file:mr-3 file:py-1 file:px-3 file:rounded file:border-0 file:bg-blue-600 file:text-white file:text-xs file:cursor-pointer hover:file:bg-blue-700">
            <p class="text-xs text-gray-500 mt-1">PNG, JPG, WEBP — máx. 5MB</p>
            <div id="previewArea" class="mt-3"></div>
          </div>

          <div class="flex gap-3">
            <button type="submit"
              class="bg-blue-600 hover:bg-blue-700 text-white px-5 py-2.5 rounded-lg text-sm font-semibold transition">
              ✅ Atualizar Cliente
            </button>
            <a href="/admin/clientes"
               class="bg-gray-700 hover:bg-gray-600 text-gray-300 px-5 py-2.5 rounded-lg text-sm font-semibold transition">
              ← Cancelar
            </a>
          </div>
        </form>
      </div>

    </main>
  </div>

  <script>
    // Preview de imagem única
    const inputLogo = document.getElementById("logo");
    const previewArea = document.getElementById("previewArea");

    inputLogo.addEventListener("change", function() {
      previewArea.innerHTML = "";
      const file = this.files[0];
      if (!file) return;

      if (!file.type.startsWith("image/")) {
        alert("Arquivo deve ser uma imagem");
        return;
      }
      if (file.size > 5 * 1024 * 1024) {
        alert("Arquivo muito grande (máx 5MB)");
        return;
      }

      const reader = new FileReader();
      reader.onload = function(e) {
        const img = document.createElement("img");
        img.src = e.target.result;
        img.className = "h-24 w-24 object-cover rounded-lg border border-gray-700";
        previewArea.appendChild(img);
      };
      reader.readAsDataURL(file);
    });
  </script>

</body>
</html>
