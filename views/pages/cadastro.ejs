<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Criar conta  LojÃ£o</title>
  <link rel="stylesheet" href="/css/style.css">
  <style>
    body { background: #f3f4f6; margin: 0; padding: 32px 16px; font-family: 'Inter', Arial, sans-serif; }
    .auth-card {
      background: #fff; border-radius: 16px; box-shadow: 0 8px 32px rgba(0,0,0,0.10);
      padding: 40px; width: 100%; max-width: 600px; margin: 0 auto;
    }
    .auth-logo { text-align: center; margin-bottom: 24px; }
    .auth-logo a { font-size: 1.8rem; font-weight: 800; color: #3b82f6; text-decoration: none; }
    .auth-titulo { font-size: 1.4rem; font-weight: 700; color: #111; margin-bottom: 6px; text-align: center; }
    .auth-sub { color: #6b7280; font-size: 0.88rem; text-align: center; margin-bottom: 28px; }
    .secao { font-size: 0.78rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.8px; color: #9ca3af; margin: 24px 0 12px; border-bottom: 1px solid #f3f4f6; padding-bottom: 6px; }
    .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
    .grid-3-1 { display: grid; grid-template-columns: 3fr 1fr; gap: 14px; }
    .form-grupo { margin-bottom: 14px; }
    .form-grupo label { display: block; font-size: 0.83rem; font-weight: 600; color: #374151; margin-bottom: 5px; }
    .form-grupo input, .form-grupo select {
      width: 100%; padding: 10px 13px; border: 1.5px solid #d1d5db; border-radius: 8px;
      font-size: 0.93rem; outline: none; transition: border 0.2s; box-sizing: border-box; background: #fff;
    }
    .form-grupo input:focus, .form-grupo select:focus { border-color: #3b82f6; }
    .form-grupo input:disabled { background: #f9fafb; color: #6b7280; }
    .senha-wrapper { position: relative; }
    .senha-wrapper input { padding-right: 42px; }
    .toggle-senha { position: absolute; right: 11px; top: 50%; transform: translateY(-50%); background: none; border: none; cursor: pointer; color: #9ca3af; }
    .btn-cep { position: absolute; right: 10px; top: 50%; transform: translateY(-50%); background: #3b82f6; color: #fff; border: none; border-radius: 6px; padding: 5px 10px; font-size: 0.78rem; cursor: pointer; }
    .cep-wrapper { position: relative; }
    .cep-wrapper input { padding-right: 70px; }
    .forca-barra { height: 4px; border-radius: 4px; margin-top: 5px; background: #e5e7eb; transition: all 0.3s; }
    .forca-label { font-size: 0.76rem; color: #6b7280; margin-top: 3px; }
    .btn-cadastrar {
      width: 100%; padding: 13px; background: #3b82f6; color: #fff; font-weight: 700;
      font-size: 1rem; border: none; border-radius: 8px; cursor: pointer; transition: background 0.2s; margin-top: 8px;
    }
    .btn-cadastrar:hover { background: #2563eb; }
    .alerta-erros { background: #fef2f2; border: 1px solid #fca5a5; color: #b91c1c; border-radius: 8px; padding: 12px 16px; margin-bottom: 20px; font-size: 0.88rem; }
    .alerta-erros ul { margin: 4px 0 0 16px; padding: 0; }
    .links-auth { text-align: center; margin-top: 20px; font-size: 0.88rem; color: #6b7280; }
    .links-auth a { color: #3b82f6; text-decoration: none; font-weight: 600; }
    .obrigatorio { color: #ef4444; }
    @media (max-width: 600px) {
      .grid-2, .grid-3-1 { grid-template-columns: 1fr; }
      .auth-card { padding: 28px 20px; }
    }
  </style>
</head>
<body>
  <div class="auth-card">
    <div class="auth-logo"><a href="/"><span style="display:flex;align-items:center;width:20px;height:20px;"><%- icon('shopping_cart', 'w-5 h-5') %></span> LojÃ£o</a></div>
    <h1 class="auth-titulo">Criar sua conta</h1>
    <p class="auth-sub">Preencha os dados abaixo para comeÃ§ar a comprar.</p>

    <% if (erros && erros.length > 0) { %>
      <div class="alerta-erros">
         Corrija os erros antes de continuar:
        <ul><% erros.forEach(e => { %><li><%= e %></li><% }) %></ul>
      </div>
    <% } %>

    <form method="POST" action="/cadastro" id="formCadastro">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">

      <div class="secao">Dados pessoais</div>

      <div class="form-grupo">
        <label for="nome">Nome completo <span class="obrigatorio">*</span></label>
        <input type="text" id="nome" name="nome" value="<%= dados.nome || '' %>" required autocomplete="name" placeholder="Seu nome completo">
      </div>

      <div class="grid-2">
        <div class="form-grupo">
          <label for="email">Email <span class="obrigatorio">*</span></label>
          <input type="email" id="email" name="email" value="<%= dados.email || '' %>" required autocomplete="email" placeholder="seu@email.com">
        </div>
        <div class="form-grupo">
          <label for="telefone">Telefone <span class="obrigatorio">*</span></label>
          <input type="tel" id="telefone" name="telefone" value="<%= dados.telefone || '' %>" required autocomplete="tel" placeholder="(11) 99999-9999" maxlength="15">
        </div>
      </div>

      <div class="secao">Senha</div>

      <div class="grid-2">
        <div class="form-grupo">
          <label for="senha">Senha <span class="obrigatorio">*</span></label>
          <div class="senha-wrapper">
            <input type="password" id="senha" name="senha" required autocomplete="new-password" placeholder="MÃnimo 8 caracteres" oninput="avaliarSenha(this.value)">
            <button type="button" class="toggle-senha" onclick="toggleSenha('senha',this)"></button>
          </div>
          <div class="forca-barra" id="forcaBarra"></div>
          <div class="forca-label" id="forcaLabel"></div>
        </div>
        <div class="form-grupo">
          <label for="confirmacao">Confirmar senha <span class="obrigatorio">*</span></label>
          <div class="senha-wrapper">
            <input type="password" id="confirmacao" name="confirmacao" required autocomplete="new-password" placeholder="Repita a senha">
            <button type="button" class="toggle-senha" onclick="toggleSenha('confirmacao',this)"></button>
          </div>
        </div>
      </div>

      <div class="secao">EndereÃ§o</div>

      <div class="form-grupo">
        <label for="cep">CEP <span class="obrigatorio">*</span></label>
        <div class="cep-wrapper">
          <input type="text" id="cep" name="cep" value="<%= dados.cep || '' %>" required placeholder="00000-000" maxlength="9" oninput="mascaraCep(this)" onblur="buscarCep(this.value)">
          <button type="button" class="btn-cep" onclick="buscarCep(document.getElementById('cep').value)">Buscar</button>
        </div>
      </div>

      <div class="form-grupo">
        <label for="logradouro">Logradouro <span class="obrigatorio">*</span></label>
        <input type="text" id="logradouro" name="logradouro" value="<%= dados.logradouro || '' %>" required placeholder="Rua, Avenida...">
      </div>

      <div class="grid-3-1">
        <div class="form-grupo">
          <label for="bairro">Bairro <span class="obrigatorio">*</span></label>
          <input type="text" id="bairro" name="bairro" value="<%= dados.bairro || '' %>" required>
        </div>
        <div class="form-grupo">
          <label for="numero">NÃºmero <span class="obrigatorio">*</span></label>
          <input type="text" id="numero" name="numero" value="<%= dados.numero || '' %>" required placeholder="Ex: 42">
        </div>
      </div>

      <div class="grid-2">
        <div class="form-grupo">
          <label for="cidade">Cidade <span class="obrigatorio">*</span></label>
          <input type="text" id="cidade" name="cidade" value="<%= dados.cidade || '' %>" required>
        </div>
        <div class="form-grupo">
          <label for="estado">Estado <span class="obrigatorio">*</span></label>
          <select id="estado" name="estado" required>
            <option value="">Selecione</option>
            <% ['AC','AL','AP','AM','BA','CE','DF','ES','GO','MA','MT','MS','MG','PA','PB','PR','PE','PI','RJ','RN','RS','RO','RR','SC','SP','SE','TO'].forEach(uf => { %>
              <option value="<%= uf %>" <%= (dados.estado === uf ? 'selected' : '') %>><%= uf %></option>
            <% }) %>
          </select>
        </div>
      </div>

      <div class="form-grupo">
        <label for="complemento">Complemento</label>
        <input type="text" id="complemento" name="complemento" value="<%= dados.complemento || '' %>" placeholder="Apto, bloco, casa... (opcional)">
      </div>

      <button type="submit" class="btn-cadastrar">Criar minha conta</button>
    </form>

    <div class="links-auth">
      JÃ¡ tem conta? <a href="/login">Entrar</a>
    </div>
  </div>

  <script>
    function toggleSenha(id, btn) {
      const input = document.getElementById(id);
      input.type = input.type === 'password' ? 'text' : 'password';
      btn.textContent = input.type === 'password' ? '' : '';
    }

    function avaliarSenha(v) {
      const pontos = [v.length >= 8, /\d/.test(v), /[A-Z]/.test(v), /[^a-zA-Z0-9]/.test(v)].filter(Boolean).length;
      const cores = ['#ef4444','#f97316','#eab308','#22c55e'];
      const labels = ['Muito fraca','Fraca','MÃ©dia','Forte'];
      const barra = document.getElementById('forcaBarra');
      const label = document.getElementById('forcaLabel');
      if (!v.length) { barra.style.width='0'; label.textContent=''; return; }
      barra.style.width = (pontos*25)+'%';
      barra.style.background = cores[pontos-1]||'#e5e7eb';
      label.textContent = labels[pontos-1]||'';
      label.style.color = cores[pontos-1]||'#6b7280';
    }

    function mascaraCep(input) {
      let v = input.value.replace(/\D/g,'');
      if (v.length > 5) v = v.slice(0,5)+'-'+v.slice(5,8);
      input.value = v;
    }

    function mascaraTelefone(input) {
      let v = input.value.replace(/\D/g,'');
      if (v.length <= 10) v = v.replace(/^(\d{2})(\d{4})(\d{0,4})$/,'($1) $2-$3');
      else v = v.replace(/^(\d{2})(\d{5})(\d{0,4})$/,'($1) $2-$3');
      input.value = v;
    }

    async function buscarCep(cep) {
      const num = cep.replace(/\D/g,'');
      if (num.length !== 8) return;
      try {
        const r = await fetch('https://viacep.com.br/ws/'+num+'/json/');
        const d = await r.json();
        if (d.erro) return;
        document.getElementById('logradouro').value = d.logradouro || '';
        document.getElementById('bairro').value = d.bairro || '';
        document.getElementById('cidade').value = d.localidade || '';
        document.getElementById('estado').value = d.uf || '';
      } catch(e) {}
    }

    document.getElementById('telefone').addEventListener('input', function(){ mascaraTelefone(this); });
  </script>
</body>
</html>
