<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Lojão - Produtos de qualidade</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<%- include("../partials/header") %>

<!-- Hero Banner -->
<div class="hero">
  <div class="hero-content">
    <h1>Os melhores produtos, <br>para você.</h1>
    <p>Qualidade garantida com entrega rápida em todo o Brasil.</p>
    <a href="#produtos" class="btn btn-hero">Ver produtos ↓</a>
  </div>
</div>

<div class="container" id="produtos">

  <div class="section-title">
    <h2>Nossos Produtos</h2>
    <p>Encontre o que você precisa com os melhores preços</p>
  </div>

  <% if(produtos.length === 0){ %>
    <div class="empty-state">
      <div class="empty-icon">📦</div>
      <h3>Nenhum produto cadastrado ainda</h3>
      <p>Volte em breve ou <a href="/admin">acesse o painel admin</a> para cadastrar produtos.</p>
    </div>
  <% } else { %>
    <div class="produtos-grid">
      <% produtos.forEach(function(produto){ %>
        <%- include("../partials/produto-card", {produto}) %>
      <% }) %>
    </div>
  <% } %>

</div>

<!-- Seção de Clientes -->
<% if(clientes && clientes.length > 0){ %>
  <section class="py-16 bg-gray-50">
    <div class="container">
      <div class="section-title">
        <h2>Nossos Clientes</h2>
        <p>Empresas que confiam em nós</p>
      </div>

      <div class="overflow-hidden bg-white py-8 rounded-xl">
        <div class="animate-scroll">
          <!-- Duplicado para efeito de scroll infinito -->
          <% for(let i = 0; i < 2; i++) { %>
            <% clientes.forEach(function(cliente){ %>
              <a href="<%= cliente.website || '#' %>" target="<%= cliente.website ? '_blank' : '_self' %>" class="flex-shrink-0 flex items-center justify-center h-20 hover:opacity-75 transition">
                <img src="<%= cliente.logo %>" alt="<%= cliente.nome %>" class="max-h-14 max-w-xs object-contain px-4" title="<%= cliente.nome %>">
              </a>
            <% }) %>
          <% } %>
        </div>
      </div>
    </div>
  </section>
<% } %>

<%- include("../partials/footer") %>

</body>
</html>
