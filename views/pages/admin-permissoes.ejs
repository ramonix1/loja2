<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Permissões - Admin Lojão</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap');
    body { font-family: 'Inter', sans-serif; }
  </style>
</head>
<body class="bg-gray-950 min-h-screen text-white">
  <div class="flex min-h-screen">

  <%- include('../partials/admin-sidebar') %>

    <!-- Conteúdo -->
    <main class="ml-60 flex-1 p-8">
      <div class="mb-6">
        <h1 class="text-2xl font-bold text-white">🔐 Permissões do Sistema</h1>
        <p class="text-gray-400 mt-1 text-sm">Gerencie os administradores com acesso ao painel</p>
      </div>

      <% if (sucesso) { %>
        <div class="bg-green-900 border border-green-700 text-green-300 rounded-xl px-5 py-3 mb-6 text-sm"><span style="display:flex;align-items:center;width:20px;height:20px;"><%- icon('check', 'w-5 h-5') %></span> <%= sucesso %></div>
      <% } %>
      <% if (erro) { %>
        <div class="bg-red-900 border border-red-700 text-red-300 rounded-xl px-5 py-3 mb-6 text-sm">⚠️ <%= erro %></div>
      <% } %>

      <!-- Formulário de novo admin -->
      <div class="bg-gray-900 border border-gray-800 rounded-xl p-6 max-w-2xl mb-8">
        <h2 class="text-lg font-bold text-white mb-5">Adicionar Administrador</h2>
        <form action="/admin/permissoes/criar" method="POST" class="space-y-4">
          <input type="hidden" name="_csrf" value="<%= locals.csrfToken %>">

          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-gray-300 mb-1">Nome *</label>
              <input type="text" name="nome" required placeholder="Nome completo"
                class="w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2.5 text-white text-sm focus:outline-none focus:border-blue-500">
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-300 mb-1">Email *</label>
              <input type="email" name="email" required placeholder="admin@email.com"
                class="w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2.5 text-white text-sm focus:outline-none focus:border-blue-500">
            </div>
          </div>

          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-gray-300 mb-1">Senha *</label>
              <div class="relative">
                <input type="password" name="senha" id="senhaAdmin" required placeholder="Mínimo 8 caracteres"
                  class="w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2.5 text-white text-sm focus:outline-none focus:border-blue-500 pr-10">
                <button type="button" onclick="toggleSenha()" class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 text-sm">👁</button>
              </div>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-300 mb-1">CPF</label>
              <input type="text" name="cpf" placeholder="000.000.000-00" maxlength="14"
                oninput="mascaraCpf(this)"
                class="w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2.5 text-white text-sm focus:outline-none focus:border-blue-500">
            </div>
          </div>

          <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white px-5 py-2.5 rounded-lg text-sm font-semibold transition">
            ➕ Criar Administrador
          </button>
        </form>
      </div>

      <!-- Lista de admins -->
      <div class="bg-gray-900 border border-gray-800 rounded-xl p-6">
        <div class="flex justify-between items-center mb-5">
          <h2 class="text-lg font-bold text-white">Administradores Cadastrados</h2>
          <span class="text-sm text-gray-400"><%= admins.length %> admin<%= admins.length !== 1 ? 's' : '' %></span>
        </div>

        <% if (admins.length === 0) { %>
          <div class="text-center py-12 bg-gray-800 rounded-xl">
            <div class="text-4xl mb-2">🔐</div>
            <p class="text-gray-400">Nenhum administrador cadastrado</p>
          </div>
        <% } else { %>
          <div class="overflow-x-auto">
            <table class="w-full">
              <thead>
                <tr class="border-b border-gray-800">
                  <th class="pb-3 text-left text-xs font-semibold text-gray-500 uppercase">Nome</th>
                  <th class="pb-3 text-left text-xs font-semibold text-gray-500 uppercase">Email</th>
                  <th class="pb-3 text-left text-xs font-semibold text-gray-500 uppercase">CPF</th>
                  <th class="pb-3 text-left text-xs font-semibold text-gray-500 uppercase">Status</th>
                  <th class="pb-3 text-left text-xs font-semibold text-gray-500 uppercase">Último acesso</th>
                  <th class="pb-3 text-left text-xs font-semibold text-gray-500 uppercase">Ações</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-800">
                <% admins.forEach(admin => { %>
                  <tr class="hover:bg-gray-800/40 transition">
                    <td class="py-3 pr-4">
                      <div class="font-medium text-white text-sm"><%= admin.nome %></div>
                    </td>
                    <td class="py-3 pr-4 text-gray-300 text-sm"><%= admin.email %></td>
                    <td class="py-3 pr-4 text-gray-400 text-sm"><%= admin.cpf || '—' %></td>
                    <td class="py-3 pr-4">
                      <span class="px-2 py-1 rounded-full text-xs font-semibold <%= admin.ativo ? 'bg-green-900 text-green-300' : 'bg-red-900 text-red-300' %>">
                        <%= admin.ativo ? 'Ativo' : 'Inativo' %>
                      </span>
                    </td>
                    <td class="py-3 pr-4 text-gray-400 text-xs">
                      <%= admin.ultimo_acesso ? new Date(admin.ultimo_acesso).toLocaleString('pt-BR') : 'Nunca' %>
                    </td>
                    <td class="py-3">
                      <div class="flex gap-2">
                        <% if (admin.id !== locals.usuario?.id) { %>
                          <form action="/admin/permissoes/toggle/<%= admin.id %>" method="POST">
                            <input type="hidden" name="_csrf" value="<%= locals.csrfToken %>">
                            <button type="submit"
                              class="<%= admin.ativo ? 'bg-yellow-700 hover:bg-yellow-600 text-yellow-200' : 'bg-green-700 hover:bg-green-600 text-green-200' %> px-3 py-1.5 rounded-lg text-xs font-medium transition">
                              <%= admin.ativo ? '⏸ Suspender' : '▶ Ativar' %>
                            </button>
                          </form>
                          <form action="/admin/permissoes/excluir/<%= admin.id %>" method="POST"
                            onsubmit="return confirm('Remover o acesso de <%= admin.nome %>?')">
                            <input type="hidden" name="_csrf" value="<%= locals.csrfToken %>">
                            <button type="submit" class="bg-red-700 hover:bg-red-600 text-white px-3 py-1.5 rounded-lg text-xs font-medium transition">
                              🗑 Remover
                            </button>
                          </form>
                        <% } else { %>
                          <span class="text-xs text-gray-600 italic px-2 py-1">Você mesmo</span>
                        <% } %>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    </main>
  </div>

  <script>
    function toggleSenha() {
      const input = document.getElementById('senhaAdmin');
      input.type = input.type === 'password' ? 'text' : 'password';
    }
    function mascaraCpf(input) {
      let v = input.value.replace(/\D/g,'');
      v = v.replace(/^(\d{3})(\d)/,'$1.$2');
      v = v.replace(/^(\d{3})\.(\d{3})(\d)/,'$1.$2.$3');
      v = v.replace(/\.(\d{3})(\d)/,'.$1-$2');
      input.value = v;
    }
  </script>
</body>
</html>
