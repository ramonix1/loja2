<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Editar Categoria - Admin</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap');
    body { font-family: 'Inter', sans-serif; }
  </style>
</head>
<body class="bg-gray-950 min-h-screen text-white">
<div class="flex min-h-screen">

  <%- include('../partials/admin-sidebar') %>

  <main class="ml-60 flex-1 p-8">

    <div class="mb-6">
      <div class="text-xs text-gray-500 mb-1">
        <a href="/admin" class="hover:text-gray-300 transition">Dashboard</a>
        <span class="mx-2">/</span>
        <a href="/admin/categorias" class="hover:text-gray-300 transition">Categorias</a>
        <span class="mx-2">/</span>
        <span class="text-gray-300">Editar</span>
      </div>
      <h1 class="text-2xl font-bold text-white"> Editar Categoria</h1>
    </div>

    <form method="POST" action="/admin/categorias/<%= categoria.id %>">
      <input type="hidden" name="_csrf" value="<%= locals.csrfToken %>">

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

        <!-- Produtos -->
        <div class="lg:col-span-2">
          <div class="bg-gray-900 border border-gray-800 rounded-xl p-6">
            <div class="flex items-center justify-between mb-4">
              <h2 class="text-base font-bold text-white">Produtos nesta categoria</h2>
              <div class="flex gap-2">
                <button type="button" onclick="toggleTodos(true)"
                        class="text-xs text-blue-400 hover:text-blue-300 transition">Marcar todos</button>
                <span class="text-gray-600">Â</span>
                <button type="button" onclick="toggleTodos(false)"
                        class="text-xs text-gray-400 hover:text-gray-300 transition">Desmarcar todos</button>
              </div>
            </div>

            <% if (produtos.length === 0) { %>
              <p class="text-gray-400 text-sm text-center py-8">Nenhum produto cadastrado ainda.</p>
            <% } else { %>
              <div class="space-y-2" id="lista-produtos">
                <% produtos.forEach(function(p) { %>
                  <label class="flex items-center gap-3 p-3 rounded-lg cursor-pointer hover:bg-gray-800 transition group">
                    <input type="checkbox" name="produtos_ids" value="<%= p.id %>"
                           <%= p.categoria_id == categoria.id ? 'checked' : '' %>
                           class="w-4 h-4 rounded accent-blue-500 flex-shrink-0">
                    <span class="text-sm text-gray-300 group-hover:text-white transition flex-1"><%= p.nome %></span>
                    <% if (p.categoria_id && p.categoria_id != categoria.id) { %>
                      <span class="text-xs text-amber-500 flex-shrink-0">(outra categoria)</span>
                    <% } %>
                  </label>
                <% }) %>
              </div>
            <% } %>
          </div>
        </div>

        <!-- ConfiguraÃ§Ãµes -->
        <div>
          <div class="bg-gray-900 border border-gray-800 rounded-xl p-6 sticky top-8 space-y-4">
            <h2 class="text-base font-bold text-white">ConfiguraÃ§Ãµes</h2>

            <div>
              <label class="block text-sm font-medium text-gray-300 mb-1.5">Nome da categoria *</label>
              <input type="text" name="nome" value="<%= categoria.nome %>" required
                     class="w-full bg-gray-800 border border-gray-700 text-white rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:border-blue-500">
            </div>

            <div>
              <label class="block text-sm font-medium text-gray-300 mb-1.5">Ordem de exibiÃ§Ã£o</label>
              <input type="number" name="ordem" value="<%= categoria.ordem %>" min="0"
                     class="w-full bg-gray-800 border border-gray-700 text-white rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:border-blue-500">
              <p class="text-xs text-gray-500 mt-1">Menor nÃºmero aparece primeiro na vitrine.</p>
            </div>

            <button type="submit"
                    class="w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2.5 rounded-lg text-sm transition">
              ¾ Salvar
            </button>

            <a href="/admin/categorias"
               class="block text-center text-sm text-gray-400 hover:text-white transition py-2">
              Cancelar
            </a>
          </div>
        </div>

      </div>
    </form>

  </main>
</div>
<script>
function toggleTodos(marcar) {
  document.querySelectorAll('#lista-produtos input[type=checkbox]').forEach(function(cb) {
    cb.checked = marcar;
  });
}
</script>
</body>
</html>
