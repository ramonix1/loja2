<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Clientes - Admin Lojão</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap');
    body { font-family: 'Inter', sans-serif; }
    .badge-soon { font-size: 10px; font-weight: 700; letter-spacing: 0.5px; }
  </style>
</head>

<body class="bg-gray-950 min-h-screen text-white">

  <div class="flex min-h-screen">

  <%- include('../partials/admin-sidebar') %>

    <!-- Conteúdo -->
    <main class="ml-60 flex-1 p-8">

      <!-- Header -->
      <div class="mb-6">
        <div class="text-xs text-gray-500 mb-1">
          <a href="/admin" class="hover:text-gray-300 transition">Dashboard</a>
          <span class="mx-2">/</span>
          <span class="text-gray-300">Clientes</span>
        </div>
        <h1 class="text-2xl font-bold text-white">🏢 Clientes</h1>
        <p class="text-gray-400 mt-1 text-sm">Cadastre e gerencie os logos dos clientes</p>
      </div>

      <!-- Formulário de cadastro -->
      <div class="bg-gray-900 border border-gray-800 rounded-xl p-6 max-w-2xl mb-8">
        <h2 class="text-lg font-bold text-white mb-5">Cadastrar Novo Cliente</h2>

        <form action="/admin/clientes/salvar?_csrf=<%= locals.csrfToken %>" method="POST" enctype="multipart/form-data" class="space-y-4">

          <div>
            <label class="block text-sm font-medium text-gray-300 mb-1">Nome do Cliente *</label>
            <input type="text" name="nome" required
              class="w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2.5 text-white text-sm placeholder-gray-500 focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500"
              placeholder="Ex: Empresa ABC">
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-300 mb-1">Site (URL) - Opcional</label>
            <input type="url" name="website"
              class="w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2.5 text-white text-sm placeholder-gray-500 focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500"
              placeholder="https://exemplo.com">
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-300 mb-1">Ordem de Exibição</label>
            <input type="number" name="ordem" value="0" min="0"
              class="w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2.5 text-white text-sm placeholder-gray-500 focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500"
              placeholder="0">
            <p class="text-xs text-gray-500 mt-1">Menor número aparece primeiro</p>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-300 mb-1">Logo do Cliente *</label>
            <input type="file" name="logo" id="logo" accept="image/*" required
              class="w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2.5 text-gray-300 text-sm file:mr-3 file:py-1 file:px-3 file:rounded file:border-0 file:bg-blue-600 file:text-white file:text-xs file:cursor-pointer hover:file:bg-blue-700">
            <p class="text-xs text-gray-500 mt-1">PNG, JPG, WEBP — máx. 5MB</p>
            <div id="previewArea" class="mt-3"></div>
          </div>

          <button type="submit"
            class="bg-blue-600 hover:bg-blue-700 text-white px-5 py-2.5 rounded-lg text-sm font-semibold transition">
            <span style="display:flex;align-items:center;width:20px;height:20px;"><%- icon('check', 'w-5 h-5') %></span> Salvar Cliente
          </button>
        </form>
      </div>

      <!-- Lista de clientes -->
      <div class="bg-gray-900 border border-gray-800 rounded-xl p-6">
        <div class="flex justify-between items-center mb-5">
          <h2 class="text-lg font-bold text-white">Clientes Cadastrados</h2>
          <span class="text-sm text-gray-400"><%= clientes.length %> cliente<%= clientes.length !== 1 ? 's' : '' %></span>
        </div>

        <% if (clientes.length === 0) { %>
          <div class="text-center py-16 bg-gray-800 rounded-xl">
            <div class="text-5xl mb-3">🏢</div>
            <p class="text-gray-400 font-medium">Nenhum cliente cadastrado</p>
            <p class="text-gray-600 text-sm mt-1">Use o formulário acima para adicionar</p>
          </div>
        <% } else { %>
          <div class="overflow-x-auto">
            <table class="w-full">
              <thead>
                <tr class="border-b border-gray-800">
                  <th class="pb-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Cliente</th>
                  <th class="pb-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Ordem</th>
                  <th class="pb-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Status</th>
                  <th class="pb-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Ações</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-800">
                <% clientes.forEach(function(cliente) { %>
                  <tr class="hover:bg-gray-800/50 transition">
                    <td class="py-3 pr-4">
                      <div class="flex items-center gap-3">
                        <img src="<%= cliente.logo || 'https://placehold.co/40x40/374151/9ca3af?text=?' %>"
                             class="h-10 w-10 object-cover rounded-lg border border-gray-700"
                             onerror="this.src='https://placehold.co/40x40/374151/9ca3af?text=?'">
                        <div>
                          <div class="font-medium text-white text-sm"><%= cliente.nome %></div>
                          <% if (cliente.website) { %>
                            <a href="<%= cliente.website %>" target="_blank" class="text-xs text-blue-400 hover:text-blue-300">
                              <%= cliente.website %>
                            </a>
                          <% } %>
                        </div>
                      </div>
                    </td>
                    <td class="py-3 pr-4">
                      <span class="text-gray-400 text-sm"><%= cliente.ordem %></span>
                    </td>
                    <td class="py-3 pr-4">
                      <span class="<%= cliente.ativo ? 'text-green-400' : 'text-red-400' %> text-sm font-medium">
                        <%= cliente.ativo ? '✓ Ativo' : '✗ Inativo' %>
                      </span>
                    </td>
                    <td class="py-3">
                      <div class="flex gap-2">
                        <a href="/admin/clientes/editar/<%= cliente.id %>"
                           class="bg-yellow-600 hover:bg-yellow-500 text-white px-3 py-1.5 rounded-lg text-xs font-medium transition">
                          ✏️ Editar
                        </a>
                        <a href="/admin/clientes/excluir/<%= cliente.id %>"
                           class="bg-red-700 hover:bg-red-600 text-white px-3 py-1.5 rounded-lg text-xs font-medium transition"
                           onclick="return confirm('Excluir este cliente permanentemente?')">
                          🗑️ Excluir
                        </a>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>

    </main>
  </div>

  <script>
    // Preview de imagem única
    const inputLogo = document.getElementById("logo");
    const previewArea = document.getElementById("previewArea");

    inputLogo.addEventListener("change", function() {
      previewArea.innerHTML = "";
      const file = this.files[0];
      if (!file) return;

      if (!file.type.startsWith("image/")) {
        alert("Arquivo deve ser uma imagem");
        return;
      }
      if (file.size > 5 * 1024 * 1024) {
        alert("Arquivo muito grande (máx 5MB)");
        return;
      }

      const reader = new FileReader();
      reader.onload = function(e) {
        const img = document.createElement("img");
        img.src = e.target.result;
        img.className = "h-24 w-24 object-cover rounded-lg border border-gray-700";
        previewArea.appendChild(img);
      };
      reader.readAsDataURL(file);
    });
  </script>

</body>
</html>
