<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Painel Admin - Lojão</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap');
    body { font-family: 'Inter', sans-serif; }

    .module-card {
      transition: all 0.2s ease;
    }
    .module-card:hover {
      transform: translateY(-3px);
    }
    .module-card.disabled {
      opacity: 0.5;
      cursor: not-allowed;
      pointer-events: none;
    }
    .badge-soon {
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.5px;
    }
  </style>
</head>

<body class="bg-gray-950 min-h-screen text-white">

  <!-- Sidebar + Layout -->
  <div class="flex min-h-screen">

    <%- include('../partials/admin-sidebar') %>

    <!-- Conteúdo principal -->
    <main class="ml-60 flex-1 p-8">

      <!-- Header -->
      <div class="mb-8">
        <h1 class="text-2xl font-bold text-white">Dashboard</h1>
        <p class="text-gray-400 mt-1 text-sm">Bem-vindo ao painel de controle do Lojão</p>
      </div>

      <!-- Cards de estatística -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-10">
        <div class="bg-gray-900 rounded-xl p-5 border border-gray-800">
          <div class="text-3xl mb-1">📦</div>
          <div class="text-2xl font-bold text-white"><%= totalProdutos %></div>
          <div class="text-sm text-gray-400 mt-1">Produtos cadastrados</div>
        </div>
        <div class="bg-gray-900 rounded-xl p-5 border border-gray-800">
          <div class="text-3xl mb-1">🖼️</div>
          <div class="text-2xl font-bold text-white"><%= totalBanners %></div>
          <div class="text-sm text-gray-400 mt-1">Banners ativos</div>
        </div>
        <div class="bg-gray-900 rounded-xl p-5 border border-gray-800 opacity-50">
          <div class="text-3xl mb-1">🏷️</div>
          <div class="text-2xl font-bold text-white">—</div>
          <div class="text-sm text-gray-400 mt-1">Categorias</div>
        </div>
        <div class="bg-gray-900 rounded-xl p-5 border border-gray-800 opacity-50">
          <div class="text-3xl mb-1">🛍️</div>
          <div class="text-2xl font-bold text-white">—</div>
          <div class="text-sm text-gray-400 mt-1">Pedidos</div>
        </div>
      </div>

      <!-- Módulos -->
      <h2 class="text-lg font-semibold text-white mb-4">Módulos</h2>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">

        <!-- Produtos (ativo) -->
        <a href="/admin/produtos" class="module-card bg-gray-900 border border-gray-800 hover:border-blue-500 rounded-xl p-6 block">
          <div class="flex items-start justify-between mb-4">
            <div class="w-12 h-12 bg-blue-600 rounded-xl flex items-center justify-center text-2xl">📦</div>
            <span class="text-xs bg-green-900 text-green-400 font-semibold px-2 py-1 rounded-full">Ativo</span>
          </div>
          <h3 class="font-bold text-white text-lg mb-1">Produtos</h3>
          <p class="text-gray-400 text-sm mb-4">Cadastre, edite e remova produtos da loja. Gerencie imagens, preços e descrições.</p>
          <div class="flex items-center text-blue-400 text-sm font-medium">
            Acessar módulo <span class="ml-1">→</span>
          </div>
        </a>

        <!-- Banners (ativo) -->
        <a href="/admin/banners" class="module-card bg-gray-900 border border-gray-800 hover:border-blue-500 rounded-xl p-6 block">
          <div class="flex items-start justify-between mb-4">
            <div class="w-12 h-12 bg-purple-600 rounded-xl flex items-center justify-center text-2xl">🖼️</div>
            <span class="text-xs bg-green-900 text-green-400 font-semibold px-2 py-1 rounded-full">Ativo</span>
          </div>
          <h3 class="font-bold text-white text-lg mb-1">Banners</h3>
          <p class="text-gray-400 text-sm mb-4">Gerencie os banners do carrossel da página inicial com título, subtítulo e botão CTA.</p>
          <div class="flex items-center text-blue-400 text-sm font-medium">
            Acessar módulo <span class="ml-1">→</span>
          </div>
        </a>

        <!-- Categorias (em breve) -->
        <div class="module-card disabled bg-gray-900 border border-gray-800 rounded-xl p-6">
          <div class="flex items-start justify-between mb-4">
            <div class="w-12 h-12 bg-gray-700 rounded-xl flex items-center justify-center text-2xl">🏷️</div>
            <span class="text-xs bg-gray-800 text-gray-500 font-semibold px-2 py-1 rounded-full badge-soon">EM BREVE</span>
          </div>
          <h3 class="font-bold text-gray-400 text-lg mb-1">Categorias</h3>
          <p class="text-gray-600 text-sm mb-4">Organize produtos em categorias para facilitar a navegação na loja.</p>
          <div class="flex items-center text-gray-600 text-sm font-medium">
            Em desenvolvimento
          </div>
        </div>

        <!-- Pedidos (ativo) -->
        <a href="/admin/pedidos" class="module-card bg-gray-900 border border-gray-800 hover:border-blue-500 rounded-xl p-6 block">
          <div class="flex items-start justify-between mb-4">
            <div class="w-12 h-12 bg-yellow-600 rounded-xl flex items-center justify-center text-2xl">🛍️</div>
            <span class="text-xs bg-green-900 text-green-400 font-semibold px-2 py-1 rounded-full">Ativo</span>
          </div>
          <h3 class="font-bold text-white text-lg mb-1">Pedidos</h3>
          <p class="text-gray-400 text-sm mb-4">Acompanhe e gerencie os pedidos realizados pelos clientes.</p>
          <div class="flex items-center text-blue-400 text-sm font-medium">
            Acessar módulo <span class="ml-1">→</span>
          </div>
        </a>

        <!-- Clientes (ativo) -->
        <a href="/admin/clientes" class="module-card bg-gray-900 border border-gray-800 hover:border-blue-500 rounded-xl p-6 block">
          <div class="flex items-start justify-between mb-4">
            <div class="w-12 h-12 bg-green-600 rounded-xl flex items-center justify-center text-2xl">🏢</div>
            <span class="text-xs bg-green-900 text-green-400 font-semibold px-2 py-1 rounded-full">Ativo</span>
          </div>
          <h3 class="font-bold text-white text-lg mb-1">Clientes</h3>
          <p class="text-gray-400 text-sm mb-4">Gerencie os logos dos clientes exibidos no carrossel da página inicial.</p>
          <div class="flex items-center text-blue-400 text-sm font-medium">
            Acessar módulo <span class="ml-1">→</span>
          </div>
        </a>

        <!-- Configurações (ativo) -->
        <a href="/admin/configuracoes" class="module-card bg-gray-900 border border-gray-800 hover:border-blue-500 rounded-xl p-6 block">
          <div class="flex items-start justify-between mb-4">
            <div class="w-12 h-12 bg-orange-600 rounded-xl flex items-center justify-center text-2xl">⚙️</div>
            <span class="text-xs bg-green-900 text-green-400 font-semibold px-2 py-1 rounded-full">Ativo</span>
          </div>
          <h3 class="font-bold text-white text-lg mb-1">Configurações</h3>
          <p class="text-gray-400 text-sm mb-4">Controle de estoque, reservas, e outras opções do sistema.</p>
          <div class="flex items-center text-blue-400 text-sm font-medium">
            Acessar módulo <span class="ml-1">→</span>
          </div>
        </a>

      </div>

    </main>
  </div>

</body>
</html>
