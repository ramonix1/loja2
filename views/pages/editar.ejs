<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Editar Produto - Admin Lojão</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap');
    body { font-family: 'Inter', sans-serif; }
  </style>
</head>
<body class="bg-gray-950 min-h-screen text-white">
<div class="flex min-h-screen">

  <%- include('../partials/admin-sidebar') %>

  <main class="ml-60 flex-1 p-8">

    <div class="mb-6">
      <div class="text-xs text-gray-500 mb-1">
        <a href="/admin" class="hover:text-gray-300 transition">Dashboard</a>
        <span class="mx-2">/</span>
        <a href="/admin/produtos" class="hover:text-gray-300 transition">Produtos</a>
        <span class="mx-2">/</span>
        <span class="text-gray-300">Editar</span>
      </div>
      <h1 class="text-2xl font-bold text-white"> Editar Produto</h1>
      <p class="text-gray-400 mt-1 text-sm"><%= produto.nome %></p>
    </div>

    <form action="/atualizar/<%= produto.id %>?_csrf=<%= locals.csrfToken %>" method="POST" enctype="multipart/form-data"
          class="bg-gray-900 border border-gray-800 rounded-xl p-6 max-w-2xl">

      <input type="hidden" name="id" value="<%= produto.id %>">

      <div class="space-y-4">

        <div>
          <label class="block text-sm font-medium text-gray-300 mb-1">Nome do Produto *</label>
          <input name="titulo" value="<%= produto.nome %>" required
            class="w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2.5 text-white text-sm focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500">
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-300 mb-1">Subttulo</label>
          <input name="subtitulo" value="<%= produto.subtitulo || '' %>"
            class="w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2.5 text-white text-sm focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500">
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-300 mb-1">Valor (R$) *</label>
          <input type="text" name="valor" id="valor" required
            value="R$ <%= Number(produto.valor).toFixed(2).replace('.', ',') %>"
            class="w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2.5 text-white text-sm focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500">
        </div>

        <% if (configs.controla_estoque === 'true') { %>
        <div>
          <label class="block text-sm font-medium text-gray-300 mb-1">Estoque</label>
          <input type="number" name="estoque" min="0"
            value="<%= produto.estoque !== null && produto.estoque !== undefined ? produto.estoque : '' %>"
            class="w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2.5 text-white text-sm focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500"
            placeholder="Deixe em branco para ilimitado">
          <p class="text-xs text-gray-500 mt-1">Deixe em branco para não controlar estoque deste produto.</p>
        </div>
        <% } %>

        <div>
          <label class="block text-sm font-medium text-gray-300 mb-1">Descrição</label>
          <textarea name="descricao" rows="4"
            class="w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2.5 text-white text-sm focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 resize-none"><%= produto.descricao || '' %></textarea>
        </div>

        <!-- Imagens atuais -->
        <div>
          <label class="block text-sm font-medium text-gray-300 mb-2">Imagens Atuais</label>
          <% if (imagens && imagens.length > 0) { %>
            <div class="flex flex-wrap gap-2 mb-3">
              <% imagens.forEach(function(img) { %>
                <div class="relative group">
                  <img src="<%= img.url %>"
                       class="h-20 w-20 object-cover rounded-lg border border-gray-700">
                  <a href="/excluir-imagem/<%= img.id %>?produto=<%= produto.id %>"
                     onclick="return confirm('Remover esta imagem?')"
                     class="absolute -top-1 -right-1 bg-red-600 text-white rounded-full w-5 h-5 flex items-center justify-center text-xs opacity-0 group-hover:opacity-100 transition font-bold"></a>
                </div>
              <% }) %>
            </div>
          <% } else { %>
            <p class="text-gray-500 text-sm mb-3">Nenhuma imagem cadastrada.</p>
          <% } %>

          <label class="block text-sm font-medium text-gray-300 mb-1">Adicionar Novas Imagens</label>
          <input type="file" name="imagens" id="imagens" multiple accept="image/*"
            class="w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2.5 text-gray-300 text-sm file:mr-3 file:py-1 file:px-3 file:rounded file:border-0 file:bg-blue-600 file:text-white file:text-xs file:cursor-pointer hover:file:bg-blue-700">
          <p class="text-xs text-gray-500 mt-1">Deixe em branco para manter as imagens atuais.</p>
          <div id="previewArea" class="flex flex-wrap gap-2 mt-3"></div>
        </div>

      </div>

      <div class="flex gap-3 mt-6 pt-6 border-t border-gray-800">
        <button type="submit"
          class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-2.5 rounded-lg text-sm font-semibold transition">
          ¾ Salvar Alteraçµes
        </button>
        <a href="/admin/produtos"
          class="bg-gray-700 hover:bg-gray-600 text-gray-300 px-6 py-2.5 rounded-lg text-sm font-medium transition text-center">
          Cancelar
        </a>
      </div>
    </form>

  </main>
</div>

<script>
  const valorInput = document.getElementById("valor");
  valorInput.addEventListener("input", function(e) {
    let v = e.target.value.replace(/\D/g, "");
    v = (v / 100).toFixed(2);
    v = v.replace(".", ",");
    v = v.replace(/\B(?=(\d{3})+(?!\d))/g, ".");
    e.target.value = "R$ " + v;
  });

  const inputImagens = document.getElementById("imagens");
  const previewArea = document.getElementById("previewArea");
  inputImagens.addEventListener("change", function() {
    previewArea.innerHTML = "";
    Array.from(this.files).forEach(function(file) {
      if (!file.type.startsWith("image/")) return;
      const reader = new FileReader();
      reader.onload = function(e) {
        const img = document.createElement("img");
        img.src = e.target.result;
        img.className = "h-16 w-16 object-cover rounded-lg border border-gray-700";
        previewArea.appendChild(img);
      };
      reader.readAsDataURL(file);
    });
  });
</script>
</body>
</html>
