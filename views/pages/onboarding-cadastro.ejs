<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Cadastro — Plataforma de Lojas</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>body { font-family: 'Inter', sans-serif; }</style>
</head>
<body class="bg-gray-50 min-h-screen">

  <!-- Header -->
  <header class="bg-white border-b border-gray-200">
    <div class="max-w-3xl mx-auto px-4 py-4 flex items-center gap-3">
      <a href="/onboarding" class="text-blue-600 font-bold text-xl">Plataforma de Lojas</a>
    </div>
  </header>

  <!-- Stepper -->
  <div class="max-w-3xl mx-auto px-4 pt-8">
    <div class="flex items-center gap-2 mb-8 text-sm">
      <span class="flex items-center justify-center w-7 h-7 rounded-full bg-blue-600 text-white font-bold text-xs">1</span>
      <span class="font-semibold text-blue-600">Dados da empresa</span>
      <div class="flex-1 h-px bg-gray-200 mx-2"></div>
      <span class="flex items-center justify-center w-7 h-7 rounded-full bg-gray-200 text-gray-400 font-bold text-xs">2</span>
      <span class="text-gray-400">Pagamento</span>
      <div class="flex-1 h-px bg-gray-200 mx-2"></div>
      <span class="flex items-center justify-center w-7 h-7 rounded-full bg-gray-200 text-gray-400 font-bold text-xs">3</span>
      <span class="text-gray-400">Pronto!</span>
    </div>
  </div>

  <main class="max-w-3xl mx-auto px-4 pb-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

      <!-- Formulário -->
      <div class="md:col-span-2 bg-white rounded-2xl shadow p-8">
        <h1 class="text-xl font-bold text-gray-800 mb-1">Dados da sua empresa</h1>
        <p class="text-sm text-gray-500 mb-6">Preencha para criar sua loja.</p>

        <% if (erro) { %>
        <div class="bg-red-50 border border-red-200 text-red-700 text-sm rounded-lg px-4 py-3 mb-5"><%= erro %></div>
        <% } %>

        <form method="POST" action="/onboarding/cadastro">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <% if (lead && lead.token) { %>
          <input type="hidden" name="token_lead" value="<%= lead.token %>">
          <% } %>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
            <div>
              <label class="block text-xs font-semibold text-gray-600 mb-1">Nome do responsável *</label>
              <input type="text" name="nome_contato" required
                value="<%= lead?.nome_contato || '' %>"
                class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
            </div>
            <div>
              <label class="block text-xs font-semibold text-gray-600 mb-1">Email *</label>
              <input type="email" name="email" required
                value="<%= lead?.email || '' %>"
                class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
            </div>
            <div>
              <label class="block text-xs font-semibold text-gray-600 mb-1">WhatsApp</label>
              <input type="tel" name="telefone"
                value="<%= lead?.telefone || '' %>"
                placeholder="(11) 99999-9999"
                class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
            </div>
            <div>
              <label class="block text-xs font-semibold text-gray-600 mb-1">CPF / CNPJ</label>
              <input type="text" name="cpf_cnpj"
                value="<%= lead?.cpf_cnpj || '' %>"
                class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
            </div>
          </div>

          <div class="mb-4">
            <label class="block text-xs font-semibold text-gray-600 mb-1">Nome da loja / empresa *</label>
            <input type="text" name="nome_empresa" required
              value="<%= lead?.nome_empresa || '' %>"
              class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
          </div>

          <div class="mb-6">
            <label class="block text-xs font-semibold text-gray-600 mb-1">Subdomínio da loja *</label>
            <div class="flex items-center border border-gray-300 rounded-lg overflow-hidden focus-within:ring-2 focus-within:ring-blue-500">
              <input type="text" name="slug_desejado" id="slug" required
                value="<%= lead?.slug_desejado || '' %>"
                pattern="[a-z0-9-]{3,50}"
                placeholder="minha-loja"
                class="flex-1 px-3 py-2 text-sm outline-none">
              <span class="bg-gray-100 text-gray-500 text-xs px-3 py-2 border-l border-gray-300">.sualoja.com.br</span>
            </div>
            <p class="text-xs text-gray-400 mt-1">Apenas letras minúsculas, números e hífen. Não pode ser alterado depois.</p>
          </div>

          <!-- Seleção de plano -->
          <div class="mb-6">
            <label class="block text-xs font-semibold text-gray-600 mb-2">Plano</label>
            <div class="grid grid-cols-3 gap-2">
              <% planos.forEach(p => { %>
              <label class="cursor-pointer">
                <input type="radio" name="plano" value="<%= p.id %>" class="sr-only peer" <%= p.id === plano.id ? 'checked' : '' %>>
                <div class="border-2 rounded-xl px-3 py-2 text-center text-xs font-semibold transition
                            peer-checked:border-blue-500 peer-checked:bg-blue-50 peer-checked:text-blue-700
                            border-gray-200 text-gray-600 hover:border-gray-300">
                  <%= p.nome %><br>
                  <span class="font-normal">R$ <%= p.preco %>/mês</span>
                </div>
              </label>
              <% }); %>
            </div>
          </div>

          <div class="mb-6">
            <label class="flex items-start gap-2 cursor-pointer">
              <input type="checkbox" name="termos" class="mt-0.5 accent-blue-600" required>
              <span class="text-xs text-gray-600">Li e aceito os <a href="#" class="text-blue-600 underline">Termos de Uso</a> e a <a href="#" class="text-blue-600 underline">Política de Privacidade</a>.</span>
            </label>
          </div>

          <button type="submit"
            class="w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 rounded-xl transition">
            Continuar para pagamento →
          </button>
        </form>
      </div>

      <!-- Resumo do plano -->
      <div class="md:col-span-1">
        <div class="bg-blue-50 border border-blue-100 rounded-2xl p-6 sticky top-6">
          <h3 class="font-bold text-blue-800 mb-1">Plano <%= plano.nome %></h3>
          <p class="text-sm text-blue-600 mb-4"><%= plano.descricao %></p>
          <div class="text-3xl font-extrabold text-blue-900 mb-1">R$&nbsp;<%= plano.preco %><span class="text-base font-normal text-blue-400">/mês</span></div>
          <p class="text-xs text-blue-400 mb-4">+ <%= plano.fee.toFixed(2).replace('.', ',') %>% por transação</p>
          <ul class="space-y-2">
            <% plano.recursos.forEach(r => { %>
            <li class="text-xs text-blue-700 flex items-center gap-1.5">
              <svg class="w-3.5 h-3.5 text-blue-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
              <%= r %>
            </li>
            <% }); %>
          </ul>
        </div>
      </div>

    </div>
  </main>

  <script>
    // Auto-gerar slug a partir do nome da empresa
    const nomeEmpresa = document.querySelector('[name="nome_empresa"]');
    const slugInput = document.getElementById('slug');
    nomeEmpresa.addEventListener('input', () => {
      if (slugInput.dataset.editado) return;
      slugInput.value = nomeEmpresa.value
        .toLowerCase()
        .normalize('NFD').replace(/[̀-ͯ]/g, '')
        .replace(/[^a-z0-9]+/g, '-')
        .replace(/^-|-$/g, '')
        .slice(0, 50);
    });
    slugInput.addEventListener('input', () => { slugInput.dataset.editado = '1'; });
  </script>
</body>
</html>
