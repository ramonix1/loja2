<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Relatórios - Admin</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap');
    body { font-family: 'Inter', sans-serif; }
    @media print {
      aside, .no-print { display: none !important; }
      main { margin-left: 0 !important; padding: 16px !important; }
      body { background: white !important; color: black !important; }
      .print-bg { background: white !important; color: black !important; border: 1px solid #ccc !important; }
      .bar-chart-bar { background: #3b82f6 !important; }
    }
  </style>
</head>
<body class="bg-gray-950 min-h-screen text-white">
<div class="flex min-h-screen">

  <%- include('../partials/admin-sidebar') %>

  <main class="ml-60 flex-1 p-8">

    <!-- Cabeçalho -->
    <div class="mb-6 flex flex-wrap items-start justify-between gap-4">
      <div>
        <div class="text-xs text-gray-500 mb-1">
          <a href="/admin" class="hover:text-gray-300 transition">Dashboard</a>
          <span class="mx-2">/</span>
          <span class="text-gray-300">Relatórios</span>
        </div>
        <h1 class="text-2xl font-bold text-white">📊 Relatórios</h1>
        <p class="text-gray-400 mt-1 text-sm">Visão analítica do negócio</p>
      </div>
      <div class="flex gap-2 no-print">
        <button onclick="window.print()"
          class="bg-gray-700 hover:bg-gray-600 text-gray-200 px-4 py-2 rounded-lg text-sm font-medium transition flex items-center gap-2">
          🖨️ Imprimir
        </button>
        <a href="/admin/relatorios/csv/<%= aba %>?inicio=<%= dataInicio %>&fim=<%= dataFim %>"
          class="bg-green-700 hover:bg-green-600 text-white px-4 py-2 rounded-lg text-sm font-medium transition flex items-center gap-2">
          ⬇️ Exportar CSV
        </a>
      </div>
    </div>

    <!-- Filtro de datas -->
    <% if (['vendas','produtos','financeiro','clientes','agendamentos'].includes(aba)) { %>
    <form method="GET" action="/admin/relatorios" class="bg-gray-900 border border-gray-800 rounded-xl px-5 py-4 mb-6 flex flex-wrap gap-3 items-end no-print">
      <input type="hidden" name="aba" value="<%= aba %>">
      <div>
        <label class="block text-xs text-gray-400 mb-1">Início</label>
        <input type="date" name="inicio" value="<%= dataInicio %>"
          class="bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-sm text-white focus:outline-none focus:border-blue-500">
      </div>
      <div>
        <label class="block text-xs text-gray-400 mb-1">Fim</label>
        <input type="date" name="fim" value="<%= dataFim %>"
          class="bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-sm text-white focus:outline-none focus:border-blue-500">
      </div>
      <button type="submit"
        class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg text-sm font-semibold transition">
        Filtrar
      </button>
      <a href="/admin/relatorios?aba=<%= aba %>"
        class="text-gray-400 hover:text-white text-sm py-2 transition">Limpar filtro</a>
    </form>
    <% } %>

    <!-- Abas -->
    <div class="flex gap-1 mb-6 bg-gray-900 border border-gray-800 p-1 rounded-xl w-fit no-print">
      <% [
        { id:'vendas',     icon:'<span style="display:flex;align-items:center;width:20px;height:20px;"><%- icon('shopping_cart', 'w-5 h-5') %></span>', label:'Vendas' },
        { id:'estoque',    icon:'<span style="display:flex;align-items:center;width:20px;height:20px;"><%- icon('package', 'w-5 h-5') %></span>', label:'Estoque' },
        { id:'entregas',   icon:'🚚', label:'Entregas' },
        { id:'produtos',   icon:'🏆', label:'Produtos' },
        { id:'financeiro', icon:'<span style="display:flex;align-items:center;width:20px;height:20px;"><%- icon('money', 'w-5 h-5') %></span>', label:'Financeiro' },
        { id:'clientes',      icon:'👥', label:'Clientes' },
        { id:'agendamentos',  icon:'📅', label:'Agendamentos' },
      ].forEach(function(a) { %>
        <a href="/admin/relatorios?aba=<%= a.id %>&inicio=<%= dataInicio %>&fim=<%= dataFim %>"
          class="flex items-center gap-1.5 px-4 py-2 rounded-lg text-sm font-medium transition
                 <%= aba === a.id ? 'bg-blue-600 text-white' : 'text-gray-400 hover:text-white hover:bg-gray-800' %>">
          <%= a.icon %> <%= a.label %>
        </a>
      <% }) %>
    </div>

    <!-- Erro -->
    <% if (dados.erro) { %>
      <div class="bg-red-900/30 border border-red-700 text-red-300 rounded-xl px-5 py-4 mb-6">
        Erro ao carregar relatório: <%= dados.erro %>
      </div>
    <% } %>

    <!-- ════════════════════════════════════════════════════════════
         ABA: VENDAS
    ════════════════════════════════════════════════════════════ -->
    <% if (aba === 'vendas' && !dados.erro) { %>

      <!-- KPIs -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
          <div class="text-xs text-gray-500 mb-1">Total de Pedidos</div>
          <div class="text-2xl font-bold text-white"><%= dados.resumo.total_pedidos %></div>
          <div class="text-xs text-gray-600 mt-1"><%= dados.pedidos.filter(p=>p.status==='cancelado').length %> cancelados</div>
        </div>
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
          <div class="text-xs text-gray-500 mb-1">Receita Confirmada</div>
          <div class="text-2xl font-bold text-green-400">R$ <%= Number(dados.resumo.receita_confirmada).toFixed(2).replace('.', ',') %></div>
        </div>
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
          <div class="text-xs text-gray-500 mb-1">Ticket Médio</div>
          <div class="text-2xl font-bold text-blue-400">R$ <%= Number(dados.resumo.ticket_medio).toFixed(2).replace('.', ',') %></div>
        </div>
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
          <div class="text-xs text-gray-500 mb-1">Pendente de Pagamento</div>
          <div class="text-2xl font-bold text-yellow-400">R$ <%= Number(dados.resumo.receita_pendente).toFixed(2).replace('.', ',') %></div>
        </div>
      </div>

      <!-- Gráfico por dia -->
      <% if (dados.porDia && dados.porDia.length > 0) { %>
      <div class="bg-gray-900 border border-gray-800 rounded-xl p-5 mb-6">
        <h3 class="text-sm font-semibold text-white mb-4">Receita por Dia</h3>
        <%
          const maxReceita = Math.max(...dados.porDia.map(d => parseFloat(d.receita) || 0), 1);
        %>
        <div class="flex items-end gap-1 h-32 overflow-x-auto pb-2">
          <% dados.porDia.forEach(function(d) {
            const h = Math.round((parseFloat(d.receita || 0) / maxReceita) * 100);
          %>
            <div class="flex flex-col items-center gap-1 flex-1 min-w-[24px] group relative">
              <div class="absolute -top-7 left-1/2 -translate-x-1/2 bg-gray-700 text-white text-xs rounded px-1.5 py-0.5 whitespace-nowrap opacity-0 group-hover:opacity-100 pointer-events-none z-10">
                R$ <%= Number(d.receita).toFixed(2).replace('.', ',') %>
              </div>
              <div class="bar-chart-bar w-full bg-blue-600 rounded-t transition-all" style="height:<%= h %>%"></div>
            </div>
          <% }); %>
        </div>
        <div class="flex gap-1 overflow-x-auto mt-1">
          <% dados.porDia.forEach(function(d) { %>
            <div class="flex-1 min-w-[24px] text-center text-[9px] text-gray-600 truncate">
              <%= new Date(d.dia).getDate() %>/<%= new Date(d.dia).getMonth()+1 %>
            </div>
          <% }); %>
        </div>
      </div>
      <% } %>

      <!-- Tabela de pedidos -->
      <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
        <h3 class="text-sm font-semibold text-white mb-4">Pedidos no Período</h3>
        <% if (dados.pedidos.length === 0) { %>
          <p class="text-gray-500 text-sm text-center py-8">Nenhum pedido no período selecionado.</p>
        <% } else { %>
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-gray-800 text-xs text-gray-500 uppercase tracking-wider">
                <th class="pb-2 text-left">#</th>
                <th class="pb-2 text-left">Data</th>
                <th class="pb-2 text-left">Cliente</th>
                <th class="pb-2 text-right">Itens</th>
                <th class="pb-2 text-right">Total</th>
                <th class="pb-2 text-left">Pagamento</th>
                <th class="pb-2 text-left">Status</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-800">
              <% dados.pedidos.forEach(function(p) { %>
              <tr class="hover:bg-gray-800/40 transition">
                <td class="py-2 pr-3 text-gray-500">#<%= p.id %></td>
                <td class="py-2 pr-3 text-gray-300 whitespace-nowrap">
                  <%= new Date(p.created_at).toLocaleDateString('pt-BR') %>
                </td>
                <td class="py-2 pr-3">
                  <div class="text-white text-sm"><%= p.cliente_nome %></div>
                  <div class="text-gray-500 text-xs"><%= p.email_entrega %></div>
                </td>
                <td class="py-2 pr-3 text-right text-gray-300"><%= p.qtd_itens %></td>
                <td class="py-2 pr-3 text-right font-semibold text-green-400">
                  R$ <%= Number(p.total).toFixed(2).replace('.', ',') %>
                </td>
                <td class="py-2 pr-3 text-gray-400 text-xs capitalize"><%= p.metodo_pagamento || '—' %></td>
                <td class="py-2">
                  <%
                    const statusCores = {
                      pago: 'bg-green-900/40 text-green-400',
                      enviado: 'bg-blue-900/40 text-blue-400',
                      entregue: 'bg-teal-900/40 text-teal-400',
                      cancelado: 'bg-red-900/40 text-red-400',
                      aguardando_pagamento: 'bg-yellow-900/40 text-yellow-400',
                      em_separacao: 'bg-purple-900/40 text-purple-400',
                    };
                    const cor = statusCores[p.status] || 'bg-gray-800 text-gray-400';
                  %>
                  <span class="px-2 py-0.5 rounded-full text-xs font-medium <%= cor %>">
                    <%= STATUS_LABEL[p.status] || p.status %>
                  </span>
                </td>
              </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
        <% } %>
      </div>

    <!-- ════════════════════════════════════════════════════════════
         ABA: ESTOQUE
    ════════════════════════════════════════════════════════════ -->
    <% } else if (aba === 'estoque' && !dados.erro) { %>

      <!-- KPIs estoque -->
      <div class="grid grid-cols-2 md:grid-cols-5 gap-4 mb-6">
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
          <div class="text-xs text-gray-500 mb-1">Total de Produtos</div>
          <div class="text-2xl font-bold text-white"><%= dados.resumo.total %></div>
        </div>
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
          <div class="text-xs text-gray-500 mb-1">OK</div>
          <div class="text-2xl font-bold text-green-400"><%= dados.resumo.ok %></div>
        </div>
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
          <div class="text-xs text-gray-500 mb-1">Estoque Baixo</div>
          <div class="text-2xl font-bold text-yellow-400"><%= dados.resumo.baixo %></div>
        </div>
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
          <div class="text-xs text-gray-500 mb-1">Esgotados</div>
          <div class="text-2xl font-bold text-red-400"><%= dados.resumo.esgotados %></div>
        </div>
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
          <div class="text-xs text-gray-500 mb-1">Ilimitados</div>
          <div class="text-2xl font-bold text-gray-400"><%= dados.resumo.ilimitados %></div>
        </div>
      </div>

      <!-- Filtro estoque -->
      <form method="GET" action="/admin/relatorios" class="flex gap-2 mb-4 no-print">
        <input type="hidden" name="aba" value="estoque">
        <% [
          { v:'todos', l:'Todos' },
          { v:'esgotado', l:'Esgotados' },
          { v:'baixo', l:'Estoque Baixo' },
          { v:'ok', l:'OK' },
          { v:'ilimitado', l:'Ilimitados' },
        ].forEach(function(f) { %>
          <button type="submit" name="filtro_estoque" value="<%= f.v %>"
            class="px-3 py-1.5 rounded-lg text-xs font-medium transition
                   <%= filtroEstoque === f.v ? 'bg-blue-600 text-white' : 'bg-gray-800 text-gray-400 hover:bg-gray-700' %>">
            <%= f.l %>
          </button>
        <% }); %>
      </form>

      <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
        <% if (dados.produtos.length === 0) { %>
          <p class="text-gray-500 text-sm text-center py-8">Nenhum produto encontrado.</p>
        <% } else { %>
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-gray-800 text-xs text-gray-500 uppercase tracking-wider">
                <th class="pb-2 text-left">Produto</th>
                <th class="pb-2 text-left">Categoria</th>
                <th class="pb-2 text-right">Valor</th>
                <th class="pb-2 text-right">Estoque</th>
                <th class="pb-2 text-left">Status</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-800">
              <% dados.produtos.forEach(function(p) {
                const st = p.estoque === null ? 'ilimitado' : p.estoque === 0 ? 'esgotado' : p.estoque <= 5 ? 'baixo' : 'ok';
                const stCores = { ok:'text-green-400', baixo:'text-yellow-400', esgotado:'text-red-400', ilimitado:'text-gray-500' };
                const stLabel = { ok:'OK', baixo:'Estoque baixo', esgotado:'Esgotado', ilimitado:'Ilimitado' };
              %>
              <tr class="hover:bg-gray-800/40 transition">
                <td class="py-2 pr-4 font-medium text-white"><%= p.nome %></td>
                <td class="py-2 pr-4 text-gray-400 text-xs"><%= p.categoria_nome || '—' %></td>
                <td class="py-2 pr-4 text-right text-green-400">R$ <%= Number(p.valor).toFixed(2).replace('.', ',') %></td>
                <td class="py-2 pr-4 text-right font-semibold <%= stCores[st] %>">
                  <%= p.estoque !== null ? p.estoque : '∞' %>
                </td>
                <td class="py-2">
                  <span class="text-xs font-medium <%= stCores[st] %>"><%= stLabel[st] %></span>
                </td>
              </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
        <% } %>
      </div>

    <!-- ════════════════════════════════════════════════════════════
         ABA: ENTREGAS
    ════════════════════════════════════════════════════════════ -->
    <% } else if (aba === 'entregas' && !dados.erro) { %>

      <!-- KPIs por status -->
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4 mb-6">
        <%
          const statusOrdem = ['aguardando_pagamento','pago','em_separacao','enviado','entregue','cancelado'];
          const statusCoresKpi = {
            aguardando_pagamento: 'border-yellow-700/50 text-yellow-400',
            pago: 'border-green-700/50 text-green-400',
            em_separacao: 'border-purple-700/50 text-purple-400',
            enviado: 'border-blue-700/50 text-blue-400',
            entregue: 'border-teal-700/50 text-teal-400',
            cancelado: 'border-red-700/50 text-red-400',
          };
          const statusMap = {};
          dados.porStatus.forEach(function(s) { statusMap[s.status] = s; });
        %>
        <% statusOrdem.forEach(function(s) {
          const item = statusMap[s] || { total:0, valor:0 };
        %>
        <div class="bg-gray-900 border rounded-xl p-4 <%= statusCoresKpi[s] || 'border-gray-700 text-gray-400' %>">
          <div class="text-xs text-gray-500 mb-1 truncate"><%= STATUS_LABEL[s] || s %></div>
          <div class="text-xl font-bold"><%= item.total %></div>
        </div>
        <% }); %>
      </div>

      <!-- Pedidos em aberto -->
      <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
        <h3 class="text-sm font-semibold text-white mb-4">Pedidos em Andamento</h3>
        <% if (dados.pedidos.length === 0) { %>
          <p class="text-gray-500 text-sm text-center py-8">Nenhum pedido em andamento.</p>
        <% } else { %>
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-gray-800 text-xs text-gray-500 uppercase tracking-wider">
                <th class="pb-2 text-left">#</th>
                <th class="pb-2 text-left">Data</th>
                <th class="pb-2 text-left">Destinatário</th>
                <th class="pb-2 text-left">Cidade/UF</th>
                <th class="pb-2 text-left">Serviço</th>
                <th class="pb-2 text-left">Rastreio</th>
                <th class="pb-2 text-right">Total</th>
                <th class="pb-2 text-left">Status</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-800">
              <% dados.pedidos.forEach(function(p) {
                const statusCores = {
                  pago: 'bg-green-900/40 text-green-400',
                  enviado: 'bg-blue-900/40 text-blue-400',
                  em_separacao: 'bg-purple-900/40 text-purple-400',
                  aguardando_pagamento: 'bg-yellow-900/40 text-yellow-400',
                };
                const cor = statusCores[p.status] || 'bg-gray-800 text-gray-400';
              %>
              <tr class="hover:bg-gray-800/40 transition">
                <td class="py-2 pr-3 text-gray-500">
                  <a href="/admin/pedidos/<%= p.id %>" class="hover:text-blue-400 transition">#<%= p.id %></a>
                </td>
                <td class="py-2 pr-3 text-gray-300 whitespace-nowrap text-xs">
                  <%= new Date(p.created_at).toLocaleDateString('pt-BR') %>
                </td>
                <td class="py-2 pr-3">
                  <div class="text-white text-sm"><%= p.nome_entrega %></div>
                  <div class="text-gray-500 text-xs"><%= p.email_entrega %></div>
                </td>
                <td class="py-2 pr-3 text-gray-400 text-xs"><%= p.cidade || '' %>/<%= p.estado || '' %></td>
                <td class="py-2 pr-3 text-gray-400 text-xs"><%= p.frete_servico || '—' %></td>
                <td class="py-2 pr-3">
                  <% if (p.codigo_rastreio) { %>
                    <a href="https://www.correios.com.br/rastreamento/#/<%= p.codigo_rastreio %>"
                       target="_blank" class="text-blue-400 hover:underline text-xs font-mono">
                      <%= p.codigo_rastreio %>
                    </a>
                  <% } else { %>
                    <span class="text-gray-600 text-xs">—</span>
                  <% } %>
                </td>
                <td class="py-2 pr-3 text-right font-semibold text-green-400 text-sm">
                  R$ <%= Number(p.total).toFixed(2).replace('.', ',') %>
                </td>
                <td class="py-2">
                  <span class="px-2 py-0.5 rounded-full text-xs font-medium <%= cor %>">
                    <%= STATUS_LABEL[p.status] || p.status %>
                  </span>
                </td>
              </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
        <% } %>
      </div>

    <!-- ════════════════════════════════════════════════════════════
         ABA: PRODUTOS
    ════════════════════════════════════════════════════════════ -->
    <% } else if (aba === 'produtos' && !dados.erro) { %>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">

        <!-- Top 20 produtos -->
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
          <h3 class="text-sm font-semibold text-white mb-4">🏆 Top Produtos Vendidos</h3>
          <% if (dados.topProdutos.length === 0) { %>
            <p class="text-gray-500 text-sm text-center py-8">Nenhum produto vendido no período.</p>
          <% } else { %>
            <%
              const maxVendidos = Math.max(...dados.topProdutos.map(p => parseInt(p.total_vendido) || 0), 1);
            %>
            <div class="space-y-3">
              <% dados.topProdutos.forEach(function(p, i) {
                const pct = Math.round((parseInt(p.total_vendido) / maxVendidos) * 100);
              %>
              <div>
                <div class="flex justify-between items-center mb-1">
                  <span class="text-xs text-gray-300 truncate pr-2">
                    <span class="text-gray-600 mr-1"><%= i+1 %>.</span><%= p.nome_produto %>
                  </span>
                  <div class="text-right flex-shrink-0">
                    <span class="text-xs font-semibold text-white"><%= p.total_vendido %> un.</span>
                    <span class="text-xs text-green-400 ml-2">R$ <%= Number(p.receita_total).toFixed(2).replace('.', ',') %></span>
                  </div>
                </div>
                <div class="h-1.5 bg-gray-800 rounded-full overflow-hidden">
                  <div class="h-full bg-blue-600 rounded-full" style="width:<%= pct %>%"></div>
                </div>
              </div>
              <% }); %>
            </div>
          <% } %>
        </div>

        <!-- Por categoria -->
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
          <h3 class="text-sm font-semibold text-white mb-4">📁 Receita por Categoria</h3>
          <% if (dados.porCategoria.length === 0) { %>
            <p class="text-gray-500 text-sm text-center py-8">Nenhum dado no período.</p>
          <% } else { %>
            <%
              const maxCat = Math.max(...dados.porCategoria.map(c => parseFloat(c.receita_total) || 0), 1);
            %>
            <div class="space-y-3">
              <% dados.porCategoria.forEach(function(c) {
                const pct = Math.round((parseFloat(c.receita_total) / maxCat) * 100);
              %>
              <div>
                <div class="flex justify-between items-center mb-1">
                  <span class="text-xs text-gray-300"><%= c.categoria %></span>
                  <div class="text-right">
                    <span class="text-xs text-gray-400"><%= c.total_vendido %> un.</span>
                    <span class="text-xs font-semibold text-green-400 ml-2">R$ <%= Number(c.receita_total).toFixed(2).replace('.', ',') %></span>
                  </div>
                </div>
                <div class="h-1.5 bg-gray-800 rounded-full overflow-hidden">
                  <div class="h-full bg-emerald-600 rounded-full" style="width:<%= pct %>%"></div>
                </div>
              </div>
              <% }); %>
            </div>
          <% } %>
        </div>

      </div>

    <!-- ════════════════════════════════════════════════════════════
         ABA: FINANCEIRO
    ════════════════════════════════════════════════════════════ -->
    <% } else if (aba === 'financeiro' && !dados.erro) { %>

      <!-- KPIs financeiro -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
          <div class="text-xs text-gray-500 mb-1">Receita Total</div>
          <div class="text-2xl font-bold text-green-400">R$ <%= Number(dados.resumo.receita_total).toFixed(2).replace('.', ',') %></div>
        </div>
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
          <div class="text-xs text-gray-500 mb-1">Total Pedidos</div>
          <div class="text-2xl font-bold text-white"><%= dados.resumo.total_pedidos %></div>
        </div>
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
          <div class="text-xs text-gray-500 mb-1">Ticket Médio</div>
          <div class="text-2xl font-bold text-blue-400">R$ <%= Number(dados.resumo.ticket_medio).toFixed(2).replace('.', ',') %></div>
        </div>
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
          <div class="text-xs text-gray-500 mb-1">Total em Frete</div>
          <div class="text-2xl font-bold text-gray-300">R$ <%= Number(dados.resumo.total_frete).toFixed(2).replace('.', ',') %></div>
        </div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

        <!-- Por método de pagamento -->
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
          <h3 class="text-sm font-semibold text-white mb-4">Métodos de Pagamento</h3>
          <% if (dados.porMetodo.length === 0) { %>
            <p class="text-gray-500 text-sm text-center py-6">Nenhum dado.</p>
          <% } else { %>
            <%
              const maxMetodo = Math.max(...dados.porMetodo.map(m => parseFloat(m.receita) || 0), 1);
            %>
            <div class="space-y-3">
              <% dados.porMetodo.forEach(function(m) {
                const pct = Math.round((parseFloat(m.receita) / maxMetodo) * 100);
              %>
              <div>
                <div class="flex justify-between items-center mb-1">
                  <span class="text-sm text-gray-300 capitalize"><%= m.metodo_pagamento %></span>
                  <div class="text-right">
                    <span class="text-xs text-gray-500"><%= m.total_pedidos %> pedidos</span>
                    <span class="text-sm font-semibold text-green-400 ml-3">R$ <%= Number(m.receita).toFixed(2).replace('.', ',') %></span>
                  </div>
                </div>
                <div class="h-2 bg-gray-800 rounded-full overflow-hidden">
                  <div class="h-full bg-blue-600 rounded-full" style="width:<%= pct %>%"></div>
                </div>
              </div>
              <% }); %>
            </div>
          <% } %>
        </div>

        <!-- Receita últimos 12 meses -->
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
          <h3 class="text-sm font-semibold text-white mb-4">Receita — Últimos 12 Meses</h3>
          <% if (!dados.porMes || dados.porMes.length === 0) { %>
            <p class="text-gray-500 text-sm text-center py-6">Nenhum dado.</p>
          <% } else { %>
            <%
              const maxMes = Math.max(...dados.porMes.map(m => parseFloat(m.receita) || 0), 1);
            %>
            <div class="flex items-end gap-1 h-36 overflow-x-auto pb-2">
              <% dados.porMes.forEach(function(m) {
                const h = Math.round((parseFloat(m.receita || 0) / maxMes) * 100);
              %>
                <div class="flex flex-col items-center gap-1 flex-1 min-w-[28px] group relative">
                  <div class="absolute -top-7 left-1/2 -translate-x-1/2 bg-gray-700 text-white text-xs rounded px-1.5 py-0.5 whitespace-nowrap opacity-0 group-hover:opacity-100 pointer-events-none z-10">
                    R$ <%= Number(m.receita).toFixed(2).replace('.', ',') %>
                  </div>
                  <div class="bar-chart-bar w-full bg-blue-600 rounded-t" style="height:<%= h %>%"></div>
                  <div class="text-[9px] text-gray-600 truncate w-full text-center">
                    <%= new Date(m.mes).toLocaleDateString('pt-BR', { month:'short' }) %>
                  </div>
                </div>
              <% }); %>
            </div>
          <% } %>
        </div>

      </div>

    <!-- ════════════════════════════════════════════════════════════
         ABA: CLIENTES
    ════════════════════════════════════════════════════════════ -->
    <% } else if (aba === 'clientes' && !dados.erro) { %>

      <!-- KPIs -->
      <div class="grid grid-cols-2 md:grid-cols-3 gap-4 mb-6">
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
          <div class="text-xs text-gray-500 mb-1">Total de Clientes</div>
          <div class="text-2xl font-bold text-white"><%= dados.totalClientes %></div>
        </div>
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
          <div class="text-xs text-gray-500 mb-1">Clientes Ativos (período)</div>
          <div class="text-2xl font-bold text-blue-400"><%= dados.topClientes.length %></div>
        </div>
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
          <div class="text-xs text-gray-500 mb-1">Novos no Período</div>
          <div class="text-2xl font-bold text-green-400">
            <%= dados.novosPorDia.reduce(function(s, d) { return s + parseInt(d.novos || 0); }, 0) %>
          </div>
        </div>
      </div>

      <!-- Gráfico novos clientes por dia -->
      <% if (dados.novosPorDia && dados.novosPorDia.length > 0) { %>
      <div class="bg-gray-900 border border-gray-800 rounded-xl p-5 mb-6">
        <h3 class="text-sm font-semibold text-white mb-4">Novos Clientes por Dia</h3>
        <%
          const maxNovos = Math.max(...dados.novosPorDia.map(d => parseInt(d.novos) || 0), 1);
        %>
        <div class="flex items-end gap-1 h-24 overflow-x-auto pb-2">
          <% dados.novosPorDia.forEach(function(d) {
            const h = Math.round((parseInt(d.novos || 0) / maxNovos) * 100);
          %>
            <div class="flex flex-col items-center gap-1 flex-1 min-w-[24px] group relative">
              <div class="absolute -top-7 left-1/2 -translate-x-1/2 bg-gray-700 text-white text-xs rounded px-1.5 py-0.5 opacity-0 group-hover:opacity-100 pointer-events-none z-10">
                <%= d.novos %>
              </div>
              <div class="bar-chart-bar w-full bg-blue-600 rounded-t" style="height:<%= h %>%"></div>
              <div class="text-[9px] text-gray-600">
                <%= new Date(d.dia).getDate() %>
              </div>
            </div>
          <% }); %>
        </div>
      </div>
      <% } %>

      <!-- Ranking clientes -->
      <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
        <h3 class="text-sm font-semibold text-white mb-4">Clientes com Maior Compra no Período</h3>
        <% if (dados.topClientes.length === 0) { %>
          <p class="text-gray-500 text-sm text-center py-8">Nenhum cliente com pedidos no período.</p>
        <% } else { %>
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-gray-800 text-xs text-gray-500 uppercase tracking-wider">
                <th class="pb-2 text-left">#</th>
                <th class="pb-2 text-left">Cliente</th>
                <th class="pb-2 text-right">Pedidos</th>
                <th class="pb-2 text-right">Total Gasto</th>
                <th class="pb-2 text-left">Último Pedido</th>
                <th class="pb-2 text-left">Membro Desde</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-800">
              <% dados.topClientes.forEach(function(c, i) { %>
              <tr class="hover:bg-gray-800/40 transition">
                <td class="py-2 pr-3 text-gray-600 text-xs"><%= i+1 %>.</td>
                <td class="py-2 pr-4">
                  <div class="font-medium text-white"><%= c.nome %></div>
                  <div class="text-gray-500 text-xs"><%= c.email %></div>
                </td>
                <td class="py-2 pr-4 text-right text-gray-300"><%= c.total_pedidos %></td>
                <td class="py-2 pr-4 text-right font-semibold text-green-400">
                  R$ <%= Number(c.total_gasto).toFixed(2).replace('.', ',') %>
                </td>
                <td class="py-2 pr-4 text-gray-400 text-xs whitespace-nowrap">
                  <%= new Date(c.ultimo_pedido).toLocaleDateString('pt-BR') %>
                </td>
                <td class="py-2 text-gray-500 text-xs whitespace-nowrap">
                  <%= new Date(c.membro_desde).toLocaleDateString('pt-BR') %>
                </td>
              </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
        <% } %>
      </div>

    <% } %>

    <!-- ════════════════════════════════════════════════════════════
         ABA: AGENDAMENTOS
    ════════════════════════════════════════════════════════════ -->
    <% if (aba === 'agendamentos' && !dados.erro) { %>

      <!-- Cards de resumo -->
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-4 print-bg">
          <div class="text-xs text-gray-500 mb-1">Total no período</div>
          <div class="text-2xl font-bold text-white"><%= dados.resumo.total %></div>
        </div>
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-4 print-bg">
          <div class="text-xs text-gray-500 mb-1">Confirmados</div>
          <div class="text-2xl font-bold text-green-400"><%= dados.resumo.confirmados %></div>
        </div>
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-4 print-bg">
          <div class="text-xs text-gray-500 mb-1">Cancelados</div>
          <div class="text-2xl font-bold text-red-400"><%= dados.resumo.cancelados %></div>
        </div>
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-4 print-bg">
          <div class="text-xs text-gray-500 mb-1">Receita confirmada</div>
          <div class="text-2xl font-bold text-blue-400">
            R$ <%= Number(dados.resumo.receita_confirmada).toFixed(2).replace('.', ',') %>
          </div>
        </div>
      </div>

      <!-- Gráfico por mês -->
      <% if (dados.porMes.length > 0) { %>
      <div class="bg-gray-900 border border-gray-800 rounded-xl p-5 mb-6 print-bg">
        <h3 class="text-sm font-semibold text-white mb-4">Agendamentos por Mês (últimos 12 meses)</h3>
        <% const maxMes = Math.max(...dados.porMes.map(m => m.confirmados), 1); %>
        <div class="space-y-2">
          <% dados.porMes.forEach(function(m) { %>
            <div class="flex items-center gap-3">
              <div class="text-xs text-gray-400 w-20 flex-shrink-0">
                <%= new Date(m.mes).toLocaleDateString('pt-BR', {month:'short', year:'2-digit'}) %>
              </div>
              <div class="flex-1 bg-gray-800 rounded-full h-5 overflow-hidden">
                <div class="bar-chart-bar h-full rounded-full bg-blue-600 flex items-center justify-end pr-2"
                     style="width: <%= Math.max((m.confirmados / maxMes) * 100, 2) %>%">
                  <span class="text-xs text-white font-medium"><%= m.confirmados %></span>
                </div>
              </div>
              <div class="text-xs text-gray-400 w-24 text-right flex-shrink-0">
                R$ <%= Number(m.receita).toFixed(2).replace('.', ',') %>
              </div>
            </div>
          <% }) %>
        </div>
      </div>
      <% } %>

      <!-- Tabela de agendamentos -->
      <div class="bg-gray-900 border border-gray-800 rounded-xl p-5 print-bg">
        <h3 class="text-sm font-semibold text-white mb-4">
          Relação de Agendamentos
          <span class="text-gray-500 font-normal">
            — datas de evento entre <%= new Date(dataInicio).toLocaleDateString('pt-BR') %>
            e <%= new Date(dataFim + 'T23:59:59').toLocaleDateString('pt-BR') %>
          </span>
        </h3>

        <% if (dados.agendamentos.length === 0) { %>
          <p class="text-gray-500 text-sm text-center py-8">Nenhum agendamento no período selecionado.</p>
        <% } else { %>
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-gray-800 text-xs text-gray-500 uppercase tracking-wider">
                <th class="pb-2 text-left">Pedido</th>
                <th class="pb-2 text-left">Cliente</th>
                <th class="pb-2 text-left">Data da compra</th>
                <th class="pb-2 text-left">Data agendada</th>
                <th class="pb-2 text-left">Produtos</th>
                <th class="pb-2 text-right">Total</th>
                <th class="pb-2 text-center">Agendamento</th>
                <th class="pb-2 text-center">Pedido</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-800">
              <% dados.agendamentos.forEach(function(a) { %>
              <tr class="hover:bg-gray-800/40 transition">
                <td class="py-3 pr-4">
                  <a href="/admin/pedidos/<%= a.pedido_id %>"
                     class="text-blue-400 hover:text-blue-300 font-medium">#<%= a.pedido_id %></a>
                </td>
                <td class="py-3 pr-4">
                  <a href="/admin/compradores/<%= a.usuario_id %>"
                     class="hover:text-blue-300 transition">
                    <div class="font-medium text-white"><%= a.cliente_nome %></div>
                    <div class="text-xs text-gray-500"><%= a.email %></div>
                    <% if (a.telefone) { %>
                      <div class="text-xs text-gray-600"><%= a.telefone %></div>
                    <% } %>
                  </a>
                </td>
                <td class="py-3 pr-4 text-gray-400 text-xs whitespace-nowrap">
                  <%= new Date(a.data_compra).toLocaleDateString('pt-BR') %>
                  <div class="text-gray-600">
                    <%= new Date(a.data_compra).toLocaleTimeString('pt-BR', {hour:'2-digit', minute:'2-digit'}) %>
                  </div>
                </td>
                <td class="py-3 pr-4 whitespace-nowrap">
                  <div class="font-semibold text-white">
                    <%= new Date(a.data_evento + 'T12:00:00').toLocaleDateString('pt-BR', {day:'2-digit', month:'short', year:'numeric'}) %>
                  </div>
                  <div class="text-xs text-gray-500">
                    <%= new Date(a.data_evento + 'T12:00:00').toLocaleDateString('pt-BR', {weekday:'long'}) %>
                  </div>
                </td>
                <td class="py-3 pr-4 text-gray-300 text-xs max-w-xs">
                  <%= a.produtos || '—' %>
                </td>
                <td class="py-3 pr-4 text-right font-semibold text-green-400 whitespace-nowrap">
                  R$ <%= Number(a.total).toFixed(2).replace('.', ',') %>
                </td>
                <td class="py-3 pr-4 text-center">
                  <span class="text-xs px-2 py-0.5 rounded-full font-medium
                    <%= a.status_agendamento === 'confirmado' ? 'bg-green-900/50 text-green-400' : 'bg-red-900/50 text-red-400' %>">
                    <%= a.status_agendamento === 'confirmado' ? 'Confirmado' : 'Cancelado' %>
                  </span>
                </td>
                <td class="py-3 text-center">
                  <span class="text-xs px-2 py-0.5 rounded-full
                    <%= a.status_pedido === 'pago' || a.status_pedido === 'entregue' ? 'bg-blue-900/50 text-blue-400' :
                        a.status_pedido === 'cancelado' ? 'bg-red-900/50 text-red-400' : 'bg-yellow-900/50 text-yellow-400' %>">
                    <%= STATUS_LABEL[a.status_pedido] || a.status_pedido %>
                  </span>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
        <% } %>
      </div>

    <% } %>

  </main>
</div>
</body>
</html>
