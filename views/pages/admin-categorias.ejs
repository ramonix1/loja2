<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Categorias - Admin</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap');
    body { font-family: 'Inter', sans-serif; }
  </style>
</head>
<body class="bg-gray-950 min-h-screen text-white">
<div class="flex min-h-screen">

  <%- include('../partials/admin-sidebar') %>

  <main class="ml-60 flex-1 p-8">

    <div class="mb-6">
      <div class="text-xs text-gray-500 mb-1">
        <a href="/admin" class="hover:text-gray-300 transition">Dashboard</a>
        <span class="mx-2">/</span>
        <span class="text-gray-300">Categorias</span>
      </div>
      <h1 class="text-2xl font-bold text-white">Categorias</h1>
      <p class="text-gray-400 mt-1 text-sm">Agrupe produtos em seçµes exibidas na vitrine</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

      <!-- Lista de categorias -->
      <div class="lg:col-span-2">
        <% if (categorias.length === 0) { %>
          <div class="bg-gray-900 border border-gray-800 rounded-xl p-12 text-center">
            <div class="text-4xl mb-3"><span style="display:flex;align-items:center;width:60px;height:60px;margin:0 auto;"><%- icon('tag', 'w-16 h-16') %></span></div>
            <p class="text-gray-400 text-sm">Nenhuma categoria criada ainda.</p>
            <p class="text-gray-500 text-xs mt-1">Use o formulário ao lado para criar a primeira.</p>
          </div>
        <% } else { %>
          <div class="space-y-3">
            <% categorias.forEach(function(cat) { %>
              <div class="bg-gray-900 border border-gray-800 rounded-xl p-5 flex items-center justify-between gap-4">
                <div class="flex items-center gap-4 min-w-0">
                  <div class="w-10 h-10 bg-blue-600/20 rounded-lg flex items-center justify-center text-blue-400 text-xl flex-shrink-0">
                    <span style="display:flex;align-items:center;width:24px;height:24px;"><%- icon('tag', 'w-6 h-6') %></span>
                  </div>
                  <div class="min-w-0">
                    <div class="font-semibold text-white truncate"><%= cat.nome %></div>
                    <div class="text-xs text-gray-400 mt-0.5">
                      <%= cat.total_produtos %> produto<%= cat.total_produtos != 1 ? 's' : '' %>
                      <% if (cat.ordem > 0) { %> Â ordem <%= cat.ordem %><% } %>
                    </div>
                  </div>
                </div>
                <div class="flex items-center gap-2 flex-shrink-0">
                  <a href="/admin/categorias/<%= cat.id %>/editar"
                     class="text-sm bg-gray-800 hover:bg-gray-700 text-gray-300 hover:text-white px-3 py-1.5 rounded-lg transition font-medium">
                     Editar
                  </a>
                  <form method="POST" action="/admin/categorias/<%= cat.id %>/remover"
                        onsubmit="return confirm('Remover categoria <%= cat.nome %>? Os produtos não serão excludos.')">
                    <input type="hidden" name="_csrf" value="<%= locals.csrfToken %>">
                    <button type="submit"
                            class="text-sm bg-red-900/40 hover:bg-red-900/70 text-red-400 hover:text-red-300 px-3 py-1.5 rounded-lg transition font-medium">
                      
                    </button>
                  </form>
                </div>
              </div>
            <% }) %>
          </div>
        <% } %>
      </div>

      <!-- Formulário nova categoria -->
      <div>
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-6 sticky top-8">
          <h2 class="text-base font-bold text-white mb-4">Nova categoria</h2>
          <form method="POST" action="/admin/categorias">
            <input type="hidden" name="_csrf" value="<%= locals.csrfToken %>">
            <div class="mb-4">
              <label class="block text-sm font-medium text-gray-300 mb-1.5">Nome *</label>
              <input type="text" name="nome" required placeholder="Ex: Calçados, Roupas..."
                     class="w-full bg-gray-800 border border-gray-700 text-white rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:border-blue-500 placeholder-gray-500">
            </div>
            <button type="submit"
                    class="w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2.5 rounded-lg text-sm transition">
              + Criar categoria
            </button>
          </form>
          <p class="text-xs text-gray-500 mt-4">Após criar, vocª poderá vincular produtos  categoria.</p>
        </div>
      </div>

    </div>
  </main>
</div>
</body>
</html>
