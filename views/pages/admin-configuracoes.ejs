<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ConfiguraĂ§Ăµes - Admin LojĂŁo</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap');
    body { font-family: 'Inter', sans-serif; }
  </style>
</head>

<body class="bg-gray-950 min-h-screen text-white">
<div class="flex min-h-screen">

  <%- include('../partials/admin-sidebar') %>

  <main class="ml-60 flex-1 p-8">

    <div class="mb-6">
      <div class="text-xs text-gray-500 mb-1">
        <a href="/admin" class="hover:text-gray-300 transition">Dashboard</a>
        <span class="mx-2">/</span>
        <span class="text-gray-300">ConfiguraĂ§Ăµes</span>
      </div>
      <h1 class="text-2xl font-bold text-white"><span style="display:flex;align-items:center;width:20px;height:20px;"><%- icon('settings', 'w-5 h-5') %></span> ConfiguraĂ§Ăµes</h1>
      <p class="text-gray-400 mt-1 text-sm">Gerencie as opĂ§Ăµes do sistema</p>
    </div>

    <% if (salvo) { %>
      <div class="mb-6 bg-green-900/50 border border-green-700 text-green-300 rounded-xl px-4 py-3 text-sm">
        <span style="display:flex;align-items:center;width:20px;height:20px;"><%- icon('check', 'w-5 h-5') %></span> ConfiguraĂ§Ăµes salvas com sucesso.
      </div>
    <% } %>
    <% if (erro) { %>
      <div class="mb-6 bg-red-900/50 border border-red-700 text-red-300 rounded-xl px-4 py-3 text-sm">
        <span style="display:flex;align-items:center;width:20px;height:20px;"><%- icon('error', 'w-5 h-5') %></span> Erro ao salvar configuraĂ§Ăµes.
      </div>
    <% } %>

    <form action="/admin/configuracoes" method="POST" class="space-y-6 max-w-2xl">
      <input type="hidden" name="_csrf" value="<%= locals.csrfToken %>">

      <!-- Estoque -->
      <div class="bg-gray-900 border border-gray-800 rounded-xl p-6">
        <h2 class="text-lg font-bold text-white mb-1"><span style="display:flex;align-items:center;width:20px;height:20px;"><%- icon('package', 'w-5 h-5') %></span> Controle de Estoque</h2>
        <p class="text-gray-400 text-sm mb-5">Configure como o estoque dos produtos serĂˇ gerenciado.</p>

        <div class="space-y-5">

          <!-- Toggle: controla_estoque -->
          <label class="flex items-start gap-4 cursor-pointer group">
            <div class="mt-0.5">
              <input type="checkbox" name="controla_estoque" id="controla_estoque"
                     class="sr-only peer" <%= configs.controla_estoque === 'true' ? 'checked' : '' %>>
              <div class="w-11 h-6 bg-gray-700 peer-checked:bg-blue-600 rounded-full relative transition
                          after:content-[''] after:absolute after:top-0.5 after:left-0.5
                          after:bg-white after:rounded-full after:h-5 after:w-5 after:transition
                          peer-checked:after:translate-x-5"></div>
            </div>
            <div>
              <div class="font-medium text-white text-sm">Ativar controle de estoque</div>
              <div class="text-gray-400 text-xs mt-0.5">
                Quando ativado, cada produto pode ter uma quantidade em estoque definida.
                Produtos com estoque zerado serĂŁo marcados como esgotados na vitrine.
              </div>
            </div>
          </label>

          <!-- Toggle: reservar_estoque_carrinho -->
          <label class="flex items-start gap-4 cursor-pointer group" id="reserva-row">
            <div class="mt-0.5">
              <input type="checkbox" name="reservar_estoque_carrinho" id="reservar_estoque_carrinho"
                     class="sr-only peer" <%= configs.reservar_estoque_carrinho === 'true' ? 'checked' : '' %>>
              <div class="w-11 h-6 bg-gray-700 peer-checked:bg-blue-600 rounded-full relative transition
                          after:content-[''] after:absolute after:top-0.5 after:left-0.5
                          after:bg-white after:rounded-full after:h-5 after:w-5 after:transition
                          peer-checked:after:translate-x-5"></div>
            </div>
            <div>
              <div class="font-medium text-white text-sm">Reservar estoque ao adicionar ao carrinho</div>
              <div class="text-gray-400 text-xs mt-0.5">
                <strong>Ativado:</strong> o estoque Ă© bloqueado quando o cliente adiciona ao carrinho,
                impedindo que dois clientes comprem o mesmo item simultaneamente.<br>
                <strong>Desativado:</strong> o estoque sĂł Ă© debitado ao concluir o pagamento.
                Pode haver concorrĂŞncia entre clientes, mas o carrinho nĂŁo bloqueia unidades.
              </div>
            </div>
          </label>

        </div>
      </div>

      <!-- SumUp -->
      <div class="bg-gray-900 border border-gray-800 rounded-xl p-6">
        <h2 class="text-lg font-bold text-white mb-1">ł SumUp</h2>
        <p class="text-gray-400 text-sm mb-5">
          Habilite apenas se sua conta SumUp tiver o mĂłdulo de pagamento online ativo.
          Requer <code class="text-xs bg-gray-800 px-1 rounded">SUMUP_API_KEY</code> e
          <code class="text-xs bg-gray-800 px-1 rounded">SUMUP_MERCHANT_CODE</code> configurados no servidor.
        </p>

        <label class="flex items-start gap-4 cursor-pointer group">
          <div class="mt-0.5">
            <input type="checkbox" name="habilitar_sumup" id="habilitar_sumup"
                   class="sr-only peer" <%= configs.habilitar_sumup === 'true' ? 'checked' : '' %>>
            <div class="w-11 h-6 bg-gray-700 peer-checked:bg-blue-600 rounded-full relative transition
                        after:content-[''] after:absolute after:top-0.5 after:left-0.5
                        after:bg-white after:rounded-full after:h-5 after:w-5 after:transition
                        peer-checked:after:translate-x-5"></div>
          </div>
          <div>
            <div class="font-medium text-white text-sm">Exibir opĂ§ĂŁo de pagamento via SumUp no checkout</div>
            <div class="text-gray-400 text-xs mt-0.5">
              Quando desativado, a opĂ§ĂŁo SumUp nĂŁo aparece para o cliente, mesmo que as credenciais estejam configuradas.
            </div>
          </div>
        </label>
      </div>

      <!-- Frete -->
      <div class="bg-gray-900 border border-gray-800 rounded-xl p-6">
        <h2 class="text-lg font-bold text-white mb-1">Frete</h2>
        <p class="text-gray-400 text-sm mb-5">
          Configure como o frete serĂˇ calculado no checkout.
          Para cĂˇlculo dinĂmico via <strong>Melhor Envio</strong>, informe o token e o CEP de origem.
          Caso contrĂˇrio, use frete fixo ou grĂˇtis.
        </p>

        <div class="space-y-4">

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-gray-300 mb-1.5">CEP de origem (da loja)</label>
              <input type="text" name="frete_cep_origem" value="<%= configs.frete_cep_origem || '' %>"
                     placeholder="00000-000" maxlength="9"
                     class="w-full bg-gray-800 border border-gray-700 text-white rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:border-blue-500 placeholder-gray-500">
              <p class="text-xs text-gray-500 mt-1">ObrigatĂłrio para cĂˇlculo via Melhor Envio.</p>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-300 mb-1.5">Frete fixo (R$)</label>
              <input type="number" name="frete_fixo" value="<%= configs.frete_fixo || '0' %>"
                     min="0" step="0.01" placeholder="0.00"
                     class="w-full bg-gray-800 border border-gray-700 text-white rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:border-blue-500">
              <p class="text-xs text-gray-500 mt-1">Usado quando Melhor Envio nĂŁo estĂˇ configurado. 0 = grĂˇtis.</p>
            </div>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-300 mb-1.5">Frete grĂˇtis acima de (R$)</label>
            <input type="number" name="frete_gratis_acima" value="<%= configs.frete_gratis_acima || '0' %>"
                   min="0" step="0.01" placeholder="0.00"
                   class="w-full bg-gray-800 border border-gray-700 text-white rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:border-blue-500">
            <p class="text-xs text-gray-500 mt-1">0 = desativado. Ex: 150 = frete grĂˇtis em pedidos acima de R$ 150.</p>
          </div>

          <div class="border-t border-gray-800 pt-4">
            <h3 class="text-sm font-bold text-gray-200 mb-3">Melhor Envio (opcional)</h3>
            <p class="text-xs text-gray-500 mb-3">
              Cria conta gratuita em <span class="text-gray-400">melhorenvio.com.br</span>, gere um token em
              <em>ConfiguraĂ§Ăµes  Tokens de acesso</em> e cole abaixo.
            </p>

            <div class="space-y-3">
              <div>
                <label class="block text-sm font-medium text-gray-300 mb-1.5">Token da API Melhor Envio</label>
                <input type="text" name="melhor_envio_token" value="<%= configs.melhor_envio_token || '' %>"
                       placeholder="eyJ0eXAiOiJKV1QiLCJhbGci..."
                       class="w-full bg-gray-800 border border-gray-700 text-white rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:border-blue-500 font-mono placeholder-gray-600">
              </div>

              <label class="flex items-center gap-3 cursor-pointer">
                <div class="mt-0.5">
                  <input type="checkbox" name="melhor_envio_sandbox" class="sr-only peer"
                         <%= configs.melhor_envio_sandbox !== 'false' ? 'checked' : '' %>>
                  <div class="w-11 h-6 bg-gray-700 peer-checked:bg-blue-600 rounded-full relative transition
                              after:content-[''] after:absolute after:top-0.5 after:left-0.5
                              after:bg-white after:rounded-full after:h-5 after:w-5 after:transition
                              peer-checked:after:translate-x-5"></div>
                </div>
                <div>
                  <div class="font-medium text-white text-sm">Usar ambiente sandbox (teste)</div>
                  <div class="text-gray-400 text-xs">Desative quando for para produĂ§ĂŁo.</div>
                </div>
              </label>
            </div>
          </div>

          <div class="border-t border-gray-800 pt-4">
            <h3 class="text-sm font-bold text-gray-200 mb-3">DimensĂµes e peso padrĂŁo do pacote</h3>
            <p class="text-xs text-gray-500 mb-3">Usados no cĂˇlculo quando o produto nĂŁo tem dimensĂµes individuais definidas.</p>

            <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
              <div>
                <label class="block text-xs font-medium text-gray-400 mb-1">Peso (g)</label>
                <input type="number" name="frete_peso_padrao" value="<%= configs.frete_peso_padrao || '300' %>"
                       min="1" placeholder="300"
                       class="w-full bg-gray-800 border border-gray-700 text-white rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-blue-500">
              </div>
              <div>
                <label class="block text-xs font-medium text-gray-400 mb-1">Altura (cm)</label>
                <input type="number" name="frete_altura" value="<%= configs.frete_altura || '4' %>"
                       min="1" placeholder="4"
                       class="w-full bg-gray-800 border border-gray-700 text-white rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-blue-500">
              </div>
              <div>
                <label class="block text-xs font-medium text-gray-400 mb-1">Largura (cm)</label>
                <input type="number" name="frete_largura" value="<%= configs.frete_largura || '12' %>"
                       min="1" placeholder="12"
                       class="w-full bg-gray-800 border border-gray-700 text-white rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-blue-500">
              </div>
              <div>
                <label class="block text-xs font-medium text-gray-400 mb-1">Comprimento (cm)</label>
                <input type="number" name="frete_comprimento" value="<%= configs.frete_comprimento || '17' %>"
                       min="1" placeholder="17"
                       class="w-full bg-gray-800 border border-gray-700 text-white rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-blue-500">
              </div>
            </div>
          </div>

        </div>
      </div>

      <!-- MĂłdulo Agenda -->
      <div class="bg-gray-900 border border-gray-800 rounded-xl p-6">
        <h2 class="text-lg font-bold text-white mb-1">MĂłdulo Agenda (Buffet)</h2>
        <p class="text-gray-400 text-sm mb-5">
          Quando ativado, o cliente precisa escolher uma data de evento no checkout.
          Configure as vagas e dias disponĂveis em <a href="/admin/agenda" class="text-blue-400 hover:underline">Agenda</a>.
        </p>

        <label class="flex items-start gap-4 cursor-pointer group">
          <div class="mt-0.5">
            <input type="checkbox" name="modulo_agenda" id="modulo_agenda"
                   class="sr-only peer" <%= configs.modulo_agenda === 'true' ? 'checked' : '' %>>
            <div class="w-11 h-6 bg-gray-700 peer-checked:bg-blue-600 rounded-full relative transition
                        after:content-[''] after:absolute after:top-0.5 after:left-0.5
                        after:bg-white after:rounded-full after:h-5 after:w-5 after:transition
                        peer-checked:after:translate-x-5"></div>
          </div>
          <div>
            <div class="font-medium text-white text-sm">Ativar mĂłdulo de agendamento</div>
            <div class="text-gray-400 text-xs mt-0.5">
              Exibe um calendĂˇrio no checkout para o cliente selecionar a data do evento.
              Bloqueia a compra se nĂŁo houver vagas disponĂveis no dia escolhido.
            </div>
          </div>
        </label>
      </div>

        <div class="flex gap-3 items-center">
        <button type="submit"
          class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-2.5 rounded-lg text-sm font-semibold transition">
          ľ Salvar ConfiguraĂ§Ăµes
        </button>
        <a href="/admin/diagnostico"
           class="text-sm text-gray-400 hover:text-white transition">
          § DiagnĂłstico de pagamentos 
        </a>
      </div>
    </form>

  </main>
</div>

<script>
  const toggleEstoque = document.getElementById('controla_estoque');
  const reservaRow = document.getElementById('reserva-row');

  function syncReserva() {
    reservaRow.style.opacity = toggleEstoque.checked ? '1' : '0.4';
    reservaRow.style.pointerEvents = toggleEstoque.checked ? 'auto' : 'none';
  }

  toggleEstoque.addEventListener('change', syncReserva);
  syncReserva();
</script>
</body>
</html>
