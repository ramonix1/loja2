<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= produto.nome %> - Lojão</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<%- include("../partials/header") %>

<div class="container">

  <a href="/" style="color:#2563eb; font-size:14px; text-decoration:none; display:inline-block; margin-bottom:24px;">← Voltar para loja</a>

  <div class="produto-detail">

    <!-- GALERIA DE IMAGENS -->
    <div>
      <img
        id="mainImage"
        src="<%= imagens.length ? imagens[0].url : 'https://placehold.co/600x450/f3f4f6/9ca3af?text=Sem+Imagem' %>"
        alt="<%= produto.nome %>"
        class="produto-detail-img"
        style="max-height:460px; object-fit:cover; width:100%;">

      <% if(imagens.length > 1){ %>
        <div class="galeria" id="galeria">
          <% imagens.forEach(function(img, i){ %>
            <img
              src="<%= img.url %>"
              alt="Imagem do produto"
              data-url="<%= img.url %>"
              class="<%= i === 0 ? 'galeria-ativa' : '' %>">
          <% }) %>
        </div>
      <% } %>
    </div>

    <!-- DETALHES -->
    <div style="display:flex; flex-direction:column; gap:20px;">

      <div>
        <h1 style="font-size:32px; font-weight:800; color:#111827; line-height:1.1;"><%= produto.nome %></h1>
        <% if(produto.subtitulo){ %>
          <p style="color:#6b7280; font-size:17px; margin-top:6px;"><%= produto.subtitulo %></p>
        <% } %>
      </div>

      <!-- AVALIAÇÕES -->
      <div style="display:flex; align-items:center; gap:8px; color:#f59e0b;">
        ★★★★★ <span style="color:#9ca3af; font-size:13px;">(124 avaliações)</span>
      </div>

      <!-- PREÇO -->
      <div style="font-size:38px; font-weight:900; color:#2563eb;">
        R$ <%= Number(produto.valor).toFixed(2).replace('.', ',') %>
      </div>

      <!-- ESTOQUE -->
      <% if (locals.configs && locals.configs.controla_estoque === 'true' && produto.estoque !== null && produto.estoque !== undefined) { %>
        <% if (produto.estoque <= 0) { %>
          <div style="display:inline-block; background:#fee2e2; color:#dc2626; font-size:13px; font-weight:700; padding:4px 12px; border-radius:20px;">
            Esgotado
          </div>
        <% } else if (produto.estoque <= 5) { %>
          <div style="display:inline-block; background:#fef3c7; color:#d97706; font-size:13px; font-weight:700; padding:4px 12px; border-radius:20px;">
            Últimas <%= produto.estoque %> unidade<%= produto.estoque > 1 ? 's' : '' %> disponível<%= produto.estoque > 1 ? 'is' : '' %>
          </div>
        <% } else { %>
          <div style="display:inline-block; background:#dcfce7; color:#16a34a; font-size:13px; font-weight:600; padding:4px 12px; border-radius:20px;">
            Em estoque (<%= produto.estoque %> un.)
          </div>
        <% } %>
      <% } %>

      <!-- DESCRIÇÃO -->
      <% if(produto.descricao){ %>
        <p class="produto-descricao"><%= produto.descricao %></p>
      <% } %>

      <!-- QUANTIDADE -->
      <div style="display:flex; align-items:center; gap:16px;">
        <span style="font-weight:600; color:#374151;">Quantidade</span>
        <div style="display:flex;align-items:center;border:1.5px solid #e5e7eb;border-radius:8px;overflow:hidden;">
          <button id="btnDec" style="width:36px;height:36px;background:#f9fafb;border:none;font-size:1.1rem;cursor:pointer;color:#374151;">−</button>
          <input type="number" id="qtdInput" value="1" min="1" max="99"
            style="width:52px;height:36px;border:none;border-left:1.5px solid #e5e7eb;border-right:1.5px solid #e5e7eb;text-align:center;font-size:0.95rem;font-weight:600;">
          <button id="btnInc" style="width:36px;height:36px;background:#f9fafb;border:none;font-size:1.1rem;cursor:pointer;color:#374151;">+</button>
        </div>
      </div>

      <!-- BOTÕES -->
      <% const esgotadoDetalhe = locals.configs && locals.configs.controla_estoque === 'true' && produto.estoque !== null && produto.estoque !== undefined && produto.estoque <= 0; %>
      <div style="display:flex; flex-wrap:wrap; gap:12px; margin-top:8px;">
        <% if (esgotadoDetalhe) { %>
          <button class="btn" disabled style="font-size:15px; padding:14px 28px; background:#374151; color:#9ca3af; cursor:not-allowed;">Produto Esgotado</button>
        <% } else { %>
          <button class="btn btn-primary" id="btnAddCart" data-id="<%= produto.id %>" style="font-size:15px; padding:14px 28px;">🛒 Adicionar ao Carrinho</button>
          <button class="btn" id="btnBuyNow" data-id="<%= produto.id %>" style="background:#16a34a; color:white; font-size:15px; padding:14px 28px;">⚡ Comprar Agora</button>
        <% } %>
      </div>

      <!-- GARANTIAS -->
      <div style="border-top:1px solid #f3f4f6; padding-top:20px; display:flex; flex-direction:column; gap:8px;">
        <div style="display:flex; align-items:center; gap:8px; font-size:14px; color:#4b5563;">
          🚚 <span>Frete calculado no checkout</span>
        </div>
        <div style="display:flex; align-items:center; gap:8px; font-size:14px; color:#4b5563;">
          🔄 <span>Troca garantida em até 7 dias</span>
        </div>
        <div style="display:flex; align-items:center; gap:8px; font-size:14px; color:#4b5563;">
          🔒 <span>Pagamento 100% seguro</span>
        </div>
      </div>

    </div>
  </div>

</div>

<%- include("../partials/footer") %>

<script>
(function() {
  // Galeria
  var galeria = document.getElementById('galeria');
  if (galeria) {
    galeria.addEventListener('click', function(e) {
      var thumb = e.target.closest('img[data-url]');
      if (!thumb) return;
      document.getElementById('mainImage').src = thumb.dataset.url;
      galeria.querySelectorAll('img').forEach(function(img) {
        img.style.borderColor = 'transparent';
        img.classList.remove('galeria-ativa');
      });
      thumb.style.borderColor = '#2563eb';
      thumb.classList.add('galeria-ativa');
    });
  }

  // Controle de quantidade
  var qtdInput = document.getElementById('qtdInput');
  document.getElementById('btnDec').addEventListener('click', function() {
    var v = parseInt(qtdInput.value) - 1;
    qtdInput.value = v < 1 ? 1 : v;
  });
  document.getElementById('btnInc').addEventListener('click', function() {
    var v = parseInt(qtdInput.value) + 1;
    qtdInput.value = v > 99 ? 99 : v;
  });

  // Adicionar ao carrinho
  function adicionarCarrinho(produtoId, redirecionar) {
    var qtd = parseInt(qtdInput.value) || 1;
    fetch('/carrinho/adicionar', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'x-csrf-token': '<%= csrfToken %>' },
      body: JSON.stringify({ produto_id: produtoId, quantidade: qtd })
    })
    .then(function(r) { return r.json(); })
    .then(function(d) {
      if (d.erro) { alert(d.erro); return; }
      atualizarBadge(d.contagem);
      if (redirecionar) {
        window.location.href = '/carrinho';
      } else {
        mostrarToast('Produto adicionado ao carrinho!');
      }
    })
    .catch(function() { alert('Erro ao adicionar. Tente novamente.'); });
  }

  function atualizarBadge(n) {
    var badge = document.getElementById('cartBadge');
    if (!badge) return;
    badge.textContent = n > 99 ? '99+' : n;
    badge.style.display = n > 0 ? 'flex' : 'none';
  }

  function mostrarToast(msg) {
    var toast = document.getElementById('toastCarrinho');
    var msgEl = document.getElementById('toastMsg');
    if (!toast) return;
    msgEl.textContent = msg;
    toast.style.display = 'flex';
    requestAnimationFrame(function() {
      toast.style.opacity = '1';
      toast.style.transform = 'translateY(0)';
    });
    setTimeout(function() {
      toast.style.opacity = '0';
      toast.style.transform = 'translateY(20px)';
      setTimeout(function() { toast.style.display = 'none'; }, 300);
    }, 3000);
  }

  var btnAdd = document.getElementById('btnAddCart');
  var btnBuy = document.getElementById('btnBuyNow');
  if (btnAdd) btnAdd.addEventListener('click', function() { adicionarCarrinho(this.dataset.id, false); });
  if (btnBuy) btnBuy.addEventListener('click', function() { adicionarCarrinho(this.dataset.id, true); });
})();
</script>

</body>
</html>
