<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Pedidos - Admin</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap');
    body { font-family: 'Inter', sans-serif; }
  </style>
</head>
<body class="bg-gray-950 min-h-screen text-white">
<div class="flex min-h-screen">

  <%- include('../partials/admin-sidebar') %>

  <main class="ml-60 flex-1 p-8">

    <div class="mb-6">
      <div class="text-xs text-gray-500 mb-1">
        <a href="/admin" class="hover:text-gray-300 transition">Dashboard</a>
        <span class="mx-2">/</span>
        <span class="text-gray-300">Pedidos</span>
      </div>
      <h1 class="text-2xl font-bold text-white">Pedidos</h1>
      <p class="text-gray-400 mt-1 text-sm">Gerencie todos os pedidos da loja</p>
    </div>

    <div class="bg-gray-900 border border-gray-800 rounded-xl p-6">
      <div class="flex justify-between items-center mb-5">
        <h2 class="text-lg font-bold text-white">Todos os Pedidos</h2>
        <span class="text-sm text-gray-400"><%= pedidos.length %> pedido<%= pedidos.length !== 1 ? 's' : '' %></span>
      </div>

      <% if (pedidos.length === 0) { %>
        <div class="text-center py-16 bg-gray-800 rounded-xl">
          <div class="text-5xl mb-3"><span style="display:flex;align-items:center;width:60px;height:60px;margin:0 auto;"><%- icon('shopping_bag', 'w-16 h-16') %></span></div>
          <p class="text-gray-400 font-medium">Nenhum pedido ainda</p>
          <p class="text-gray-600 text-sm mt-1">Os pedidos aparecerão aqui quando clientes finalizarem compras</p>
        </div>
      <% } else { %>
        <div class="overflow-x-auto">
          <table class="w-full">
            <thead>
              <tr class="border-b border-gray-800">
                <th class="pb-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">#</th>
                <th class="pb-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Cliente</th>
                <th class="pb-3 text-center text-xs font-semibold text-gray-500 uppercase tracking-wider">Itens</th>
                <th class="pb-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider">Total</th>
                <th class="pb-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Pagamento</th>
                <th class="pb-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Status</th>
                <th class="pb-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Data</th>
                <th class="pb-3"></th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-800">
              <% pedidos.forEach(function(p) {
                const statusCores = {
                  pago:                  'bg-green-900/40 text-green-400',
                  enviado:               'bg-blue-900/40 text-blue-400',
                  entregue:              'bg-teal-900/40 text-teal-400',
                  cancelado:             'bg-red-900/40 text-red-400',
                  aguardando_pagamento:  'bg-yellow-900/40 text-yellow-400',
                  em_separacao:          'bg-purple-900/40 text-purple-400',
                };
                const statusLabel = {
                  aguardando_pagamento: 'Aguardando',
                  pago:        'Pago',
                  em_separacao:'Em separação',
                  enviado:     'Enviado',
                  entregue:    'Entregue',
                  cancelado:   'Cancelado',
                };
                const cor = statusCores[p.status] || 'bg-gray-800 text-gray-400';
                const metodoLabel = { pix:'PIX', boleto:'Boleto', cartao:'Cartão', stripe:'Cartão', teste:'Teste' };
              %>
              <tr class="hover:bg-gray-800/50 transition">
                <td class="py-3 pr-4 text-gray-500 font-mono text-sm">#<%= p.id %></td>
                <td class="py-3 pr-4">
                  <div class="font-medium text-white text-sm"><%= p.usuario_nome %></div>
                  <div class="text-xs text-gray-500"><%= p.usuario_email %></div>
                </td>
                <td class="py-3 pr-4 text-center text-gray-300 text-sm"><%= p.total_itens %></td>
                <td class="py-3 pr-4 text-right font-semibold text-green-400 text-sm">
                  R$ <%= Number(p.total).toFixed(2).replace('.', ',') %>
                </td>
                <td class="py-3 pr-4 text-gray-400 text-sm">
                  <%= metodoLabel[p.metodo_pagamento] || p.metodo_pagamento || '�' %>
                </td>
                <td class="py-3 pr-4">
                  <span class="px-2.5 py-1 rounded-full text-xs font-semibold <%= cor %>">
                    <%= statusLabel[p.status] || p.status %>
                  </span>
                </td>
                <td class="py-3 pr-4 text-gray-500 text-xs whitespace-nowrap">
                  <%= new Date(p.created_at).toLocaleDateString('pt-BR') %>
                </td>
                <td class="py-3">
                  <a href="/admin/pedidos/<%= p.id %>"
                     class="bg-gray-700 hover:bg-gray-600 text-gray-300 px-3 py-1.5 rounded-lg text-xs font-medium transition">
                    Ver
                  </a>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>

  </main>
</div>
</body>
</html>
