<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Aparência - Admin</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap');
    body { font-family: 'Inter', sans-serif; }
    .preview-nav {
      background: #1f2937;
      padding: 12px 24px;
      display: flex;
      align-items: center;
      gap: 12px;
      border-radius: 8px;
    }
    .preview-btn {
      padding: 6px 18px;
      border-radius: 6px;
      font-size: 13px;
      font-weight: 600;
      color: #fff;
      display: inline-block;
    }
  </style>
</head>
<body class="bg-gray-950 min-h-screen text-white">
<div class="flex min-h-screen">

  <%- include('../partials/admin-sidebar') %>

  <main class="ml-60 flex-1 p-8">

    <div class="mb-6">
      <div class="text-xs text-gray-500 mb-1">
        <a href="/admin" class="hover:text-gray-300 transition">Dashboard</a>
        <span class="mx-2">/</span>
        <span class="text-gray-300">Aparência</span>
      </div>
      <h1 class="text-2xl font-bold text-white">🎨 Aparência</h1>
      <p class="text-gray-400 mt-1 text-sm">Personalize a identidade visual da loja</p>
    </div>

    <% if (salvo) { %>
      <div class="mb-6 bg-green-900/50 border border-green-700 text-green-300 rounded-xl px-4 py-3 text-sm">
        ✅ Aparência salva com sucesso.
      </div>
    <% } %>

    <!-- Preview ao vivo -->
    <div class="mb-6">
      <div class="text-xs text-gray-500 uppercase tracking-wide mb-2 font-medium">Pré-visualização do header</div>
      <div class="preview-nav" id="previewNav">
        <div id="previewLogo" style="font-size:20px;font-weight:700;color:#fff;display:flex;align-items:center;gap:8px;">
          <% if (cfg.loja_logo) { %>
            <img id="previewLogoImg" src="<%= cfg.loja_logo %>" style="height:32px;object-fit:contain;" alt="">
          <% } else { %>
            <span>🛒</span>
            <span id="previewNomeTexto"><%= cfg.loja_nome || 'Nome da loja' %></span>
          <% } %>
        </div>
        <div style="flex:1;display:flex;gap:16px;margin-left:24px;">
          <span style="color:#d1d5db;font-size:13px;">Home</span>
          <span style="color:#d1d5db;font-size:13px;">Pedidos</span>
        </div>
        <span class="preview-btn" id="previewBtn" style="background:<%= cfg.loja_cor_primaria || '#2563eb' %>;">Entrar</span>
      </div>
    </div>

    <form method="POST" action="/admin/aparencia?_csrf=<%= csrfToken %>" enctype="multipart/form-data">

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

        <!-- Informações básicas -->
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-6 space-y-4">
          <h2 class="text-base font-bold text-white mb-1">Informações básicas</h2>

          <div>
            <label class="block text-sm font-medium text-gray-300 mb-1.5">Nome da loja</label>
            <input type="text" name="loja_nome" value="<%= cfg.loja_nome || '' %>"
                   placeholder="Ex: Sapataria Mario"
                   class="w-full bg-gray-800 border border-gray-700 text-white rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:border-blue-500 placeholder-gray-500">
            <p class="text-xs text-gray-500 mt-1">Exibido no header, rodapé e abas do navegador.</p>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-300 mb-1.5">Slogan / descrição curta</label>
            <input type="text" name="loja_slogan" value="<%= cfg.loja_slogan || '' %>"
                   placeholder="Ex: Os melhores calçados da cidade"
                   class="w-full bg-gray-800 border border-gray-700 text-white rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:border-blue-500 placeholder-gray-500">
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-300 mb-1.5">Texto do rodapé</label>
            <input type="text" name="loja_rodape" value="<%= cfg.loja_rodape || '' %>"
                   placeholder="Ex: © 2025 Sapataria Mario. Todos os direitos reservados."
                   class="w-full bg-gray-800 border border-gray-700 text-white rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:border-blue-500 placeholder-gray-500">
          </div>
        </div>

        <!-- Cor e identidade visual -->
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-6 space-y-4">
          <h2 class="text-base font-bold text-white mb-1">Identidade visual</h2>

          <div>
            <label class="block text-sm font-medium text-gray-300 mb-1.5">Cor principal</label>
            <div class="flex items-center gap-3">
              <input type="color" name="loja_cor_primaria" id="corPrimaria"
                     value="<%= cfg.loja_cor_primaria || '#2563eb' %>"
                     class="w-12 h-12 rounded-lg border border-gray-700 cursor-pointer bg-gray-800 p-1">
              <div>
                <div class="text-sm text-white font-medium" id="corHex"><%= cfg.loja_cor_primaria || '#2563eb' %></div>
                <div class="text-xs text-gray-500">Aplicada em botões e destaques</div>
              </div>
            </div>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-300 mb-1.5">Logomarca</label>
            <% if (cfg.loja_logo) { %>
              <div class="mb-3 p-3 bg-gray-800 rounded-lg inline-block">
                <img src="<%= cfg.loja_logo %>" alt="Logo atual" style="height:48px;object-fit:contain;">
              </div>
              <div class="text-xs text-gray-500 mb-2">Logo atual — envie um novo para substituir</div>
            <% } %>
            <input type="file" name="logo" accept="image/*"
                   class="block w-full text-sm text-gray-400 file:mr-3 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-medium file:bg-gray-800 file:text-gray-300 hover:file:bg-gray-700 file:cursor-pointer">
            <p class="text-xs text-gray-500 mt-1">PNG ou SVG com fundo transparente. Recomendado: 200×60px.</p>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-300 mb-1.5">Favicon</label>
            <% if (cfg.loja_favicon) { %>
              <div class="mb-2 flex items-center gap-2">
                <img src="<%= cfg.loja_favicon %>" alt="Favicon" style="width:24px;height:24px;object-fit:contain;">
                <span class="text-xs text-gray-500">Favicon atual</span>
              </div>
            <% } %>
            <input type="file" name="favicon" accept="image/*"
                   class="block w-full text-sm text-gray-400 file:mr-3 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-medium file:bg-gray-800 file:text-gray-300 hover:file:bg-gray-700 file:cursor-pointer">
            <p class="text-xs text-gray-500 mt-1">PNG ou ICO. Recomendado: 32×32px.</p>
          </div>
        </div>

        <!-- Contato -->
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-6 space-y-4">
          <h2 class="text-base font-bold text-white mb-1">Informações de contato</h2>
          <p class="text-gray-500 text-xs -mt-2">Exibidas no rodapé da loja.</p>

          <div>
            <label class="block text-sm font-medium text-gray-300 mb-1.5">E-mail de contato</label>
            <input type="email" name="loja_email" value="<%= cfg.loja_email || '' %>"
                   placeholder="contato@minhaloja.com.br"
                   class="w-full bg-gray-800 border border-gray-700 text-white rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:border-blue-500 placeholder-gray-500">
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-300 mb-1.5">WhatsApp</label>
            <input type="text" name="loja_whatsapp" value="<%= cfg.loja_whatsapp || '' %>"
                   placeholder="(00) 90000-0000"
                   class="w-full bg-gray-800 border border-gray-700 text-white rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:border-blue-500 placeholder-gray-500">
          </div>
        </div>

      </div>

      <div class="mt-6">
        <button type="submit"
                class="bg-blue-600 hover:bg-blue-700 text-white font-semibold px-8 py-3 rounded-lg text-sm transition">
          💾 Salvar aparência
        </button>
      </div>

    </form>
  </main>
</div>

<script>
  // Preview ao vivo
  var corInput = document.getElementById('corPrimaria');
  var corHex   = document.getElementById('corHex');
  var btn      = document.getElementById('previewBtn');
  var nomeTexto = document.getElementById('previewNomeTexto');
  var nomeInput = document.querySelector('input[name="loja_nome"]');

  corInput.addEventListener('input', function() {
    btn.style.background = this.value;
    corHex.textContent = this.value;
  });

  if (nomeInput && nomeTexto) {
    nomeInput.addEventListener('input', function() {
      nomeTexto.textContent = this.value || 'Nome da loja';
    });
  }

  // Preview do logo ao selecionar arquivo
  var logoInput = document.querySelector('input[name="logo"]');
  if (logoInput) {
    logoInput.addEventListener('change', function() {
      var file = this.files[0];
      if (!file) return;
      var reader = new FileReader();
      reader.onload = function(e) {
        var previewLogo = document.getElementById('previewLogo');
        previewLogo.innerHTML = '<img src="' + e.target.result + '" style="height:32px;object-fit:contain;" alt="">';
      };
      reader.readAsDataURL(file);
    });
  }
</script>
</body>
</html>
