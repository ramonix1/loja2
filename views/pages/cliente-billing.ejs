<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Meu Faturamento - <%= loja.nome %></title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: #f5f5f5;
      color: #333;
    }

    .header {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: white;
      padding: 40px 20px;
      text-align: center;
    }

    .header h1 {
      font-size: 32px;
      margin-bottom: 10px;
    }

    .header p {
      font-size: 16px;
      opacity: 0.9;
    }

    .container {
      max-width: 1000px;
      margin: -40px auto 30px;
      padding: 0 20px;
    }

    .card {
      background: white;
      border-radius: 8px;
      padding: 30px;
      margin-bottom: 20px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }

    .plano-info {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 20px;
      margin-bottom: 20px;
    }

    .info-item {
      padding: 15px;
      background: #f9f9f9;
      border-radius: 6px;
      border-left: 4px solid #667eea;
    }

    .info-item label {
      font-size: 12px;
      color: #666;
      text-transform: uppercase;
      font-weight: 600;
      display: block;
      margin-bottom: 5px;
    }

    .info-item value {
      font-size: 20px;
      font-weight: bold;
      color: #333;
      display: block;
    }

    .badge {
      display: inline-block;
      padding: 6px 12px;
      border-radius: 20px;
      font-size: 12px;
      font-weight: 600;
    }

    .badge-paid {
      background: #d4edda;
      color: #155724;
    }

    .badge-pending {
      background: #fff3cd;
      color: #856404;
    }

    .badge-overdue {
      background: #f8d7da;
      color: #721c24;
    }

    h2 {
      margin: 30px 0 20px;
      font-size: 24px;
      color: #333;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 20px;
    }

    th {
      background: #f5f5f5;
      padding: 12px;
      text-align: left;
      font-weight: 600;
      border-bottom: 2px solid #ddd;
      font-size: 12px;
      text-transform: uppercase;
      color: #666;
    }

    td {
      padding: 12px;
      border-bottom: 1px solid #eee;
    }

    tr:hover {
      background: #f9f9f9;
    }

    .amount {
      font-weight: bold;
      color: #667eea;
      font-size: 16px;
    }

    .invoice-number {
      font-family: 'Courier New', monospace;
      font-weight: 600;
    }

    .empty {
      text-align: center;
      padding: 40px 20px;
      color: #999;
    }

    .empty p {
      margin-bottom: 10px;
    }

    .btn {
      display: inline-block;
      padding: 10px 20px;
      background: #667eea;
      color: white;
      border: none;
      border-radius: 4px;
      cursor: pointer;
      font-size: 14px;
      text-decoration: none;
      transition: background 0.3s;
    }

    .btn:hover {
      background: #5568d3;
    }

    .btn-secondary {
      background: #6c757d;
    }

    .btn-secondary:hover {
      background: #5a6268;
    }

    .summary {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
      gap: 15px;
      margin-bottom: 30px;
    }

    .summary-item {
      padding: 15px;
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: white;
      border-radius: 6px;
      text-align: center;
    }

    .summary-item .label {
      font-size: 12px;
      opacity: 0.9;
      margin-bottom: 5px;
    }

    .summary-item .value {
      font-size: 24px;
      font-weight: bold;
    }

    .actions {
      text-align: right;
      margin-top: 15px;
    }

    .actions a {
      margin-left: 10px;
    }

    footer {
      text-align: center;
      padding: 30px 20px;
      color: #999;
      font-size: 12px;
    }

    @media (max-width: 768px) {
      .header h1 {
        font-size: 24px;
      }

      .plano-info {
        grid-template-columns: 1fr;
      }

      table {
        font-size: 12px;
      }

      td, th {
        padding: 8px;
      }
    }
  </style>
</head>
<body>
  <div class="header">
    <h1><span style="display:flex;align-items:center;width:20px;height:20px;"><%- icon('money', 'w-5 h-5') %></span> Meu Faturamento</h1>
    <p>Acompanhe suas invoices e dados de billing</p>
  </div>

  <div class="container">
    <!-- INFORMAÇÕES DO PLANO -->
    <div class="card">
      <h2>Meu Plano</h2>
      <div class="plano-info">
        <div class="info-item">
          <label>Tipo de Plano</label>
          <value><%= billing.billingType || 'N/A' %></value>
        </div>
        <div class="info-item">
          <label>Mensalidade</label>
          <value>
            <% if (billing.monthlyFee) { %>
              R$ <%= parseFloat(billing.monthlyFee).toFixed(2) %>
            <% } else { %>
              Variável
            <% } %>
          </value>
        </div>
        <% if (billing.commissionPercentage) { %>
          <div class="info-item">
            <label>Comissão por Venda</label>
            <value><%= billing.commissionPercentage %>%</value>
          </div>
        <% } %>
        <div class="info-item">
          <label>Mês Atual</label>
          <value><%= billing.month || new Date().toLocaleDateString('pt-BR', { year: 'numeric', month: '2-digit' }).split('/').reverse().join('-') %></value>
        </div>
      </div>
    </div>

    <!-- RESUMO -->
    <div class="card">
      <h2>Resumo do Mês</h2>
      <div class="summary">
        <div class="summary-item">
          <div class="label">Pedidos</div>
          <div class="value"><%= billing.orders?.total || 0 %></div>
        </div>
        <div class="summary-item">
          <div class="label">Vendas</div>
          <div class="value">R$ <%= parseFloat(billing.orders?.totalSales || 0).toFixed(0) %></div>
        </div>
        <% if (billing.commissionPercentage) { %>
          <div class="summary-item">
            <div class="label">Comissão</div>
            <div class="value">R$ <%= parseFloat(billing.orders?.totalCommission || 0).toFixed(2) %></div>
          </div>
        <% } %>
      </div>
    </div>

    <!-- INVOICES -->
    <div class="card">
      <h2>Minhas Invoices</h2>

      <% if (!invoices || invoices.length === 0) { %>
        <div class="empty">
          <p>📋 Nenhuma invoice gerada ainda</p>
          <p>Invoices são geradas automaticamente no final de cada mês.</p>
        </div>
      <% } else { %>
        <table>
          <thead>
            <tr>
              <th>Número</th>
              <th>Período</th>
              <th>Total</th>
              <th>Status</th>
              <th>Emissão</th>
              <th>Ações</th>
            </tr>
          </thead>
          <tbody>
            <% invoices.forEach(inv => { %>
              <tr>
                <td class="invoice-number"><%= inv.invoice_number %></td>
                <td><%= inv.month_year %></td>
                <td class="amount">R$ <%= parseFloat(inv.total || 0).toFixed(2) %></td>
                <td>
                  <span class="badge badge-<%= inv.status %>">
                    <%=
                      inv.status === 'paid' ? '<span style="display:flex;align-items:center;width:20px;height:20px;"><%- icon('check', 'w-5 h-5') %></span> Pago' :
                      inv.status === 'pending' ? '⏳ Pendente' :
                      inv.status === 'overdue' ? '⚠️ Vencido' :
                      inv.status === 'sent' ? '📧 Enviado' :
                      inv.status.toUpperCase()
                    %>
                  </span>
                </td>
                <td><%= new Date(inv.issue_date).toLocaleDateString('pt-BR') %></td>
                <td class="actions">
                  <a href="/api/billing/invoices/<%= inv.id %>" class="btn btn-secondary" target="_blank">Ver</a>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      <% } %>
    </div>

    <!-- DÚVIDAS -->
    <div class="card">
      <h2>❓ Dúvidas?</h2>
      <p>Entre em contato com nosso suporte:</p>
      <ul style="margin-left: 20px; margin-top: 10px; line-height: 1.8;">
        <li><strong>Email:</strong> suporte@<%= (loja.email || 'empresa.com').split('@')[1] %></li>
        <% if (loja.whatsapp) { %>
          <li><strong>WhatsApp:</strong> <%= loja.whatsapp %></li>
        <% } %>
      </ul>
    </div>
  </div>

  <footer>
    <p>&copy; 2026 <%= loja.nome %>. Todos os direitos reservados.</p>
  </footer>
</body>
</html>
