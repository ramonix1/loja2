<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= banner ? 'Editar Banner' : 'Novo Banner' %> - Admin LojĂŁo</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap');
    body { font-family: 'Inter', sans-serif; }
    .badge-soon { font-size: 10px; font-weight: 700; letter-spacing: 0.5px; }
    #preview-img { transition: opacity 0.2s; }
  </style>
</head>

<body class="bg-gray-950 min-h-screen text-white">
  <div class="flex min-h-screen">

  <%- include('../partials/admin-sidebar') %>

    <!-- ConteĂşdo principal -->
    <main class="ml-60 flex-1 p-8">

      <div class="mb-8 flex items-center gap-4">
        <a href="/admin/banners" class="text-gray-400 hover:text-white transition text-sm"> Banners</a>
        <h1 class="text-2xl font-bold text-white"><%= banner ? 'Editar Banner' : 'Novo Banner' %></h1>
      </div>

      <div class="max-w-2xl">
        <form
          action="<%= banner ? '/admin/banners/atualizar/' + banner.id : '/admin/banners/salvar' %>?_csrf=<%= locals.csrfToken %>"
          method="POST"
          enctype="multipart/form-data"
          class="space-y-6"
        >

          <!-- Imagem -->
          <div class="bg-gray-900 border border-gray-800 rounded-xl p-6">
            <h2 class="text-sm font-semibold text-gray-300 mb-4 uppercase tracking-wider">Imagem do Banner</h2>

            <% if (banner && banner.imagem) { %>
              <div class="mb-4 rounded-lg overflow-hidden bg-gray-800" style="max-height:200px;">
                <img id="preview-img" src="<%= banner.imagem %>" alt="Preview" class="w-full object-cover" style="max-height:200px; object-position:center;">
              </div>
              <p class="text-xs text-gray-500 mb-3">Selecione uma nova imagem para substituir a atual.</p>
            <% } else { %>
              <div id="preview-container" class="mb-4 hidden rounded-lg overflow-hidden bg-gray-800" style="max-height:200px;">
                <img id="preview-img" src="" alt="Preview" class="w-full object-cover" style="max-height:200px; object-position:center;">
              </div>
            <% } %>

            <label class="block">
              <div class="border-2 border-dashed border-gray-700 rounded-lg p-6 text-center cursor-pointer hover:border-blue-500 transition">
                <div class="text-3xl mb-2"></div>
                <p class="text-sm text-gray-400">Clique para selecionar uma imagem</p>
                <p class="text-xs text-gray-600 mt-1">JPG, PNG, WEBP ou GIF  atĂŠ 5MB</p>
              </div>
              <input type="file" name="imagem" accept="image/*" class="hidden" id="input-imagem"
                <%= banner ? '' : 'required' %>
                onchange="previewImagem(this)">
            </label>
          </div>

          <!-- Textos -->
          <div class="bg-gray-900 border border-gray-800 rounded-xl p-6 space-y-4">
            <h2 class="text-sm font-semibold text-gray-300 mb-2 uppercase tracking-wider">ConteĂşdo</h2>

            <div>
              <label class="block text-sm font-medium text-gray-300 mb-1">TĂtulo <span class="text-red-400">*</span></label>
              <input type="text" name="titulo" required
                value="<%= banner ? banner.titulo : '' %>"
                placeholder="Ex: Super Oferta de VerĂŁo"
                class="w-full bg-gray-800 border border-gray-700 rounded-lg px-4 py-2.5 text-white placeholder-gray-500 focus:outline-none focus:border-blue-500 text-sm">
            </div>

            <div>
              <label class="block text-sm font-medium text-gray-300 mb-1">SubtĂtulo / DescriĂ§ĂŁo</label>
              <input type="text" name="subtitulo"
                value="<%= banner ? (banner.subtitulo || '') : '' %>"
                placeholder="Ex: Aproveite descontos imperdĂveis em nossos produtos"
                class="w-full bg-gray-800 border border-gray-700 rounded-lg px-4 py-2.5 text-white placeholder-gray-500 focus:outline-none focus:border-blue-500 text-sm">
            </div>
          </div>

          <!-- CTA -->
          <div class="bg-gray-900 border border-gray-800 rounded-xl p-6 space-y-4">
            <h2 class="text-sm font-semibold text-gray-300 mb-2 uppercase tracking-wider">BotĂŁo CTA</h2>

            <div>
              <label class="block text-sm font-medium text-gray-300 mb-1">Texto do botĂŁo</label>
              <input type="text" name="cta_texto"
                value="<%= banner ? (banner.cta_texto || 'Ver oferta') : 'Ver oferta' %>"
                placeholder="Ex: Ver oferta"
                class="w-full bg-gray-800 border border-gray-700 rounded-lg px-4 py-2.5 text-white placeholder-gray-500 focus:outline-none focus:border-blue-500 text-sm">
            </div>

            <!-- Vincular produto OU URL manual -->
            <div>
              <label class="block text-sm font-medium text-gray-300 mb-1">Vincular a um produto</label>
              <select name="produto_id" id="select-produto" onchange="sincronizarCta()"
                class="w-full bg-gray-800 border border-gray-700 rounded-lg px-4 py-2.5 text-white focus:outline-none focus:border-blue-500 text-sm">
                <option value=""> Nenhum produto (usar URL manual) </option>
                <% produtos.forEach(function(p) { %>
                  <option value="<%= p.id %>"
                    <%= banner && banner.produto_id == p.id ? 'selected' : '' %>>
                    <%= p.nome %>
                  </option>
                <% }) %>
              </select>
              <p class="text-xs text-gray-500 mt-1">Ao vincular um produto, o botĂŁo redirecionarĂĄ para o card dele.</p>
            </div>

            <div id="campo-url" class="<%= banner && banner.produto_id ? 'hidden' : '' %>">
              <label class="block text-sm font-medium text-gray-300 mb-1">URL manual do CTA</label>
              <input type="text" name="cta_url" id="input-cta-url"
                value="<%= banner ? (banner.cta_url || '') : '' %>"
                placeholder="Ex: /produto/5 ou https://..."
                class="w-full bg-gray-800 border border-gray-700 rounded-lg px-4 py-2.5 text-white placeholder-gray-500 focus:outline-none focus:border-blue-500 text-sm">
              <p class="text-xs text-gray-500 mt-1">Deixe em branco para o botĂŁo rolar atĂŠ a seĂ§ĂŁo de produtos.</p>
            </div>
          </div>

          <!-- ConfiguraĂ§Ăľes -->
          <div class="bg-gray-900 border border-gray-800 rounded-xl p-6 space-y-4">
            <h2 class="text-sm font-semibold text-gray-300 mb-2 uppercase tracking-wider">ConfiguraĂ§Ăľes</h2>

            <div class="flex items-center gap-3">
              <input type="checkbox" name="ativo" id="ativo" value="on"
                <%= (!banner || banner.ativo) ? 'checked' : '' %>
                class="w-4 h-4 rounded accent-blue-500 cursor-pointer">
              <label for="ativo" class="text-sm text-gray-300 cursor-pointer">Banner ativo (visĂvel na loja)</label>
            </div>

            <div>
              <label class="block text-sm font-medium text-gray-300 mb-1">Ordem de exibiĂ§ĂŁo</label>
              <input type="number" name="ordem" min="0"
                value="<%= banner ? banner.ordem : 0 %>"
                class="w-32 bg-gray-800 border border-gray-700 rounded-lg px-4 py-2.5 text-white focus:outline-none focus:border-blue-500 text-sm">
              <p class="text-xs text-gray-500 mt-1">Menor nĂşmero = exibido primeiro no carrossel.</p>
            </div>
          </div>

          <!-- AĂ§Ăľes -->
          <div class="flex gap-3">
            <button type="submit"
              class="bg-blue-600 hover:bg-blue-700 text-white font-semibold px-6 py-2.5 rounded-lg text-sm transition">
              <%= banner ? 'Salvar alteraĂ§Ăľes' : 'Criar banner' %>
            </button>
            <a href="/admin/banners"
              class="bg-gray-800 hover:bg-gray-700 text-white font-semibold px-6 py-2.5 rounded-lg text-sm transition">
              Cancelar
            </a>
          </div>

        </form>
      </div>
    </main>
  </div>

  <script>
    function previewImagem(input) {
      const file = input.files[0];
      if (!file) return;
      const reader = new FileReader();
      reader.onload = (e) => {
        const img = document.getElementById('preview-img');
        const container = document.getElementById('preview-container');
        img.src = e.target.result;
        if (container) container.classList.remove('hidden');
      };
      reader.readAsDataURL(file);
    }

    function sincronizarCta() {
      const sel = document.getElementById('select-produto');
      const campoUrl = document.getElementById('campo-url');
      const inputUrl = document.getElementById('input-cta-url');
      if (sel.value) {
        campoUrl.classList.add('hidden');
        inputUrl.value = '';
      } else {
        campoUrl.classList.remove('hidden');
      }
    }
  </script>
</body>
</html>
