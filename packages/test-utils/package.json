    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@lojao/eslint-config": "workspace:*",
    "@types/node": "^22.9.0",
    "typescript": "^5.6.3"
  }
