    },
    "./test-ids/auth": {
      "types": "./src/test-ids/auth.ts",
      "default": "./src/test-ids/auth.ts"
    },
    "./test-ids/marketing": {
      "types": "./src/test-ids/marketing.ts",
      "default": "./src/test-ids/marketing.ts"
    },
    "./test-ids/signup": {
      "types": "./src/test-ids/signup.ts",
      "default": "./src/test-ids/signup.ts"
    },
    "./fixtures/auth": {
      "types": "./src/fixtures/auth.ts",
      "default": "./src/fixtures/auth.ts"
    },
    "./fixtures/seed-pedido": {
      "types": "./src/fixtures/seed-pedido.ts",
      "default": "./src/fixtures/seed-pedido.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@lojao/eslint-config": "workspace:*",
    "@types/node": "^22.9.0",
    "typescript": "^5.6.3"
