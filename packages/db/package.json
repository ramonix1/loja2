{
  "name": "@lojao/db",
  "version": "0.0.0",
  "private": true,
  "description": "Drizzle ORM — schema PostgreSQL Lojão (master + tenant)",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./schema/tenant": {
      "types": "./src/schema/tenant/index.ts",
      "default": "./src/schema/tenant/index.ts"
    },
    "./schema/master": {
      "types": "./src/schema/master/index.ts",
      "default": "./src/schema/master/index.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/migrate.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "drizzle-orm": "^0.44.2",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@lojao/eslint-config": "workspace:*",
    "@types/node": "^22.9.0",
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.31.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^3.2.4"
  }
}
