# Banco de dados
# Modo híbrido (apps no host): localhost. Modo Docker completo: compose define DATABASE_URL internamente.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lojao
NODE_ENV=development
# Postgres dev (Docker ou híbrido) não usa SSL — obrigatório fora do Docker e recomendado no híbrido.
PGSSL=disable

# Monorepo (portas dev)
API_PORT=3001
ADMIN_PORT=5173
STOREFRONT_PORT=3000

# URL da API para SSR do storefront (servidor Next)
# Híbrido: localhost. Docker completo (storefront no container): http://api:3001
API_URL=http://localhost:3001
APP_URL=http://localhost:3000
ADMIN_URL=http://localhost:5173
STOREFRONT_URL=http://localhost:3000

# URLs públicas (browser dev — sempre localhost, não hostname Docker)
# Dev: admin/storefront usam proxy same-origin (/api → :3001) — evita CORS no browser.
# Prod: browser chama API direto; CORS controlado por APP_URL/ADMIN_URL/CORS_ORIGINS na API.
VITE_API_URL=http://localhost:3001
VITE_STOREFRONT_URL=http://localhost:3000
VITE_CDN_URL=
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_ADMIN_URL=http://localhost:5173
# CDN de imagens (storefront) — produção: https://cdn.atalabs.com.br
NEXT_PUBLIC_CDN_URL=
# Sessão: cookie `lojao.sid`; prod cross-origin exige COOKIE_SAME_SITE=none na API

# CORS (API) — opcional; origens extras além de APP_URL, ADMIN_URL, STOREFRONT_URL
# CORS_ORIGINS=https://preview.example.com,https://staging.example.com

# Tenant dev (API bootstrap opcional + fallback login dev; admin usa slug no login)
# Produção: admin resolve tenant via sessão — não definir VITE_TENANT_SLUG no build admin
VITE_TENANT_SLUG=loja
TENANT_SLUG=loja
# Storefront: slug default para redirects legado e link demo (dev: loja, prod: demo)
NEXT_PUBLIC_DEFAULT_STORE_SLUG=loja

# Uploads (imagens) — dev híbrido: disco em data/uploads/images (não vai ao R2)
UPLOAD_DIR=./data/uploads/images
# Storage: local (disco, default dev) ou r2 (Cloudflare — produção ou teste explícito)
STORAGE_PROVIDER=local
# R2 — obrigatório quando STORAGE_PROVIDER=r2
R2_ACCOUNT_ID=66836ec0393e82929ae0c3090b013f9d
R2_BUCKET=ata-commerce
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# Entrega: proxy (API serve /images/*, bucket privado) ou cdn (domínio customizado no R2)
R2_DELIVERY=proxy
# Só quando R2_DELIVERY=cdn — domínio customizado (NÃO use *.r2.dev em produção)
R2_PUBLIC_URL=

# Otimização no upload (API) — resize + WebP antes de gravar no R2/disco
IMAGE_OPTIMIZE=1
IMAGE_MAX_DIMENSION=1920
IMAGE_WEBP_QUALITY=82

# Auto-provision dev (API bootstrap no boot)
ADMIN_EMAIL=admin@loja.com
ADMIN_SENHA=admin123
ADMIN_NOME=Administrador

# E2E (Playwright)
E2E_BASE_URL=http://localhost:5173
E2E_STORE_URL=http://localhost:3000
E2E_API_URL=http://localhost:3001
E2E_STORE_SLUG=loja
E2E_ADMIN_EMAIL=admin@loja.com
E2E_ADMIN_PASSWORD=admin123
# Platform Hub (Fase F) — devem casar com MASTER_EMAIL/MASTER_PASSWORD da API
E2E_MASTER_EMAIL=master@suaplataforma.com
E2E_MASTER_PASSWORD=troque-por-senha-forte-aqui

# Sessão (gere uma string aleatória longa e segura)
SESSION_SECRET=troque-por-uma-string-aleatoria-muito-longa-e-segura
# Render/prod cross-origin admin: none (default implícito em produção). Dev/Docker: omita ou lax.
# COOKIE_SAME_SITE=none

# URLs públicas produção — Ata Labs (Render + Cloudflare)
# APP_URL=https://atalabs.com.br
# ADMIN_URL=https://app.atalabs.com.br
# NEXT_PUBLIC_CDN_URL=https://cdn.atalabs.com.br
# R2_DELIVERY=cdn
# R2_PUBLIC_URL=https://cdn.atalabs.com.br

# Pagamentos
STRIPE_SECRET_KEY=
STRIPE_PUBLIC_KEY=
STRIPE_WEBHOOK_SECRET=
SUMUP_API_KEY=
SUMUP_MERCHANT_CODE=

# Email (opcional — log-only na API quando ausente)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM="Ata Commerce <noreply@atalabs.com.br>"

# Twilio (SMS - opcional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# Painel Master (plataforma whitelabel)
MASTER_EMAIL=master@suaplataforma.com
MASTER_PASSWORD=troque-por-senha-forte-aqui

# Asaas (gateway nativo da plataforma)
ASAAS_API_KEY=
ASAAS_ENV=sandbox

# Configurações de bloqueio
MAX_TENTATIVAS_LOGIN=5
BLOQUEIO_MINUTOS=15
TOKEN_EXPIRACAO_MINUTOS=30
