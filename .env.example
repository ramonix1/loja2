# Banco de dados
DATABASE_URL=postgresql://postgres:123456@localhost:5432/lojao
NODE_ENV=development
# Em dev/Docker, o Postgres não usa SSL. Defina PGSSL=disable se DATABASE_URL
# apontar para um banco sem SSL (o docker-compose já faz isso).
# PGSSL=disable

# Monorepo (portas dev)
API_PORT=3001
ADMIN_PORT=5173
STOREFRONT_PORT=3002

# URLs internas (rede Docker)
API_URL=http://api:3001
LEGACY_URL=http://legacy:3000

# URLs públicas (browser dev — sempre localhost, não hostname Docker)
VITE_API_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001

# Admin React (Vite) — tenant dev resolvido via header X-Tenant-Slug
VITE_TENANT_SLUG=loja

# E2E (Playwright) — defaults já apontam para o dev local
E2E_BASE_URL=http://localhost:5173
E2E_API_URL=http://localhost:3001
E2E_TENANT_SLUG=loja
E2E_ADMIN_EMAIL=admin@loja.com
E2E_ADMIN_PASSWORD=admin123

# Tenant único (para deploy no Render / produção single-tenant)
# Defina estas variáveis no painel do Render para provisionar o tenant automaticamente
# TENANT_SLUG=vitrine
# ADMIN_EMAIL=admin@sualoja.com
# ADMIN_SENHA=senha-segura-aqui
# ADMIN_NOME=Administrador

# Sessão (gere uma string aleatória longa e segura)
# IMPORTANTE: api e legacy DEVEM usar o MESMO SESSION_SECRET para compartilhar a
# sessão (cookie lojao.sid). O docker-compose.yml já injeta o mesmo valor nos dois.
SESSION_SECRET=troque-por-uma-string-aleatoria-muito-longa-e-segura

# CSRF
CSRF_SECRET=outra-string-aleatoria-muito-longa-para-csrf

# Email (Nodemailer - use Gmail com App Password ou SMTP próprio)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=seu-email@gmail.com
EMAIL_PASS=sua-app-password
EMAIL_FROM="Lojão <noreply@seudominio.com>"

# Twilio (SMS - opcional)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM=+5511999999999

# Painel Master (plataforma whitelabel)
MASTER_EMAIL=master@suaplataforma.com
MASTER_PASSWORD=troque-por-senha-forte-aqui

# Asaas (gateway nativo da plataforma)
ASAAS_API_KEY=
ASAAS_ENV=sandbox

# Configurações de bloqueio
MAX_TENTATIVAS_LOGIN=5
BLOQUEIO_MINUTOS=15
TOKEN_EXPIRACAO_MINUTOS=30
