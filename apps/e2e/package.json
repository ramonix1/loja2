{
  "name": "e2e",
  "version": "0.0.0",
  "private": true,
  "description": "Suíte E2E Playwright (QA) — specs de UI nova a partir da Fase 2",
  "type": "module",
  "scripts": {
    "install:browsers": "node ./scripts/run-playwright.mjs install chromium",
    "test": "node ./scripts/run-playwright.mjs test --pass-with-no-tests",
    "test:ui": "node ./scripts/run-playwright.mjs test --ui",
    "test:smoke": "node ./scripts/run-playwright.mjs test --grep @smoke --pass-with-no-tests",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@lojao/eslint-config": "workspace:*",
    "@lojao/tenant-host": "workspace:*",
    "@lojao/test-utils": "workspace:*",
    "@playwright/test": "^1.49.0",
    "playwright": "^1.49.0",
    "@types/node": "^22.9.0",
    "typescript": "^5.6.3"
  }
}
