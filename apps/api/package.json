{
  "name": "api",
  "version": "0.0.0",
  "private": true,
  "description": "Lojão API — Fastify + TypeScript",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "tsx src/index.ts",
    "start:dist": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "seed:dev": "node ./scripts/run-seed.mjs",
    "seed:fresh": "node ./scripts/run-seed.mjs --fresh"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^10.0.1",
    "@fastify/multipart": "^9.0.3",
    "@fastify/static": "^8.0.4",
    "@lojao/db": "workspace:*",
    "argon2": "^0.44.0",
    "fastify": "^5.1.0",
    "fastify-plugin": "^5.0.1",
    "pg": "^8.13.1",
    "socket.io": "^4.8.3",
    "stripe": "^22.2.0",
    "tsx": "^4.19.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@lojao/eslint-config": "workspace:*",
    "@lojao/types": "workspace:*",
    "@types/node": "^22.9.0",
    "@types/pg": "^8.11.10",
    "typescript": "^5.6.3",
    "vitest": "^3.2.4"
  }
}
