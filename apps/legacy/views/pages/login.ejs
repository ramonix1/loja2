<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login  Lojão</title>
  <link rel="stylesheet" href="/css/style.css">
  <style>
    body { background: #f3f4f6; display: flex; align-items: center; justify-content: center; min-height: 100vh; margin: 0; }
    .auth-card {
      background: #fff;
      border-radius: 16px;
      box-shadow: 0 8px 32px rgba(0,0,0,0.10);
      padding: 48px 40px 40px;
      width: 100%;
      max-width: 420px;
    }
    .auth-logo { text-align: center; margin-bottom: 32px; }
    .auth-logo a { font-size: 1.8rem; font-weight: 800; color: #3b82f6; text-decoration: none; }
    .auth-titulo { font-size: 1.4rem; font-weight: 700; color: #111; margin-bottom: 6px; text-align: center; }
    .auth-sub { color: #6b7280; font-size: 0.9rem; text-align: center; margin-bottom: 28px; }
    .form-grupo { margin-bottom: 18px; }
    .form-grupo label { display: block; font-size: 0.85rem; font-weight: 600; color: #374151; margin-bottom: 6px; }
    .form-grupo input {
      width: 100%; padding: 11px 14px; border: 1.5px solid #d1d5db; border-radius: 8px;
      font-size: 0.95rem; outline: none; transition: border 0.2s; box-sizing: border-box;
    }
    .form-grupo input:focus { border-color: #3b82f6; }
    .btn-login {
      width: 100%; padding: 13px; background: #3b82f6; color: #fff; font-weight: 700;
      font-size: 1rem; border: none; border-radius: 8px; cursor: pointer; transition: background 0.2s;
      margin-top: 6px;
    }
    .btn-login:hover { background: #2563eb; }
    .alerta-erro {
      background: #fef2f2; border: 1px solid #fca5a5; color: #b91c1c;
      border-radius: 8px; padding: 12px 16px; margin-bottom: 20px; font-size: 0.9rem;
    }
    .alerta-info {
      background: #eff6ff; border: 1px solid #93c5fd; color: #1d4ed8;
      border-radius: 8px; padding: 12px 16px; margin-bottom: 20px; font-size: 0.9rem;
    }
    .links-auth { text-align: center; margin-top: 22px; font-size: 0.88rem; color: #6b7280; }
    .links-auth a { color: #3b82f6; text-decoration: none; font-weight: 600; }
    .links-auth a:hover { text-decoration: underline; }
    .senha-wrapper { position: relative; }
    .senha-wrapper input { padding-right: 44px; }
    .toggle-senha {
      position: absolute; right: 12px; top: 50%; transform: translateY(-50%);
      background: none; border: none; cursor: pointer; color: #9ca3af; font-size: 1rem;
    }
  </style>
</head>
<body>
  <div class="auth-card">
    <div class="auth-logo"><a href="/"><span style="display:flex;align-items:center;width:20px;height:20px;"><%- icon('shopping_cart', 'w-5 h-5') %></span> Lojão</a></div>
    <h1 class="auth-titulo">Entrar na sua conta</h1>
    <p class="auth-sub">Bem-vindo de volta! Faça login para continuar.</p>

    <% if (erro) { %>
      <div class="alerta-erro"> <%= erro %></div>
    <% } %>
    <% if (info) { %>
      <div class="alerta-info"><span style="display:flex;align-items:center;width:20px;height:20px;"><%- icon('check', 'w-5 h-5') %></span> <%= info %></div>
    <% } %>

    <form method="POST" action="/login">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">

      <div class="form-grupo">
        <label for="email">Email</label>
        <input type="email" id="email" name="email" placeholder="seu@email.com" required autofocus autocomplete="email">
      </div>

      <div class="form-grupo">
        <label for="senha">Senha</label>
        <div class="senha-wrapper">
          <input type="password" id="senha" name="senha" placeholder="Sua senha" required autocomplete="current-password">
          <button type="button" class="toggle-senha" onclick="toggleSenha('senha', this)" title="Mostrar/ocultar senha"></button>
        </div>
      </div>

      <button type="submit" class="btn-login">Entrar</button>
    </form>

    <div class="links-auth">
      <a href="/recuperar-senha">Esqueci minha senha</a>
      <span style="margin: 0 10px; color: #d1d5db;">|</span>
      <a href="/cadastro">Criar conta</a>
    </div>
  </div>

  <script>
    function toggleSenha(id, btn) {
      const input = document.getElementById(id);
      input.type = input.type === 'password' ? 'text' : 'password';
      btn.textContent = input.type === 'password' ? '' : '';
    }
  </script>
</body>
</html>
