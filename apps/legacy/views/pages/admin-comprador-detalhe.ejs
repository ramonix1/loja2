<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= comprador.nome %> - Ficha do Comprador</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap');
    body { font-family: 'Inter', sans-serif; }
  </style>
</head>
<body class="bg-gray-950 min-h-screen text-white">
<div class="flex min-h-screen">

  <%- include('../partials/admin-sidebar') %>

  <main class="ml-60 flex-1 p-8">

    <!-- Header -->
    <div class="mb-6">
      <div class="text-xs text-gray-500 mb-1">
        <a href="/admin" class="hover:text-gray-300 transition">Dashboard</a>
        <span class="mx-2">/</span>
        <a href="/admin/compradores" class="hover:text-gray-300 transition">Compradores</a>
        <span class="mx-2">/</span>
        <span class="text-gray-300"><%= comprador.nome %></span>
      </div>
      <div class="flex items-center justify-between">
        <div class="flex items-center gap-4">
          <div class="w-14 h-14 rounded-full bg-blue-600 flex items-center justify-center text-2xl font-bold">
            <%= comprador.nome.charAt(0).toUpperCase() %>
          </div>
          <div>
            <h1 class="text-2xl font-bold text-white"><%= comprador.nome %></h1>
            <div class="flex items-center gap-3 mt-1">
              <span class="text-gray-400 text-sm"><%= comprador.email %></span>
              <span class="text-xs px-2 py-0.5 rounded-full font-medium
                <%= comprador.ativo ? 'bg-green-900/50 text-green-400' : 'bg-red-900/50 text-red-400' %>">
                <%= comprador.ativo ? 'Ativo' : 'Inativo' %>
              </span>
            </div>
          </div>
        </div>
        <a href="/admin/compradores" class="text-sm text-gray-400 hover:text-white transition">
           Voltar
        </a>
      </div>
    </div>

    <!-- Cards de resumo -->
    <div class="grid grid-cols-4 gap-4 mb-6">
      <div class="bg-gray-900 border border-gray-800 rounded-xl p-4">
        <div class="text-xs text-gray-500 mb-1">Total de pedidos</div>
        <div class="text-2xl font-bold text-white"><%= resumo.total_pedidos %></div>
      </div>
      <div class="bg-gray-900 border border-gray-800 rounded-xl p-4">
        <div class="text-xs text-gray-500 mb-1">Total gasto</div>
        <div class="text-2xl font-bold text-green-400">
          R$ <%= Number(resumo.total_gasto).toFixed(2).replace('.', ',') %>
        </div>
      </div>
      <div class="bg-gray-900 border border-gray-800 rounded-xl p-4">
        <div class="text-xs text-gray-500 mb-1">Agendamentos</div>
        <div class="text-2xl font-bold text-blue-400"><%= agendamentos.length %></div>
      </div>
      <div class="bg-gray-900 border border-gray-800 rounded-xl p-4">
        <div class="text-xs text-gray-500 mb-1">Cliente desde</div>
        <div class="text-lg font-bold text-white">
          <%= new Date(comprador.created_at).toLocaleDateString('pt-BR') %>
        </div>
      </div>
    </div>

    <div class="grid grid-cols-3 gap-6">

      <!-- Coluna esquerda: Dados pessoais -->
      <div class="space-y-4">

        <!-- Dados de contato -->
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
          <h2 class="font-semibold text-white mb-4 flex items-center gap-2">
            <span></span> Dados Pessoais
          </h2>
          <div class="space-y-3 text-sm">
            <div>
              <div class="text-xs text-gray-500 mb-0.5">Nome completo</div>
              <div class="text-gray-200"><%= comprador.nome %></div>
            </div>
            <div>
              <div class="text-xs text-gray-500 mb-0.5">E-mail</div>
              <div class="text-gray-200"><%= comprador.email %></div>
            </div>
            <div>
              <div class="text-xs text-gray-500 mb-0.5">Telefone</div>
              <div class="text-gray-200"><%= comprador.telefone || '' %></div>
            </div>
            <div>
              <div class="text-xs text-gray-500 mb-0.5">CPF</div>
              <div class="text-gray-200"><%= comprador.cpf || '' %></div>
            </div>
          </div>
        </div>

        <!-- Endereço -->
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
          <h2 class="font-semibold text-white mb-4 flex items-center gap-2">
            <span></span> Endereço
          </h2>
          <% const temEndereco = comprador.logradouro || comprador.cidade; %>
          <% if (temEndereco) { %>
            <div class="space-y-2 text-sm">
              <% if (comprador.logradouro) { %>
                <div class="text-gray-200">
                  <%= comprador.logradouro %>, <%= comprador.numero %>
                  <% if (comprador.complemento) { %>  <%= comprador.complemento %><% } %>
                </div>
              <% } %>
              <% if (comprador.bairro) { %>
                <div class="text-gray-400"><%= comprador.bairro %></div>
              <% } %>
              <% if (comprador.cidade) { %>
                <div class="text-gray-200"><%= comprador.cidade %> / <%= comprador.estado %></div>
              <% } %>
              <% if (comprador.cep) { %>
                <div class="text-gray-500">CEP: <%= comprador.cep %></div>
              <% } %>
            </div>
          <% } else { %>
            <p class="text-gray-600 text-sm">Endereço não informado</p>
          <% } %>
        </div>

        <!-- Info da conta -->
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
          <h2 class="font-semibold text-white mb-4 flex items-center gap-2">
            <span></span> Conta
          </h2>
          <div class="space-y-3 text-sm">
            <div>
              <div class="text-xs text-gray-500 mb-0.5">Cadastro</div>
              <div class="text-gray-200">
                <%= new Date(comprador.created_at).toLocaleDateString('pt-BR') %>
                s <%= new Date(comprador.created_at).toLocaleTimeString('pt-BR', {hour:'2-digit',minute:'2-digit'}) %>
              </div>
            </div>
            <% if (comprador.ultimo_acesso) { %>
              <div>
                <div class="text-xs text-gray-500 mb-0.5">ltimo acesso</div>
                <div class="text-gray-200">
                  <%= new Date(comprador.ultimo_acesso).toLocaleDateString('pt-BR') %>
                </div>
              </div>
            <% } %>
            <div>
              <div class="text-xs text-gray-500 mb-0.5">Status</div>
              <span class="text-xs px-2 py-1 rounded-full font-medium
                <%= comprador.ativo ? 'bg-green-900/50 text-green-400' : 'bg-red-900/50 text-red-400' %>">
                <%= comprador.ativo ? 'Ativo' : 'Inativo' %>
              </span>
            </div>
          </div>
        </div>

      </div>

      <!-- Coluna direita: Pedidos e agendamentos -->
      <div class="col-span-2 space-y-6">

        <!-- Agendamentos -->
        <% if (agendamentos.length > 0) { %>
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
          <h2 class="font-semibold text-white mb-4 flex items-center gap-2">
            <span></span> Agendamentos
            <span class="text-xs bg-blue-900/50 text-blue-400 px-2 py-0.5 rounded-full font-medium">
              <%= agendamentos.length %>
            </span>
          </h2>
          <div class="space-y-3">
            <% agendamentos.forEach(a => { %>
              <div class="flex items-center justify-between bg-gray-800 rounded-lg px-4 py-3">
                <div>
                  <div class="font-medium text-sm text-white">
                    <%= new Date(a.data_evento + 'T12:00:00').toLocaleDateString('pt-BR', {weekday:'long', day:'2-digit', month:'long', year:'numeric'}) %>
                  </div>
                  <div class="text-xs text-gray-500 mt-0.5">
                    Pedido #<%= a.pedido_id %> Â R$ <%= Number(a.pedido_total).toFixed(2).replace('.', ',') %>
                  </div>
                </div>
                <div class="flex items-center gap-2">
                  <span class="text-xs px-2 py-1 rounded-full
                    <%= a.status === 'confirmado' ? 'bg-green-900/50 text-green-400' : 'bg-red-900/50 text-red-400' %>">
                    <%= a.status === 'confirmado' ? 'Confirmado' : 'Cancelado' %>
                  </span>
                  <a href="/admin/pedidos/<%= a.pedido_id %>"
                    class="text-xs text-blue-400 hover:text-blue-300 transition">Ver pedido </a>
                </div>
              </div>
            <% }) %>
          </div>
        </div>
        <% } %>

        <!-- Histórico de pedidos -->
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
          <h2 class="font-semibold text-white mb-4 flex items-center gap-2">
            <span></span> Histórico de Pedidos
            <span class="text-xs bg-gray-700 text-gray-300 px-2 py-0.5 rounded-full font-medium">
              <%= pedidos.length %>
            </span>
          </h2>

          <% if (pedidos.length === 0) { %>
            <p class="text-gray-600 text-sm text-center py-6">Nenhum pedido realizado ainda.</p>
          <% } else { %>
            <div class="space-y-4">
              <% const STATUS_COR = {
                aguardando_pagamento: 'bg-yellow-900/50 text-yellow-400',
                pago: 'bg-blue-900/50 text-blue-400',
                em_separacao: 'bg-purple-900/50 text-purple-400',
                enviado: 'bg-indigo-900/50 text-indigo-400',
                entregue: 'bg-green-900/50 text-green-400',
                cancelado: 'bg-red-900/50 text-red-400',
              };
              const STATUS_LABEL = {
                aguardando_pagamento: 'Aguardando pagamento',
                pago: 'Pago',
                em_separacao: 'Em separação',
                enviado: 'Enviado',
                entregue: 'Entregue',
                cancelado: 'Cancelado',
              }; %>
              <% pedidos.forEach(p => { %>
                <div class="border border-gray-800 rounded-xl overflow-hidden">
                  <!-- Header do pedido -->
                  <div class="bg-gray-800 px-4 py-3 flex items-center justify-between">
                    <div class="flex items-center gap-3">
                      <span class="text-sm font-semibold text-white">Pedido #<%= p.id %></span>
                      <span class="text-xs px-2 py-0.5 rounded-full <%= STATUS_COR[p.status] || 'bg-gray-700 text-gray-400' %>">
                        <%= STATUS_LABEL[p.status] || p.status %>
                      </span>
                    </div>
                    <div class="flex items-center gap-4 text-xs text-gray-500">
                      <span><%= new Date(p.created_at).toLocaleDateString('pt-BR') %>
                        s <%= new Date(p.created_at).toLocaleTimeString('pt-BR', {hour:'2-digit',minute:'2-digit'}) %>
                      </span>
                      <span class="font-semibold text-white text-sm">
                        R$ <%= Number(p.total).toFixed(2).replace('.', ',') %>
                      </span>
                      <a href="/admin/pedidos/<%= p.id %>"
                        class="text-blue-400 hover:text-blue-300 transition">Ver </a>
                    </div>
                  </div>
                  <!-- Itens do pedido -->
                  <div class="px-4 py-3 space-y-1.5">
                    <% if (p.itens && p.itens[0]) { %>
                      <% p.itens.forEach(item => { %>
                        <div class="flex justify-between text-sm">
                          <span class="text-gray-300">
                            <%= item.quantidade %> <%= item.nome %>
                          </span>
                          <span class="text-gray-400">
                            R$ <%= Number(item.subtotal).toFixed(2).replace('.', ',') %>
                          </span>
                        </div>
                      <% }) %>
                    <% } %>
                    <% if (p.frete > 0) { %>
                      <div class="flex justify-between text-xs text-gray-500 pt-1 border-t border-gray-800">
                        <span>Frete</span>
                        <span>R$ <%= Number(p.frete).toFixed(2).replace('.', ',') %></span>
                      </div>
                    <% } %>
                  </div>
                </div>
              <% }) %>
            </div>
          <% } %>
        </div>

      </div>
    </div>

  </main>
</div>
</body>
</html>
