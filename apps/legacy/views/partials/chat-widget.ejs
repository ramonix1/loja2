<!-- Chat Widget -->
<style>
  #chat-widget-btn {
    position: fixed;
    bottom: 24px;
    right: 24px;
    z-index: 1000;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: var(--cor-primaria, #2563eb);
    color: white;
    border: none;
    cursor: pointer;
    font-size: 24px;
    box-shadow: 0 4px 16px rgba(0,0,0,0.25);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform .2s, box-shadow .2s;
  }
  #chat-widget-btn:hover { transform: scale(1.08); box-shadow: 0 6px 20px rgba(0,0,0,0.35); }
  #chat-widget-badge {
    position: absolute;
    top: -2px;
    right: -2px;
    background: #ef4444;
    color: white;
    border-radius: 50%;
    width: 18px;
    height: 18px;
    font-size: 11px;
    font-weight: 700;
    display: none;
    align-items: center;
    justify-content: center;
  }
  #chat-widget-janela {
    position: fixed;
    bottom: 90px;
    right: 24px;
    z-index: 1000;
    width: 340px;
    max-height: 480px;
    background: #fff;
    border-radius: 16px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.18);
    display: none;
    flex-direction: column;
    overflow: hidden;
    font-family: 'Inter', system-ui, sans-serif;
  }
  #chat-widget-janela.aberta { display: flex; }
  .cw-header {
    background: var(--cor-primaria, #2563eb);
    color: #fff;
    padding: 14px 16px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-shrink: 0;
  }
  .cw-header-nome { font-weight: 600; font-size: 15px; }
  .cw-header-sub { font-size: 12px; opacity: 0.85; margin-top: 2px; }
  .cw-fechar { background: none; border: none; color: white; cursor: pointer; font-size: 18px; opacity: 0.8; }
  .cw-fechar:hover { opacity: 1; }
  #cw-mensagens {
    flex: 1;
    overflow-y: auto;
    padding: 14px;
    background: #f8fafc;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .cw-msg { display: flex; flex-direction: column; max-width: 80%; }
  .cw-msg.cliente { align-self: flex-end; align-items: flex-end; }
  .cw-msg.bot, .cw-msg.admin { align-self: flex-start; align-items: flex-start; }
  .cw-msg-balao {
    padding: 9px 13px;
    border-radius: 14px;
    font-size: 13px;
    line-height: 1.45;
    word-break: break-word;
  }
  .cw-msg.cliente .cw-msg-balao { background: var(--cor-primaria, #2563eb); color: white; border-bottom-right-radius: 4px; }
  .cw-msg.bot .cw-msg-balao    { background: #e2f0e8; color: #1a3a2a; border-bottom-left-radius: 4px; }
  .cw-msg.admin .cw-msg-balao  { background: #ede9fe; color: #3b1f5e; border-bottom-left-radius: 4px; }
  .cw-msg-label { font-size: 11px; color: #94a3b8; margin-bottom: 3px; }
  .cw-footer { padding: 10px 12px; border-top: 1px solid #e2e8f0; background: #fff; flex-shrink: 0; }
  .cw-input-row { display: flex; gap: 8px; }
  .cw-input {
    flex: 1;
    border: 1px solid #cbd5e1;
    border-radius: 10px;
    padding: 9px 12px;
    font-size: 13px;
    outline: none;
    color: #1e293b;
  }
  .cw-input:focus { border-color: var(--cor-primaria, #2563eb); }
  .cw-send {
    background: var(--cor-primaria, #2563eb);
    color: white;
    border: none;
    border-radius: 10px;
    padding: 9px 14px;
    font-size: 13px;
    cursor: pointer;
    font-weight: 600;
    transition: filter .2s;
  }
  .cw-send:hover { filter: brightness(0.9); }
  .cw-send:disabled { opacity: 0.5; cursor: not-allowed; }
  #cw-inicio { padding: 16px; display: flex; flex-direction: column; gap: 10px; background: #f8fafc; }
  #cw-inicio p { font-size: 13px; color: #64748b; text-align: center; }
  #cw-nome-input {
    width: 100%;
    border: 1px solid #cbd5e1;
    border-radius: 10px;
    padding: 9px 12px;
    font-size: 13px;
    outline: none;
    color: #1e293b;
    box-sizing: border-box;
  }
  #cw-nome-input:focus { border-color: var(--cor-primaria, #2563eb); }
  #cw-btn-iniciar {
    width: 100%;
    background: var(--cor-primaria, #2563eb);
    color: white;
    border: none;
    border-radius: 10px;
    padding: 10px;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    transition: filter .2s;
  }
  #cw-btn-iniciar:hover { filter: brightness(0.9); }
  .cw-digitando { font-size: 12px; color: #94a3b8; padding: 0 14px 8px; }
  @media (max-width: 400px) {
    #chat-widget-janela { width: calc(100vw - 16px); right: 8px; bottom: 80px; }
  }
</style>

<button id="chat-widget-btn" title="Fale conosco" aria-label="Abrir chat">
  <span id="chat-icon-open">💬</span>
  <span id="chat-icon-close" style="display:none;"></span>
  <span id="chat-widget-badge"></span>
</button>

<div id="chat-widget-janela" role="dialog" aria-label="Chat de suporte">
  <div class="cw-header">
    <div>
      <div class="cw-header-nome">Fale Conosco</div>
      <div class="cw-header-sub"><%= locals.loja?.nome || 'Loja' %>  Atendimento online</div>
    </div>
    <button class="cw-fechar" id="cw-fechar-btn" aria-label="Fechar chat"></button>
  </div>

  <!-- Tela de incio (pede nome) -->
  <div id="cw-inicio">
    <p>Olá! Como podemos te ajudar hoje?<br>Informe seu nome para começar.</p>
    <input id="cw-nome-input" type="text" placeholder="Seu nome..." maxlength="60"
      value="<%= locals.usuario?.nome || '' %>">
    <button id="cw-btn-iniciar">Iniciar conversa </button>
  </div>

  <!-- rea de mensagens (oculta até iniciar) -->
  <div id="cw-chat-area" style="display:none;flex:1;flex-direction:column;overflow:hidden;display:none;">
    <div id="cw-mensagens"></div>
    <div id="cw-digitando" class="cw-digitando" style="display:none;"><span style="display:flex;align-items:center;width:20px;height:20px;"><%- icon('robot', 'w-5 h-5') %></span> digitando...</div>
    <div class="cw-footer" id="cw-footer-area">
      <div class="cw-input-row">
        <input id="cw-input" class="cw-input" type="text" placeholder="Escreva sua mensagem..." maxlength="500">
        <button id="cw-btn-send" class="cw-send"></button>
      </div>
    </div>
  </div>
</div>

<script src="/socket.io/socket.io.js"></script>
<script>
// Ícones SVG pré-renderizados como template literals (suportam múltiplas linhas)
const _cwIconRobot  = `<%- icon('robot',  'w-5 h-5') %>`;
const _cwIconPerson = `<%- icon('person', 'w-5 h-5') %>`;
(function() {
  const btn = document.getElementById('chat-widget-btn');
  const janela = document.getElementById('chat-widget-janela');
  const badge = document.getElementById('chat-widget-badge');
  const iconOpen = document.getElementById('chat-icon-open');
  const iconClose = document.getElementById('chat-icon-close');
  const inicio = document.getElementById('cw-inicio');
  const chatArea = document.getElementById('cw-chat-area');
  const mensagensEl = document.getElementById('cw-mensagens');
  const inputEl = document.getElementById('cw-input');
  const btnSend = document.getElementById('cw-btn-send');
  const digitando = document.getElementById('cw-digitando');

  let conversaId = null;
  let socket = null;
  let iniciado = false;
  let mensagensNaoLidas = 0;
  let jaAbriu = false;

  function toggleJanela() {
    const aberta = janela.classList.contains('aberta');
    if (aberta) {
      janela.classList.remove('aberta');
      iconOpen.style.display = '';
      iconClose.style.display = 'none';
    } else {
      janela.classList.add('aberta');
      iconOpen.style.display = 'none';
      iconClose.style.display = '';
      mensagensNaoLidas = 0;
      atualizarBadge();
      if (!iniciado) {
        const nomeInput = document.getElementById('cw-nome-input');
        setTimeout(() => nomeInput.focus(), 100);
      } else {
        setTimeout(() => inputEl.focus(), 100);
      }
    }
  }

  btn.addEventListener('click', toggleJanela);
  document.getElementById('cw-fechar-btn').addEventListener('click', toggleJanela);

  function atualizarBadge() {
    if (mensagensNaoLidas > 0) {
      badge.style.display = 'flex';
      badge.textContent = mensagensNaoLidas;
    } else {
      badge.style.display = 'none';
    }
  }

  function iniciarSocket() {
    if (socket) return;
    socket = io();

    socket.on('conversa:mensagem', (msg) => {
      if (msg.remetente === 'bot') {
        digitando.style.display = 'none';
      }
      adicionarMensagem(msg);
      if (!janela.classList.contains('aberta') && msg.remetente !== 'cliente') {
        mensagensNaoLidas++;
        atualizarBadge();
      }
    });

    socket.on('conversa:encerrada', () => {
      inputEl.disabled = true;
      btnSend.disabled = true;
      inputEl.placeholder = 'Conversa encerrada';
      adicionarSistemaMensagem('Conversa encerrada pelo atendente.');
    });
  }

  document.getElementById('cw-btn-iniciar').addEventListener('click', iniciarConversa);
  document.getElementById('cw-nome-input').addEventListener('keydown', (e) => {
    if (e.key === 'Enter') iniciarConversa();
  });

  function iniciarConversa() {
    const nome = document.getElementById('cw-nome-input').value.trim() || 'Visitante';
    iniciarSocket();

    socket.emit('conversa:iniciar', { nome }, (resp) => {
      if (!resp?.ok) return;
      conversaId = resp.conversa.id;
      iniciado = true;

      inicio.style.display = 'none';
      chatArea.style.display = 'flex';
      chatArea.style.flexDirection = 'column';
      chatArea.style.overflow = 'hidden';
      chatArea.style.flex = '1';

      resp.mensagens.forEach(m => adicionarMensagem(m, false));
      mensagensEl.scrollTop = mensagensEl.scrollHeight;
      inputEl.focus();
    });
  }

  btnSend.addEventListener('click', enviar);
  inputEl.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); enviar(); }
  });

  function enviar() {
    if (!conversaId || !socket) return;
    const texto = inputEl.value.trim();
    if (!texto) return;
    socket.emit('conversa:mensagem', { conteudo: texto });
    inputEl.value = '';
    digitando.style.display = 'block';
    setTimeout(() => { digitando.style.display = 'none'; }, 5000);
  }

  function adicionarMensagem(msg, scroll = true) {
    if (msg.remetente === 'bot') digitando.style.display = 'none';
    const div = document.createElement('div');
    div.className = `cw-msg ${msg.remetente}`;
    const label = msg.remetente === 'cliente' ? 'Você'
      : msg.remetente === 'bot'
        ? `<span style="display:flex;align-items:center;width:20px;height:20px;">${_cwIconRobot}</span> Bot`
        : `<span style="display:flex;align-items:center;width:20px;height:20px;">${_cwIconPerson}</span> Atendente`;
    div.innerHTML = `<div class="cw-msg-label">${label}</div><div class="cw-msg-balao">${escHtml(msg.conteudo)}</div>`;
    mensagensEl.appendChild(div);
    if (scroll) mensagensEl.scrollTop = mensagensEl.scrollHeight;
  }

  function adicionarSistemaMensagem(texto) {
    const div = document.createElement('div');
    div.style.cssText = 'text-align:center;font-size:12px;color:#94a3b8;padding:4px 0;';
    div.textContent = texto;
    mensagensEl.appendChild(div);
    mensagensEl.scrollTop = mensagensEl.scrollHeight;
  }

  function escHtml(str) {
    return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }
})();
</script>
