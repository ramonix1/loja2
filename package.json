{
  "name": "lojao",
  "version": "2.0.0",
  "description": "Lojão — monorepo SaaS e-commerce multi-tenant",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "turbo dev",
    "dev:all": "turbo dev",
    "dev:ui": "turbo dev --ui tui",
    "dev:api": "pnpm --filter api dev",
    "dev:admin": "pnpm --filter admin dev",
    "dev:storefront": "pnpm --filter storefront dev",
    "build": "turbo build",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "test:api": "pnpm --filter api test",
    "test:e2e": "pnpm --filter e2e test",
    "test:e2e:smoke": "pnpm --filter e2e test:smoke",
    "test:all": "pnpm --filter api test && pnpm test:e2e:smoke",
    "ci:check": "pnpm turbo typecheck && pnpm --filter api test && pnpm --filter @lojao/db test",
    "ci:install": "pnpm install --frozen-lockfile",
    "seed": "pnpm --filter api seed:dev",
    "seed:fresh": "pnpm --filter api seed:fresh"
  },
  "devDependencies": {
    "turbo": "^2.5.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "argon2",
      "esbuild"
    ]
  }
}
