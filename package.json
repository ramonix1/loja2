{
  "name": "lojao",
  "version": "1.0.0",
  "description": "Lojão — monorepo SaaS e-commerce multi-tenant (migração Strangler Fig)",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "test:api": "pnpm --filter api test",
    "test:legacy": "pnpm --filter legacy test",
    "test:e2e": "pnpm --filter e2e test",
    "test:e2e:smoke": "pnpm --filter e2e test -- --grep @smoke",
    "test:all": "pnpm test && pnpm test:e2e:smoke"
  },
  "devDependencies": {
    "turbo": "^2.5.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "argon2",
      "esbuild"
    ]
  }
}
